@page
@using Microsoft.Extensions.Localization
@using TTCCashRegister
@model TTCCashRegister.Areas.Identity.Pages.Account.LoginModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@inject IStringLocalizer<Translation> Localizer

@{
    ViewData["Title"] = Localizer["Login"];
}

<div class="identity-page">
    <div class="id-paper">
        <h1>@ViewData["Title"]</h1>
        <h2>@Localizer["UseLocalAccount"]</h2>
        <hr class="id-divider" />

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="id-alert id-alert-error" role="alert">
                @Model.ErrorMessage
            </div>
        }

        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="id-validation-summary" role="alert"></div>

            <div class="id-input-group">
                <input asp-for="Input.Email" autocomplete="username webauthn" aria-required="true" placeholder=" " />
                <label asp-for="Input.Email">@Localizer["Email"]</label>
                <span asp-validation-for="Input.Email" class="id-validation"></span>
            </div>

            <div class="id-input-group">
                <input asp-for="Input.Password" autocomplete="current-password" aria-required="true" placeholder=" " />
                <label asp-for="Input.Password">@Localizer["Password"]</label>
                <span asp-validation-for="Input.Password" class="id-validation"></span>
            </div>

            <div class="id-checkbox-wrapper">
                <input asp-for="Input.RememberMe" />
                <label asp-for="Input.RememberMe">@Localizer["RememberMe"]</label>
            </div>

            <button id="login-submit" type="submit" class="id-btn id-btn-primary id-btn-full">@Localizer["Login"]</button>

            <div class="id-or-divider">@Localizer["Or"]</div>

            <passkey-submit
                operation="Request"
                name="Input.Passkey"
                email-name="Input.Email"
                request-token-name="@Model.AntiforgeryTokenName"
                request-token-value="@Model.AntiforgeryTokenValue">
                <button type="submit" name="__passkeySubmit" class="id-btn id-btn-text id-btn-full">@Localizer["LogInWithPasskey"]</button>
            </passkey-submit>

            <hr class="id-divider" />

            <div class="id-links">
                <a id="forgot-password" asp-area="Identity" asp-page="/Account/ForgotPassword">@Localizer["ForgotPassword"]</a>
                <a asp-area="Identity" asp-page="/Account/Register" asp-route-returnUrl="@Model.ReturnUrl">@Localizer["RegisterUser"]</a>
            </div>
        </form>
    </div>
</div>

<script src="/js/passkey.js" type="module"></script>
