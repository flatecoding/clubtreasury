@using Microsoft.Extensions.Localization
@using TTCCashRegister
@using TTCCashRegister.Areas.Identity.Pages.Account.Manage
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@inject IStringLocalizer<Translation> Localizer

<ul class="id-nav">
    <li><a class="@ManageNavPages.IndexNavClass(ViewContext)" asp-area="Identity" asp-page="/Account/Manage/Index">@Localizer["Profile"]</a></li>
    <li><a class="@ManageNavPages.EmailNavClass(ViewContext)" asp-area="Identity" asp-page="/Account/Manage/Email">@Localizer["Email"]</a></li>
    <li><a class="@ManageNavPages.ChangePasswordNavClass(ViewContext)" asp-area="Identity" asp-page="/Account/Manage/ChangePassword">@Localizer["Password"]</a></li>
    <li><a class="@ManageNavPages.TwoFactorAuthenticationNavClass(ViewContext)" asp-area="Identity" asp-page="/Account/Manage/TwoFactorAuthentication">@Localizer["TwoFactorAuthentication"]</a></li>
    <li><a class="@ManageNavPages.PasskeysNavClass(ViewContext)" asp-area="Identity" asp-page="/Account/Manage/Passkeys">@Localizer["Passkeys"]</a></li>
    <li><a class="@ManageNavPages.PersonalDataNavClass(ViewContext)" asp-area="Identity" asp-page="/Account/Manage/PersonalData">@Localizer[" PersonalData"]</a></li>
</ul>
