@page
@using Microsoft.Extensions.Localization
@using TTCCashRegister
@model TTCCashRegister.Areas.Identity.Pages.Account.Manage.PasskeysModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@inject IStringLocalizer<Translation> Localizer
@{
    ViewData["Title"] = Localizer["ManagePasskeys"];
    ViewData["ActivePage"] = TTCCashRegister.Areas.Identity.Pages.Account.Manage.ManageNavPages.Passkeys;
}

<h3>@ViewData["Title"]</h3>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="id-alert id-alert-success" role="alert">
        @Model.StatusMessage
    </div>
}

@if (Model.CurrentPasskeys is { Count: > 0 })
{
    <table class="id-table">
        <tbody>
        @foreach (var passkey in Model.CurrentPasskeys)
        {
            var credentialId = Convert.ToBase64String(passkey.CredentialId).TrimEnd('=').Replace('+', '-').Replace('/', '_');
            <tr>
                <td>@(passkey.Name ?? Localizer["UnnamedPasskey"].Value)</td>
                <td>
                    <form method="post">
                        <input type="hidden" name="CredentialId" value="@credentialId" />
                        <button type="submit" asp-page-handler="Rename" class="id-btn id-btn-primary">@Localizer["Rename"]</button>
                        <button type="submit" asp-page-handler="Delete" class="id-btn id-btn-danger">@Localizer["Delete"]</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
else
{
    <p>@Localizer["NoPasskeysRegistered"]</p>
}

<form method="post" asp-page-handler="Add">
    @if (Model.CurrentPasskeys is { Count: >= 100 })
    {
        <p class="id-alert id-alert-error">@Localizer["MaxPasskeysReached"]</p>
    }
    else
    {
        <passkey-submit
            operation="Create"
            name="Input"
            request-token-name="@Model.AntiforgeryTokenName"
            request-token-value="@Model.AntiforgeryTokenValue">
            <button type="submit" name="__passkeySubmit" class="id-btn id-btn-primary">@Localizer["AddNewPasskey"]</button>
        </passkey-submit>
    }
</form>

<script src="/js/passkey.js" type="module"></script>
