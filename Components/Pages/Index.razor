@page "/"
@implements IDisposable
@using System.Globalization
@using ApexCharts
@using Microsoft.Extensions.Localization
@using ClubTreasury.Data.CashRegister
@using ClubTreasury.Data.Transaction
@inject ICashRegisterService CashRegisterService
@inject ICashRegisterLogoService CashRegisterLogoService
@inject ITransactionService TransactionService
@using ClubTreasury.Data.ThemeSetting
@inject IStringLocalizer<Translation> Localizer
@inject UserPrefService UserPrefService
@inject ILogger<Index> Logger

<PageTitle>Index</PageTitle>

<MudText class="mb-3" Typo="Typo.h4">@Localizer["WelcomeMessage"]</MudText>

<MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" TabPanelsClass="pa-6"
         ActivePanelIndexChanged="OnActivePanelIndexChanged">
    @if (_allRegisters is null)
    {
        <MudText>@Localizer["LoadingData"]</MudText>
    }
    else
    {
        @foreach (var register in _allRegisters)
        {
            var registerId = register.Id;
            <MudTabPanel Text="@register.Name">
                <MudGrid>
                    <MudItem xs="12" sm="6" md="4">
                        <MudPaper Class="pa-3 rounded-lg" Elevation="3">
                            <div class="d-flex align-center gap-3">
                                @if (_logoDataUris.TryGetValue(registerId, out var logoUri))
                                {
                                    <MudImage Src="@logoUri" Alt="@register.Name" Width="50"/>
                                }
                                <div>
                                    <MudText Typo="Typo.body2" Class="mud-text-secondary">@Localizer["AccountBalance"]</MudText>
                                    <MudText Typo="Typo.h5" Color="MudBlazor.Color.Success" Class="mt-1">
                                        @(_balances.GetValueOrDefault(registerId).ToString("C", CultureInfo.CurrentCulture))
                                    </MudText>
                                </div>
                            </div>
                        </MudPaper>
                    </MudItem>
                    <MudFlexBreak/>
                    <MudItem xs="12" md="8" lg="5">
                        <MudPaper Class="pa-2 rounded-lg" Elevation="3">
                            @if (GetChartData(registerId).Count > 0)
                            {
                                <ApexChart @ref="@(_charts[registerId])" TItem="ChartDataPoint"
                                           Options="@_chartOptions"
                                           OnZoomed="OnZoomed">
                                    <ApexPointSeries TItem="ChartDataPoint"
                                                     Items="@GetChartData(registerId)"
                                                     Name="@Localizer["AccountBalance"]"
                                                     SeriesType="SeriesType.Line"
                                                     XValue="e => e.Date"
                                                     YValue="e => (decimal)e.Balance"
                                                     OrderBy="e => e.X"/>
                                    <ApexPointSeries TItem="ChartDataPoint"
                                                     Items="@GetChartData(registerId)"
                                                     Name="@Localizer["Income"]"
                                                     SeriesType="SeriesType.Line"
                                                     XValue="e => e.Date"
                                                     YValue="e => (decimal)e.Income"
                                                     OrderBy="e => e.X"/>
                                    <ApexPointSeries TItem="ChartDataPoint"
                                                     Items="@GetChartData(registerId)"
                                                     Name="@Localizer["Expenses"]"
                                                     SeriesType="SeriesType.Line"
                                                     XValue="e => e.Date"
                                                     YValue="e => (decimal)e.Expenses"
                                                     OrderBy="e => e.X"/>
                                </ApexChart>
                            }
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </MudTabPanel>
        }
    }
</MudTabs>

@code
{
    private List<CashRegisterModel>? _allRegisters;
    private readonly Dictionary<int, List<ChartDataPoint>> _chartDataByRegister = new();
    private readonly Dictionary<int, ApexChart<ChartDataPoint>> _charts = new();
    private readonly Dictionary<int, string> _logoDataUris = new();
    private Dictionary<int, decimal> _balances = new();
    private ApexChartOptions<ChartDataPoint> _chartOptions = new();
    private int _activeRegisterId;

    private List<ChartDataPoint> GetChartData(int registerId) =>
        _chartDataByRegister.TryGetValue(registerId, out var data) ? data : [];

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        UserPrefService.PropertyChanged += OnUserPrefChanged;

        _allRegisters = (await CashRegisterService.GetAllCashRegistersAsync()).ToList();
        _balances = await CashRegisterService.GetCashRegisterBalancesAsync();

        foreach (var register in _allRegisters)
        {
            var logo = await CashRegisterLogoService.GetLogoAsync(register.Id);
            if (logo is not null)
                _logoDataUris[register.Id] = $"data:{logo.Value.ContentType};base64,{Convert.ToBase64String(logo.Value.Data)}";
        }

        var firstRegister = _allRegisters.FirstOrDefault();

        if (firstRegister is not null)
        {
            _activeRegisterId = firstRegister.Id;
            await LoadChartDataAsync(firstRegister);
        }

        UpdateChartOptions();
    }

    private async Task OnActivePanelIndexChanged(int index)
    {
        if (_allRegisters is null || index < 0 || index >= _allRegisters.Count) return;

        var register = _allRegisters[index];
        _activeRegisterId = register.Id;

        if (!_chartDataByRegister.ContainsKey(register.Id))
            await LoadChartDataAsync(register);
    }

    private void UpdateChartOptions()
    {
        var isDark = UserPrefService.IsDarkMode;
        Palette palette = isDark
            ? CustomTheme.ClubTreasuryTheme.PaletteDark
            : CustomTheme.ClubTreasuryTheme.PaletteLight;
        _chartOptions = new ApexChartOptions<ChartDataPoint>
        {
            Chart = new Chart
            {
                Background = "transparent",
                ForeColor = palette.TextPrimary.ToString(),
                Toolbar = new Toolbar
                {
                    Tools = new Tools { Download = false }
                }
            },
            Theme = new Theme { Mode = isDark ? Mode.Dark : Mode.Light },
            Colors = [palette.Primary.ToString(), palette.Success.ToString(), palette.Error.ToString()],
            Stroke = new Stroke { Curve = Curve.Smooth, Width = 3 },
            Xaxis = new XAxis { Type = XAxisType.Datetime },
            Yaxis = [new YAxis { Labels = new YAxisLabels { Formatter = "function(val) { return val.toFixed(2); }" } }],
            Tooltip = new Tooltip { Theme = isDark ? Mode.Dark : Mode.Light, X = new TooltipX { Format = "dd MMM yyyy" } }
        };
    }

    private async void OnUserPrefChanged(object? sender, System.ComponentModel.PropertyChangedEventArgs e)
    {
        try
        {
            if (e.PropertyName != nameof(UserPrefService.IsDarkMode)) return;

            UpdateChartOptions();
            await InvokeAsync(StateHasChanged);
            if (_charts.TryGetValue(_activeRegisterId, out var activeChart))
                await InvokeAsync(async () => await activeChart.UpdateOptionsAsync(true, true, true));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error updating chart theme");
        }
    }

    private async void OnZoomed(ZoomedData<ChartDataPoint> zoomedData)
    {
        try
        {
            if (!_charts.TryGetValue(_activeRegisterId, out var activeChart)) return;
            var chartData = GetChartData(_activeRegisterId);
            if (chartData.Count == 0) return;

            var dataMin = new DateTimeOffset(chartData[0].Date, TimeSpan.Zero).ToUnixTimeMilliseconds();
            var dataMax = new DateTimeOffset(chartData[^1].Date, TimeSpan.Zero).ToUnixTimeMilliseconds();
            var dataRange = dataMax - dataMin;
            var zoomRange = (zoomedData.XAxis.Max ?? dataMax) - (zoomedData.XAxis.Min ?? dataMin);

            if (zoomRange > dataRange)
                await activeChart.ZoomXAsync(dataMin, dataMax);
        }
        catch (Exception e)
        {
            Logger.LogError(e, "Error while update zoom");
        }
    }

    public void Dispose()
    {
        UserPrefService.PropertyChanged -= OnUserPrefChanged;
    }

    private async Task LoadChartDataAsync(CashRegisterModel register)
    {
        var beginDate = register.GetFiscalYearStart();
        var now = DateTime.Now;

        var startingBalance = await CalculateStartingBalanceAsync(register.Id, beginDate);
        var transactions = await GetOrderedTransactionsAsync(register.Id, beginDate, now);

        _chartDataByRegister[register.Id] = CalculateTransactionData(transactions, startingBalance, beginDate);
    }

    private async Task<double> CalculateStartingBalanceAsync(int registerId, DateTime fiscalYearStart)
    {
        var priorTransactions = await TransactionService.GetTransactionsForExportAsync(
            DateTime.MinValue, fiscalYearStart.AddDays(-1), registerId);
        return (double)priorTransactions.Sum(t => t.AccountMovement);
    }

    private async Task<List<TransactionModel>> GetOrderedTransactionsAsync(int registerId, DateTime from, DateTime to)
    {
        return (await TransactionService.GetTransactionsForExportAsync(from, to, registerId))
            .OrderBy(t => t.Date)
            .ToList();
    }

    private static List<ChartDataPoint> CalculateTransactionData(
        IList<TransactionModel> transactions, double startingBalance, DateTime fiscalYearStart)
    {
        var result = new List<ChartDataPoint>();

        var cumulativeBalance = startingBalance;
        double cumulativeIncome = 0;
        double cumulativeExpenses = 0;
        
        result.Add(new ChartDataPoint
        {
            Date = DateTime.SpecifyKind(fiscalYearStart, DateTimeKind.Utc),
            Balance = Math.Round(cumulativeBalance, 2),
            Income = 0,
            Expenses = 0
        });

        var groupedByDate = transactions
            .Where(t => t.Date.HasValue)
            .GroupBy(t => t.Date!.Value)
            .OrderBy(g => g.Key);

        foreach (var group in groupedByDate)
        {
            foreach (var t in group)
            {
                var amount = (double)t.AccountMovement;
                cumulativeBalance += amount;
                if (amount > 0)
                    cumulativeIncome += amount;
                else
                    cumulativeExpenses += Math.Abs(amount);
            }

            result.Add(new ChartDataPoint
            {
                Date = DateTime.SpecifyKind(group.Key.ToDateTime(TimeOnly.MinValue), DateTimeKind.Utc),
                Balance = Math.Round(cumulativeBalance, 2),
                Income = Math.Round(cumulativeIncome, 2),
                Expenses = Math.Round(cumulativeExpenses, 2)
            });
        }

        return result;
    }

    private class ChartDataPoint
    {
        public DateTime Date { get; init; }
        public double Balance { get; init; }
        public double Income { get; init; }
        public double Expenses { get; init; }
    }
}
