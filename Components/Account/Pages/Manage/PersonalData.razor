@page "/Account/Manage/PersonalData"

@using Microsoft.AspNetCore.Identity
@using Microsoft.Extensions.Localization
@using TTCCashRegister.Data

@inject UserManager<ApplicationUser> UserManager
@inject IdentityRedirectManager RedirectManager
@inject IStringLocalizer<TTCCashRegister.Translation> Localizer

<PageTitle>@Localizer["PersonalData"]</PageTitle>

<StatusMessage />
<h3>@Localizer["PersonalData"]</h3>

<p>Your account contains personal data that you have given us. This page allows you to download or delete that data.</p>
<p>
    <strong>Deleting this data will permanently remove your account, and this cannot be recovered.</strong>
</p>
<form action="Account/Manage/DownloadPersonalData" method="post">
    <AntiforgeryToken />
    <button class="id-btn id-btn-primary" type="submit">Download</button>
</form>
<p>
    <a href="Account/Manage/DeletePersonalData" class="id-btn id-btn-danger">Delete</a>
</p>

@code {
    [CascadingParameter] private HttpContext HttpContext { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        var user = await UserManager.GetUserAsync(HttpContext.User);
        if (user is null)
        {
            RedirectManager.RedirectToInvalidUser(UserManager, HttpContext);
        }
    }
}
