@page "/Account/Manage"

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity
@using Microsoft.Extensions.Localization
@using TTCCashRegister.Data

@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject IdentityRedirectManager RedirectManager
@inject IStringLocalizer<Translation> Localizer

<PageTitle>@Localizer["Profile"]</PageTitle>

<h3>@Localizer["Profile"]</h3>
<StatusMessage />

<EditForm Model="Input" FormName="profile" OnValidSubmit="OnValidSubmitAsync" method="post">
    <DataAnnotationsValidator />
    <div class="id-validation-summary" role="alert">
        <ValidationSummary />
    </div>
    <div class="id-input-group">
        <InputText @bind-Value="Input.Username" id="Input.Username" class="id-input" placeholder=" " />
        <label for="Input.Username">@Localizer["Username"]</label>
        <ValidationMessage For="() => Input.Username" class="id-validation" />
    </div>
    <div class="id-input-group">
        <InputText @bind-Value="Input.PhoneNumber" id="Input.PhoneNumber" class="id-input" placeholder=" " type="tel" />
        <label for="Input.PhoneNumber">@Localizer["PhoneNumber"]</label>
        <ValidationMessage For="() => Input.PhoneNumber" class="id-validation" />
    </div>
    <button type="submit" class="id-btn id-btn-primary id-btn-full">@Localizer["Save"]</button>
</EditForm>

@code {
    private ApplicationUser? _user;
    private string? _originalUsername;
    private string? _originalPhoneNumber;

    [CascadingParameter] private HttpContext HttpContext { get; set; } = null!;

    [SupplyParameterFromForm] private InputModel Input { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        Input ??= new();

        _user = await UserManager.GetUserAsync(HttpContext.User);
        if (_user is null)
        {
            RedirectManager.RedirectToInvalidUser(UserManager, HttpContext);
            return;
        }

        _originalUsername = await UserManager.GetUserNameAsync(_user);
        _originalPhoneNumber = await UserManager.GetPhoneNumberAsync(_user);

        Input.Username ??= _originalUsername;
        Input.PhoneNumber ??= _originalPhoneNumber;
    }

    private async Task OnValidSubmitAsync()
    {
        if (_user is null)
        {
            RedirectManager.RedirectToInvalidUser(UserManager, HttpContext);
            return;
        }

        if (Input.Username != _originalUsername)
        {
            var setUsernameResult = await UserManager.SetUserNameAsync(_user, Input.Username);
            if (!setUsernameResult.Succeeded)
            {
                RedirectManager.RedirectToCurrentPageWithStatus($"Error: {Localizer["FailedToSetUsername"]}", HttpContext);
                return;
            }
        }

        var phoneNumber = string.IsNullOrWhiteSpace(Input.PhoneNumber) ? null : Input.PhoneNumber;
        if (phoneNumber != _originalPhoneNumber)
        {
            var setPhoneResult = await UserManager.SetPhoneNumberAsync(_user, phoneNumber);
            if (!setPhoneResult.Succeeded)
            {
                RedirectManager.RedirectToCurrentPageWithStatus($"Error: {Localizer["FailedToSetPhoneNumber"]}", HttpContext);
                return;
            }
        }

        await SignInManager.RefreshSignInAsync(_user);
        RedirectManager.RedirectToCurrentPageWithStatus(Localizer["ProfileUpdated"], HttpContext);
    }

    private sealed class InputModel
    {
        [Required]
        public string? Username { get; set; }

        public string? PhoneNumber { get; set; }
    }
}
