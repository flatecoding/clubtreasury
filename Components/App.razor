@using ClubTreasury.Data.ThemeSetting
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@{
    var lightBg = CustomTheme.ClubTreasuryTheme.PaletteLight.Background.Value;
    var darkBg = CustomTheme.ClubTreasuryTheme.PaletteDark.Background.Value;
    var isStaticRoute = HttpContext.GetEndpoint()?.Metadata
        .GetMetadata<ExcludeFromInteractiveRoutingAttribute>() is not null;
    IComponentRenderMode? pageRenderMode = isStaticRoute ? null : InteractiveServer;
    var isDarkMode = IsDarkModeFromCookie();
}
<!DOCTYPE html>
<html lang="en" class="@(isDarkMode ? "dark" : "")" style="@(isDarkMode ? $"background-color:{darkBg}" : "")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="icon" href="favicon.ico" sizes="any" />
    <link rel="icon" href="favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="favicon-16.png" sizes="16x16" type="image/png" />
    <link rel="icon" href="favicon-32.png" sizes="32x32" type="image/png" />
    <link rel="icon" href="favicon-48.png" sizes="48x48" type="image/png" />
    <script>
        (function() {
            let isDark = false;
            try {
                let match = document.cookie.match(/ClubTreasury\.UserPrefData=([^;]+)/);
                if (match) {
                    let data = JSON.parse(decodeURIComponent(match[1]));
                    isDark = data && data.IsDarkMode === true;
                }
            } catch(e) {}

            if (isDark) {
                document.documentElement.style.backgroundColor = '@darkBg';
                document.documentElement.classList.add('dark');
            }
        })();

        // Global function for theme switching (called from Blazor)
        window.setThemeBackground = function(isDark) {
            let bg = isDark ? '@darkBg' : '@lightBg';
            document.documentElement.style.backgroundColor = bg;
            document.body.style.backgroundColor = bg;
            if (isDark) {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }
        };
    </script>
    <style>
        html.dark, html.dark body { background-color: @darkBg; color-scheme: dark; }
    </style>

    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
    <link href="_content/CodeBeam.MudBlazor.Extensions/MudExtensions.min.css" rel="stylesheet" />
    <link href="css/identity.css" rel="stylesheet" />
    <HeadOutlet @rendermode="pageRenderMode" />
    <title>Club Treasury</title>
</head>
<body>
    <Routes @rendermode="pageRenderMode" />

    <div id="blazor-error-ui">
        An error has occurred. This application may no longer respond until reloaded.
        <a href="" class="reload">Reload</a>
        <a class="dismiss">&#x1F5D9;</a>
    </div>

    <script src="_framework/blazor.web.js" autostart="false"></script>
    <script>
        Blazor.start({
            circuit: {
                reconnectionOptions: {
                    maxRetries: 30,
                    retryIntervalMilliseconds: (retryNumber, previouslyElapsedMilliseconds) =>
                        retryNumber < 5 ? 200 : retryNumber < 15 ? 1000 : 5000,
                    dialogId: 'blazor-reconnect-modal'
                },
                configureSignalR: (builder) => {
                    builder.withServerTimeout(60000);
                    builder.withKeepAliveInterval(15000);
                }
            }
        });
    </script>
    <div id="blazor-reconnect-modal" style="display:none"></div>
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    <script src="_content/CodeBeam.MudBlazor.Extensions/MudExtensions.min.js"></script>
    <script src="js/culture.js"></script>
    <script src="js/passkey.js" type="module"></script>
    <script src="js/qrcode.min.js"></script>
    <script src="js/qrcodeinit.js"></script>
</body>
</html>

@code {
    [CascadingParameter]
    public HttpContext HttpContext { get; set; } = null!;

    private bool IsDarkModeFromCookie()
    {
        var cookie = HttpContext.Request.Cookies["ClubTreasury.UserPrefData"];
        if (string.IsNullOrEmpty(cookie))
            return false;
        try
        {
            var decoded = Uri.UnescapeDataString(cookie);
            var doc = System.Text.Json.JsonDocument.Parse(decoded);
            return doc.RootElement.TryGetProperty("IsDarkMode", out var prop) && prop.GetBoolean();
        }
        catch
        {
            return false;
        }
    }
}