@using Microsoft.Extensions.Localization
@using TTCCashRegister.Data.Notification
@using TTCCashRegister.Data.OperationResult

@inject ICostCenterService CostCenterService
@inject IStringLocalizer<Translation> Localizer
@inject INotificationService NotificationService
@inject IOperationResultFactory OperationResultFactory
@inject CostCenterValidator CostCenterValidator

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form"
                 Model="_costCenterModel"
                 Validation="CostCenterValidator.ValidateValue"
                 ValidationDelay="0">

            <MudTextField @bind-Value="_costCenterModel.CostUnitName"
                          Label="@Localizer["CostCenter"]"
                          For="@(() => _costCenterModel.CostUnitName)"
                          Immediate="true" />
        </MudForm>
    </DialogContent>

    <DialogActions>
        <MudButton Color="Color.Primary"
                   OnClick="@(async () => await Save())">
            @(_isEditMode ? Localizer["Save"] : Localizer["AddEntry"])
        </MudButton>

        <MudButton Color="Color.Secondary"
                   OnClick="@Cancel">
            @Localizer["Cancel"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int? CostCenterId { get; set; }

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    private MudForm _form = new();
    private CostCenterModel _costCenterModel = new();
    private bool _isEditMode;

    protected override async Task OnInitializedAsync()
    {
        _isEditMode = CostCenterId.HasValue;
        await MudDialog.SetTitleAsync(_isEditMode ? Localizer["Edit"] : Localizer["AddEntry"]);
        await LoadCostCenterAsync();
    }

    private async Task LoadCostCenterAsync()
    {
        if (!_isEditMode)
        {
            _costCenterModel = new CostCenterModel();
            return;
        }

        _costCenterModel = await CostCenterService.GetCostCenterByIdAsync(CostCenterId!.Value)
                           ?? new CostCenterModel();
    }

    private async Task Save()
    {
        await _form.Validate();
        if (!_form.IsValid)
            return;

        var result = _isEditMode
            ? await CostCenterService.UpdateCostCenterAsync(_costCenterModel)
            : await CostCenterService.AddCostCenterAsync(_costCenterModel);

        if (result.Status is OperationResultStatus.Success)
            MudDialog.Close(DialogResult.Ok(result));
        else
            await NotificationService.ShowOperationResultAsync(result);
    }

    private void Cancel() => MudDialog.Close(DialogResult.Ok(OperationResultFactory.Canceled()));
}
