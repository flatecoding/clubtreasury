@using ClubTreasury.Components.Dialog
@using ClubTreasury.Data.OperationResult

@inherits SimpleEntityDialogBase<CostCenterModel>

@inject ICostCenterService CostCenterService
@inject CostCenterValidator CostCenterValidator

<MudDialog>
    <DialogContent>
        <MudForm @ref="Form"
                 Model="Model"
                 Validation="ValidateValue"
                 ValidationDelay="0"
                 OnEnterPressed="@Save">

            <MudTextField @bind-Value="Model.CostUnitName"
                          Label="@Localizer["CostCenter"]"
                          For="@(() => Model.CostUnitName)"
                          Immediate="true" />
        </MudForm>
    </DialogContent>

    <DialogActions>
        <MudButton Color="Color.Primary"
                   OnClick="@(async () => await Save())">
            @(IsEditMode ? Localizer["Save"] : Localizer["AddEntry"])
        </MudButton>

        <MudButton Color="Color.Secondary"
                   OnClick="@Cancel">
            @Localizer["Cancel"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int? CostCenterId { get; set; }

    protected override int? EntityId => CostCenterId;
    protected override Func<object, string, Task<IEnumerable<string>>> ValidateValue => CostCenterValidator.ValidateValue;
    protected override Task<CostCenterModel?> LoadEntityAsync(int id) => CostCenterService.GetCostCenterByIdAsync(id);
    protected override Task<Result> AddEntityAsync(CostCenterModel model) => CostCenterService.AddCostCenterAsync(model);
    protected override Task<Result> UpdateEntityAsync(CostCenterModel model) => CostCenterService.UpdateCostCenterAsync(model);
}
