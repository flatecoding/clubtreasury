@page "/addCostCenter"
@using Microsoft.Extensions.Localization
@inject ICostCenterService CostCenterService
@inject IStringLocalizer<Translation> Localizer

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" Model="_newCostCenterModel" Validation="_costunitvalidator.ValidateValue" ValidationDelay="0">
            <MudTextField @bind-Value="_newCostCenterModel.CostUnitName" Label="@Localizer["CostCenter"]"
                          For="@(() => _newCostCenterModel.CostUnitName)" Immediate="true" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" OnClick="@(async () => await AddCostUnit())">@Localizer["AddEntry"]</MudButton>
        <MudButton Color="Color.Error" OnClick="@(() => Cancel())">@Localizer["Cancel"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private MudForm _form = new();
    private readonly CostCenterValidator _costunitvalidator = new(); 
    private readonly CostCenterModel _newCostCenterModel = new();
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    
    private async Task AddCostUnit()
    {
        await _form.Validate();
        if (_form.IsValid)
        {
            await CostCenterService.AddCostCenterAsync(_newCostCenterModel);
            MudDialog.Close(DialogResult.Ok(true));
        }
    }

    private void Cancel()
    {
        MudDialog.Close(DialogResult.Cancel());
    }
}
