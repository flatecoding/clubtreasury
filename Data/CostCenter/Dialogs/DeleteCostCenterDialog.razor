@page "/deletecostcenter"
@inject CostCenterService CostCenterService

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h6">Are you sure you want to delete this cost cost?</MudText>
        <MudText Typo="Typo.subtitle1">@_costCenterName</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="DeleteCostUnit">Delete</MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int CostCenterId { get; set; }
    private string _costCenterName = string.Empty;

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        var costUnit = await CostCenterService.GetCostCenterByIdAsync(CostCenterId);
        if (costUnit != null)
        {
            _costCenterName = costUnit.CostUnitName;
        }
    }

    private async Task DeleteCostUnit()
    {
        var success = await CostCenterService.DeleteCostCenterAsync(CostCenterId);
        MudDialog.Close(success ? DialogResult.Ok(true) : DialogResult.Ok(false));
    }

    private void Cancel()
    {
        MudDialog.Close(DialogResult.Cancel());
    }
}
