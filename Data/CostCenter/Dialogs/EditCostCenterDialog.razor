@page "/editcostcenter"
@using TTCCashRegister.Data.Category
@inject CostCenterService CostCenterService
@inject CategoryService CategoryService

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" Model="_editCostCenterModelCopy" Validation="_costCenterValidator.ValidateValue" ValidationDelay="0">
            <MudTextField @bind-Value="_editCostCenterModelCopy.CostUnitName" Label="Unit Name"
                          For="@(() => _editCostCenterModelCopy.CostUnitName)" Immediate="true" />
            <MudSelect T="int" Label="Category" 
                       @bind-SelectedValues="_selectedCategoriesIds" 
                       MultiSelection="true" 
                       ToStringFunc="Converter">
                @foreach (var category in _allCategories)
                {
                    <MudSelectItem T="int" Value="@category.Id">@category.Name</MudSelectItem>
                }
            </MudSelect>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(async () => await SaveCostUnit())">Save</MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="@(() => Cancel())">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int CostCenterId { get; set; }
    private MudForm _form = new();
    private CostCenterModel _editCostCenterModel = new();
    private CostCenterModel _editCostCenterModelCopy = new();
    private readonly CostCenterValidator _costCenterValidator = new(); 
    private IEnumerable<CategoryModel> _allCategories = new List<CategoryModel>();
    private IEnumerable<int> _selectedCategoriesIds = new List<int>();

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        _allCategories = await CategoryService.GetAllCategoriesAsync();
        // Load the existing CostUnit and its BasicUnits here
        _editCostCenterModel = await CostCenterService.GetCostCenterByIdAsync(CostCenterId) ?? new CostCenterModel();

        _editCostCenterModelCopy = new CostCenterModel
        {
                Id = _editCostCenterModel.Id,
                CostUnitName = _editCostCenterModel.CostUnitName,
                Categories = new List<CategoryModel>(_editCostCenterModel.Categories)
        };
        _selectedCategoriesIds = _editCostCenterModel.Categories.Select(bu => bu.Id).ToHashSet();
    }

    private async Task SaveCostUnit()
    {
        await _form.Validate();
        if (_form.IsValid)
        {
            // Update the BasicUnitDetails based on selectedBasicUnitIds
            _editCostCenterModel.CostUnitName = _editCostCenterModelCopy.CostUnitName;
            _editCostCenterModel.Categories = _allCategories.Where(bu => _selectedCategoriesIds.Contains(bu.Id)).ToList();
            await CostCenterService.UpdateCostCenterAsync(_editCostCenterModel);
            MudDialog.Close(DialogResult.Ok(true));
        }
    }

    private void Cancel()
    {
        MudDialog.Close(DialogResult.Cancel());
    }

    private string Converter(int value)
    {
        if (value == 0)
        {
            return "Please select a category";
        }
        var categories = _allCategories.FirstOrDefault(bu => bu.Id == value);
        return categories?.Name ?? "Unknown";
    }
}
