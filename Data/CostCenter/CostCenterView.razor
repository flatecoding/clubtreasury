@page "/costCenters"
@using Microsoft.Extensions.Localization
@using ClubTreasury.Data.DialogService
@using ClubTreasury.Data.Notification
@inject ICostCenterService CostCenterService
@inject IDialogService DialogService
@inject INotificationService NotificationService
@inject IStringLocalizer<Translation> Localizer

<MudGrid Spacing="0">
    <MudItem xs="12">
        <MudText Typo="Typo.h6">
            @Localizer["CostCenterPlural"]
        </MudText>
    </MudItem>
    <MudItem xs="12" md="10" lg="4">
        <MudPaper Elevation="0">
            <MudTable Items="@_allEntries" Dense="@Dense" Hover="@Hover" Bordered="@Bordered" Striped="@Striped" FixedHeader="true"
                      @bind-SelectedItem="_selectedItem"
                      Filter="new Func<CostCenterModel, bool>(FilterFunc)"
                      SortLabel="Sort By">
                <ToolBarContent>
                    <MudIconButton
                        Variant="Variant.Filled"
                               Icon="@Icons.Material.Filled.Add"
                               Color="Color.Primary"
                               OnClick="@(() => ShowAddCostUnitDialog())">
                    </MudIconButton>
                    <MudSpacer/>
                    <MudTextField
                        @bind-Value="_searchTerm"
                        Placeholder="Search"
                        Adornment="Adornment.Start"
                        AdornmentIcon="@Icons.Material.Filled.Search"
                        IconSize="Size.Medium"
                        Class="mt-0">
                    </MudTextField>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>
                        <MudTableSortLabel
                            SortBy="new Func<CostCenterModel, object>(x => x.Id)">
                            @Localizer["Id"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel 
                            SortBy="new Func<CostCenterModel, object>(x => x.CostUnitName)">
                            @Localizer["Name"]
                            </MudTableSortLabel>
                    </MudTh>
                    <MudTh>@Localizer["Actions"]</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="@Localizer["Id"].Value">@context.Id</MudTd>
                    <MudTd DataLabel="@Localizer["Name"].Value">@context.CostUnitName</MudTd>
                    <MudTd DataLabel="Actions">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Info" aria-label="edit"
                                       OnClick="@(() => ShowEditCostUnitDialog(context.Id))"/>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" aria-label="delete"
                                       OnClick="@(() => ShowDeleteCostUnitDialog(context))"></MudIconButton>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager/>
                </PagerContent>
            </MudTable>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private IEnumerable<CostCenterModel>? _allEntries;
    private const bool Dense = true;
    private const bool Hover = true;
    private const bool Striped = true;
    private const bool Bordered = false;
    private string _searchTerm = string.Empty;
    private CostCenterModel _selectedItem = new();

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        _allEntries = await CostCenterService.GetAllCostCentersAsync();
    }

    private bool FilterFunc(CostCenterModel element) => MatchesFilter(element, _searchTerm);

    private static bool MatchesFilter(CostCenterModel? element, string searchTerm)
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
            return true;
        if (element is null)
            return false;

        var lowerString = searchTerm.ToLowerInvariant();
        return element.CostUnitName.ToLower().Contains(lowerString);
    }

    private async Task ShowAddCostUnitDialog()
    {
        var result = await DialogService.ShowDialogWithNotificationAsync<CostCenterDialog>(NotificationService);
        if (result is { IsSuccess: true })
        {
            await UpdateView();    
        }
    }

    private async Task ShowEditCostUnitDialog(int costUnitId)
    {
        var result = await DialogService.ShowDialogWithNotificationAsync<CostCenterDialog>(NotificationService,
            $"{Localizer["Edit"]}", 
            new DialogParameters { ["CostCenterId"] = costUnitId });
        if (result is { IsSuccess: true })
        {
            await UpdateView();
        }
    }

    private async Task ShowDeleteCostUnitDialog(CostCenterModel costCenter)
    {
        await DialogService.ShowConfirmDeleteDialogAsync(
            NotificationService,
            entityName: Localizer["CostCenter"].Value,
            itemName: $"{costCenter.CostUnitName}",
            onConfirm: () => CostCenterService.DeleteCostCenterAsync(costCenter.Id),
            onSuccess: UpdateView,
            deleteTitle: Localizer["Delete"]);
    }

    private async Task UpdateView()
    {
        _allEntries = await CostCenterService.GetAllCostCentersAsync();
        await InvokeAsync(StateHasChanged);
    }
}
