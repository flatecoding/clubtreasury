@page "/costCenters"
@using Microsoft.Extensions.Localization
@using TTCCashRegister.Data.CostCenter.Dialogs
@using TTCCashRegister.Data.Source
@inject ICostCenterService CostCenterService
@inject IDialogService DialogService
@inject INotificationService NotificationService
@inject IStringLocalizer<Translation> Localizer

<MudGrid Spacing="0">
    <MudItem xs="12">
        <MudText Typo="Typo.h6">
            @Localizer["CostCenterPlural"]
        </MudText>
    </MudItem>
    <MudItem xs="12" md="10" lg="4">
        <MudPaper Elevation="0">
            <MudTable Items="@_allEntries" Dense="@Dense" Hover="@Hover" Bordered="@Bordered" Striped="@Striped" FixedHeader="true"
                      @bind-SelectedItem="_selectedItem"
                      Filter="new Func<CostCenterModel, bool>(FilterFunc)"
                      SortLabel="Sort By">
                <ToolBarContent>
                    <MudIconButton
                        Variant="Variant.Filled"
                               Icon="@Icons.Material.Filled.Add"
                               Color="Color.Primary"
                               OnClick="@(() => ShowAddCostUnitDialog())">
                    </MudIconButton>
                    <MudSpacer/>
                    <MudTextField
                        @bind-Value="_searchString1"
                        Placeholder="Search"
                        Adornment="Adornment.Start"
                        AdornmentIcon="@Icons.Material.Filled.Search"
                        IconSize="Size.Medium"
                        Class="mt-0">
                    </MudTextField>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>
                        <MudTableSortLabel
                            SortBy="new Func<CostCenterModel, object>(x => x.Id)">
                            @Localizer["Id"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel 
                            SortBy="new Func<CostCenterModel, object>(x => x.CostUnitName ?? string.Empty)">
                            @Localizer["Name"]
                            </MudTableSortLabel>
                    </MudTh>
                    <MudTh>@Localizer["Actions"]</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="@Localizer["Id"].Value">@context.Id</MudTd>
                    <MudTd DataLabel="@Localizer["Name"].Value">@context.CostUnitName</MudTd>
                    <MudTd DataLabel="Actions">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Info" aria-label="edit"
                                       OnClick="@(() => ShowEditCostUnitDialog(context.Id))"/>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" aria-label="delete"
                                       OnClick="@(() => ShowDeleteCostUnitDialog(context.Id))"></MudIconButton>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager/>
                </PagerContent>
            </MudTable>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private IEnumerable<CostCenterModel>? _allEntries;
    private const bool Dense = true;
    private const bool Hover = true;
    private const bool Striped = true;
    private const bool Bordered = false;
    private string _searchString1 = string.Empty;
    private CostCenterModel _selectedItem = new();

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        _allEntries = await CostCenterService.GetAllCostCentersAsync();
    }

    private bool FilterFunc(CostCenterModel element) => FilterFunc1(element, _searchString1);

    private bool FilterFunc1(CostCenterModel? element, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (element is null)
            return false;

        var lowerString = searchString.ToLowerInvariant();
        return element.CostUnitName.ToLower().Contains(lowerString);
    }

    private async Task ShowAddCostUnitDialog()
    {
        var dialog = await DialogService.ShowAsync<AddCostCenterDialog>($"{Localizer["AddEntry"]}", new DialogParameters());
        await NotificationService.ShowDialogResultAsync(await dialog.Result);
        await UpdateView();
    }

    private async Task ShowEditCostUnitDialog(int costUnitId)
    {
        var dialog = await DialogService.ShowAsync<EditCostCenterDialog>($"{Localizer["Edit"]}", 
            new DialogParameters { ["CostCenterId"] = costUnitId });
        await NotificationService.ShowDialogResultAsync(await dialog.Result);
        await UpdateView();
    }

    private async Task ShowDeleteCostUnitDialog(int costUnitId)
    {
        var dialog = await DialogService.ShowAsync<DeleteCostCenterDialog>($"{Localizer["Delete"]}", 
            new DialogParameters { ["CostCenterId"] = costUnitId });
        await NotificationService.ShowDialogResultAsync(await dialog.Result);
        await UpdateView();
    }

    private async Task UpdateView()
    {
        _allEntries = await CostCenterService.GetAllCostCentersAsync();
        await InvokeAsync(StateHasChanged);
    }
}
