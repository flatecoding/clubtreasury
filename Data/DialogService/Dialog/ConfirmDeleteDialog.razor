@page "/confirmdelete"
@using Microsoft.Extensions.Localization
@using MudExtensions
@using TTCCashRegister.Data.Notification
@using TTCCashRegister.Data.OperationResult
@inject ILogger<ConfirmDeleteDialog> Logger
@inject INotificationService NotificationService
@inject IOperationResultFactory OperationResultFactory

<MudDialog>
    <DialogContent>
        <MudTextM3 Typo="TypoM3.Title" Size="Size.Medium">@_deleteQuestion</MudTextM3>
        <MudTextM3 Typo="TypoM3.Body" Size="Size.Large">@_entityName</MudTextM3>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" OnClick="@(() => Confirm())">@Localizer["Delete"]</MudButton>
        <MudButton Color="Color.Secondary" OnClick="@(() => Cancel())">@Localizer["Cancel"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Inject]
    private IStringLocalizer<Translation> Localizer { get; set; } = null!;
    // Parameter für universelle Nutzung
    [Parameter] public string EntityName { get; set; } = string.Empty; 
    [Parameter] public string ItemName { get; set; } = string.Empty;   
    [Parameter] public EventCallback OnConfirm { get; set; }           

    private string _entityName = string.Empty;
    private string _deleteQuestion =  string.Empty;

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    
    protected override async void OnInitialized()
    {
        try
        {
            Logger.LogInformation("Open delete dialog for: {EntityName}; {ItemName}", EntityName, ItemName);
            _deleteQuestion = Localizer["DeleteQuestion"];
            _entityName = $"{ItemName}";
            await MudDialog.SetTitleAsync($"{Localizer["Delete"]}: {EntityName}");
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogCritical(ex, "An exception occurred while deleting entity: {EntityName}", EntityName);
        }
    }

    private async Task Confirm()
    {
        try
        {
            if (OnConfirm.HasDelegate)
                await OnConfirm.InvokeAsync();
            Logger.LogInformation("An entity was deleted: '{EntityName}', Item: '{ItemName}'", EntityName, ItemName);

            MudDialog.Close(DialogResult.Ok(
                OperationResultFactory.SuccessDeleted($"{EntityName}: '{ItemName}'")));
        }
        catch (Exception ex)
        {
            Logger.LogError(
                ex,
                "Error deleting entity: EntityType: {EntityName}, Item: {ItemName}",
                EntityName,
                ItemName);

            MudDialog.Close(
                DialogResult.Ok(
                    OperationResultFactory.FailedToDelete($"{EntityName}: '{ItemName}'")));
        }
    }

    private void Cancel()
    {
        Logger.LogInformation(
            "Delete dialog for {EntityName} => {ItemName} was aborted",
            EntityName,
            ItemName);

        MudDialog.Close(
            DialogResult.Ok(OperationResultFactory.Canceled()));
    }
}