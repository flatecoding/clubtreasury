@page "/export-transaction-dialog"
@using Microsoft.Extensions.Localization
@using MudExtensions
@using TTCCashRegister.Data.Source
@using TTCCashRegister.Data.Transaction
@inject ITransactionService TransactionService
@inject ISnackbar Snackbar
@inject IStringLocalizer<Translation> Localizer
@inject ILogger<ExportTransactionDialog> Logger

<MudDialog>
    <DialogContent>
        <MudForm>
            <MudDateRangePicker Label=@Localizer["DateRange"]
                                @bind-DateRange="DateRange"
                                Editable="true"
                                DateFormat="dd.MM.yyyy"
                                Class="mx-2" />  
            <MudTextField @bind-Value ="_fileName" Label=@Localizer["FileName"] Placeholder=@Localizer["FileName"] Required="true"/>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudLoadingButton 
            @bind-Loading="_isExporting" 
            Size="Size.Small" 
            LoadingAdornment="Adornment" 
            OnClick="@(async () => await ExportPdf())" 
            Variant="Variant.Outlined" 
            Color="Color.Primary"
        >@Localizer["ExportPdf"]
        </MudLoadingButton>
        <MudLoadingButton
            @bind-Loading="_isExporting"
            Size="Size.Small"
            LoadingAdornment="Adornment"
            OnClick="@(async () => await ExportCsv())"
            Variant="Variant.Outlined"
            Color="Color.Primary">
            @Localizer["ExportCSV"]
        </MudLoadingButton>
        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Error" OnClick="@(() => Cancel())">
            @Localizer["Cancel"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public DateRange? DateRange { get; set; }
    private string _fileName = string.Empty;
    private bool _isExporting;
    private const Adornment Adornment = MudBlazor.Adornment.Start;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        DateRange = new DateRange(UTools.GetBeginDateTime(), DateTime.Now);
    }

    private async Task ExportCsv()
    {
        _isExporting = true;
        try
        {
            if (DateRange is { Start: not null, End: not null })
            {
                var start = DateRange.Start.Value.Date;
                var end = DateRange.End.Value.Date;
                if (start > end)
                {
                    Snackbar.Add( $"{Localizer["DateRangeError"]}", Severity.Warning);
                    Logger.LogError("Export not possible! Start can't be after end date!");
                    return;
                }

                var filename = $"{_fileName}_{start:yyyyMMdd}_{end:yyyyMMdd}.csv";

                var result = await TransactionService.ExportTransactionsToCsv(start, end, filename);
                MudDialog.Close(DialogResult.Ok(result));
            }
        }
        catch (Exception ex)
        {
            Logger.LogCritical(ex, "Error occured during export transactions to csv-file");
            MudDialog.Close(DialogResult.Ok(false));
        }
        finally
        {
            _isExporting = false;
        }
    }



    private async Task ExportPdf()
    {
        _isExporting = true;
        try
        {
            if (DateRange is { Start: not null, End: not null })
            {
                var start = DateRange.Start.Value.Date;
                var end = DateRange.End.Value.Date;
                if (start > end)
                {
                   
                    return;
                }
                var filename = $"{_fileName}_{start:yyyyMMdd}_{end:yyyyMMdd}.pdf";
                var result = await TransactionService.ExportTransactionsToPdf(start, end, filename);
                MudDialog.Close(DialogResult.Ok(result));
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error occured during export to csv-file: {ex.Message}");
            MudDialog.Close(DialogResult.Ok(false));
        }
        finally
        {
            _isExporting = false;
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
