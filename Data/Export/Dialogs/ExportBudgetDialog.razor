@page "/export-budget-dialog"
@using MudExtensions
@using TTCCashRegister.Data.Source
@using TTCCashRegister.Data.Transaction
@inject TransactionService TransactionService
@inject ISnackbar Snackbar;

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h6">Export Transactions</MudText>
        <MudForm>
            <MudDateRangePicker Label="Date Range"
                                @bind-DateRange="DateRange"
                                Editable="true"
                                DateFormat="dd.MM.yyyy"
                                Class="mx-2" />            
            <MudTextField @bind-Value="_fileName" Label="Filename" Placeholder="Select a filename" Required="true"/>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudLoadingButton 
            @bind-Loading="_isExporting" 
            Size="Size.Small" 
            LoadingAdornment="Adornment" 
            OnClick="@(() => ExportCsv())" 
            Variant="Variant.Filled" 
            Color="Color.Primary"
        >Export as CSV
        </MudLoadingButton>
        @*<MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="ExportPdf">Export as PDF</MudButton> *@
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="@(() => Cancel())">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    private const string SelectedFolder = "Export";
    private string _fileName = string.Empty;
    [Parameter] public DateRange? DateRange { get; set; }
    private const Adornment Adornment = MudBlazor.Adornment.Start;
    private bool _isExporting;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        DateRange = new DateRange(UTools.GetBeginDateTime(), DateTime.Now);
    }

    private async Task ExportCsv()
    {
        _isExporting = true;
        try
        {
            if (DateRange is { Start: not null, End: not null })
            {
                var start = DateRange.Start.Value.Date;
                var end = DateRange.End.Value.Date;
                if (start > end)
                {
                    Snackbar.Add("Start can't be after end date!", Severity.Warning);
                    Console.WriteLine("Start can't be after end date!");
                }

                var folderPath = Path.Combine(Path.GetTempPath(), SelectedFolder);
                var destination = Path.Combine(folderPath, $"{_fileName}_{start:yyyyMMdd}_{end:yyyyMMdd}.csv");

                var result = await TransactionService.ExportBudgetToCsv(start, end, destination);
                MudDialog.Close(DialogResult.Ok(result));
            }
        }
        catch (Exception ex)
            {
                Console.WriteLine($"Error occured during export to csv-file: {ex.Message}");
                MudDialog.Close(DialogResult.Ok(false));
            }
        finally
        {
            _isExporting = false;
        }
    }


    private async Task ExportPdf()
    {
        if (DateRange is { Start: not null, End: not null })
        {
            var start = DateRange.Start.Value.Date;
            var end = DateRange.End.Value.Date;
            if (start > end)
            {
                Snackbar.Add("Start can't be after end date!", Severity.Warning);
                Console.WriteLine("Start can't be after end date!");
            }

            var folderPath = Path.Combine(Path.GetTempPath(), SelectedFolder);
            var destination = Path.Combine(folderPath, $"{_fileName}_{start:yyyyMMdd}_{end:yyyyMMdd}.pdf");
            try
            {
                var result = await TransactionService.ExportTransactionsToPdf(start, end, destination);
                MudDialog.Close(DialogResult.Ok(result));
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error occured during export to pdf:: {ex.Message}");
                MudDialog.Close(DialogResult.Ok(false));
            }
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
