@page "/export-budget-dialog"
@using Microsoft.Extensions.Localization
@using MudExtensions
@using TTCCashRegister.Data.Source
@using TTCCashRegister.Data.Transaction
@inject ITransactionService TransactionService
@inject ISnackbar Snackbar;
@inject IStringLocalizer<Translation> Localizer
@inject ILogger<ExportBudgetDialog> Logger;

<MudDialog>
    <DialogContent>
        <MudForm>
            <MudGrid Spacing="2">
                <MudItem xs="12">
                    <MudDateRangePicker
                        Label="@Localizer["DateRange"]"
                        @bind-DateRange="DateRange"
                        Editable="true"
                        DateFormat="dd.MM.yyyy"
                        fullwidth />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="_fileName"
                                  Label="@Localizer["FileName"]"
                                  Placeholder="@Localizer["SelectFile"]"
                                  Required="true"
                                  fullwidth />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>

    <DialogActions>
        <MudLoadingButton @bind-Loading="_isExporting"
                          Size="Size.Small"
                          LoadingAdornment="Adornment"
                          OnClick="@(async () => await ExportCsv())"
                          Color="Color.Primary">
            @Localizer["ExportCSV"]
        </MudLoadingButton>

        <MudLoadingButton @bind-Loading="_isExporting"
                          Size="Size.Small"
                          LoadingAdornment="Adornment"
                          OnClick="@(async () => await ExportXlsx())"
                          Color="Color.Primary">
            @Localizer["ExportXlsx"]
        </MudLoadingButton>

        <MudButton Variant="Variant.Text"
                   Color="Color.Error"
                   OnClick="@Cancel">
            @Localizer["Cancel"]
        </MudButton>
    </DialogActions>
</MudDialog>



@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
   // private const string SelectedFolder = "Export";
    private string _fileName = string.Empty;
    [Parameter] public DateRange? DateRange { get; set; }
    private const Adornment Adornment = MudBlazor.Adornment.Start;
    private bool _isExporting;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        DateRange = new DateRange(UTools.GetBeginDateTime(), DateTime.Now);
    }

    private async Task ExportCsv()
    {
        _isExporting = true;
        try
        {
            if (DateRange is { Start: not null, End: not null })
            {
                var start = DateRange.Start.Value.Date;
                var end = DateRange.End.Value.Date;
                if (start > end)
                {
                    ShowAndLogExportError(null);
                    return;
                }
                
                var fileName = $"{_fileName}_{start:yyyyMMdd}_{end:yyyyMMdd}.csv";
                var result = await TransactionService.ExportBudgetToCsv(start, end, fileName);
                MudDialog.Close(DialogResult.Ok(result));
            }
        }
        catch (Exception ex)
            {
                ShowAndLogExportError(ex);
                MudDialog.Close(DialogResult.Ok(false));
            }
        finally
        {
            _isExporting = false;
        }
    }

    private void ShowAndLogExportError(Exception? ex)
    {
        if (ex is null)
        {
            Snackbar.Add(Localizer["DateRangeError"], Severity.Warning);
            Logger.LogWarning(Localizer["DateRangeError"]);
        }
        else
        {
            Snackbar.Add(ex.Message, Severity.Error);
            Logger.LogCritical(ex, "Error occured during export!");  
        }
    }

    private async Task ExportXlsx()
    {
        _isExporting = true;
        try
        {
            if (DateRange is { Start: not null, End: not null })
            {
                var start = DateRange.Start.Value.Date;
                var end = DateRange.End.Value.Date;
                if (start > end)
                {
                    ShowAndLogExportError(null);
                    return;
                }
                
                var fileName = $"{_fileName}_{start:yyyyMMdd}_{end:yyyyMMdd}.xlsx";
                var result = await TransactionService.ExportBudgetToExcel(start, end, fileName);
                MudDialog.Close(DialogResult.Ok(result));
            }
        }
        catch (Exception ex)
        {
           ShowAndLogExportError(ex);
            MudDialog.Close(DialogResult.Ok(false));
        }
        finally
        {
            _isExporting = false;
        }
    }

    private async Task ExportPdf()
    {
        if (DateRange is { Start: not null, End: not null })
        {
            var start = DateRange.Start.Value.Date;
            var end = DateRange.End.Value.Date;
            if (start > end)
            {
                ShowAndLogExportError(null);
            }
            var fileName = $"{_fileName}_{start:yyyyMMdd}_{end:yyyyMMdd}.pdf";
            try
            {
                var result = await TransactionService.ExportTransactionsToPdf(start, end, fileName);
                MudDialog.Close(DialogResult.Ok(result));
            }
            catch (Exception ex)
            {
                ShowAndLogExportError(ex);
                MudDialog.Close(DialogResult.Ok(false));
            }
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
