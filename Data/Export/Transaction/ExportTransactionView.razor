@page "/exportcashaudit"
@using System.Globalization
@using Microsoft.Extensions.Localization
@using TTCCashRegister.Data.Export.Dialogs
@using TTCCashRegister.Data.Source
@using TTCCashRegister.Data.Transaction
@inject ITransactionService TransactionService
@inject IDialogService DialogService
@inject INotificationService NotificationService
@inject IStringLocalizer<Translation> Localizer

<MudGrid Spacing="0">
    <MudItem xs="12">
        <MudText Typo="Typo.h6">
            @Localizer["ExportCashAuditData"]
        </MudText>
    </MudItem>
    <MudItem xs="12" md="12" lg="8">
        <MudPaper Elevation="0">
            <MudTable Items="@_allEntries"
                      Dense="@Dense"
                      Hover="@Hover"
                      Bordered="@Bordered"
                      Striped="@Striped"
                      FixedHeader="true">
                <ToolBarContent>
                    <MudButton Variant="Variant.Filled"
                               StartIcon="@Icons.Material.Filled.Download"
                               Color="Color.Secondary"
                               OnClick="@(async () => await ShowExportTransactionDialogAsync())">
                        @Localizer["ExportData"]
                    </MudButton>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>@Localizer["Date"]</MudTh>
                    <MudTh>@Localizer["DocumentNumberShort"]</MudTh>
                    <MudTh>@Localizer["Description"]</MudTh>
                    <MudTh>@Localizer["Sum"]</MudTh>
                    <MudTh>@Localizer["Account"]</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="@Localizer["Date"]">
                        @context.Date
                    </MudTd>
                    <MudTd DataLabel="@Localizer["DocumentNumberShort"]">
                        @context.Documentnumber
                    </MudTd>
                    <MudTd DataLabel="@Localizer["Description"]">
                        @context.Description
                    </MudTd>
                    <MudTd DataLabel="@Localizer["Sum"]">
                        @context.Sum.ToString("C", CultureInfo.CurrentCulture)
                    </MudTd>
                    <MudTd DataLabel="@Localizer["Account"]">
                        @context.AccountMovement.ToString("C", CultureInfo.CurrentCulture)
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private IEnumerable<TransactionModel> _allEntries = [];
    private const bool Dense = true;
    private const bool Hover = true;
    private const bool Striped = true;
    private const bool Bordered = false;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        var result = await TransactionService.GetAllTransactions();
        _allEntries = result ?? [];
    }

    private async Task ShowExportTransactionDialogAsync()
    {
        var dialog = await DialogService.ShowAsync<ExportTransactionDialog>(Localizer["Export"], new DialogParameters());
        await NotificationService.ShowDialogResultAsync(await dialog.Result);
    }
}
