@page "/export-transaction-dialog"
@using FluentValidation
@using Microsoft.Extensions.Localization
@using MudExtensions
@using TTCCashRegister.Data.Export
@using TTCCashRegister.Data.Notification
@using TTCCashRegister.Data.OperationResult
@using TTCCashRegister.Data.CashRegister
@inject IExportService ExportService
@inject ICashRegisterService CashRegisterService
@inject IOperationResultFactory OperationResultFactory
@inject IStringLocalizer<Translation> Localizer
@inject ILogger<ExportTransactionDialog> Logger
@inject ExportModelValidator ExportModelValidator
@inject INotificationService NotificationService

<MudDialog>
    <DialogContent>
        <MudForm Model="@_model" @ref="_form" Validation="@(ExportModelValidator.ValidateValue)" ValidationDelay="0">
            <MudGrid Spacing="2">
                <MudItem xs="12">
                    <MudSelect T="CashRegisterModel"
                               Label="@Localizer["CashRegister"]"
                               Required="true"
                               ToStringFunc="@_cashRegisterConverter"
                               Value="_selectedCashRegister"
                               ValueChanged="OnCashRegisterChanged">
                        @foreach (var cr in _cashRegisters)
                        {
                            <MudSelectItem T="CashRegisterModel" Value="@cr">@cr.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12">
                    <MudDateRangePicker
                        Label="@Localizer["DateRange"]"
                        @bind-DateRange="_model.DateRange"
                        Editable="true"
                        DateFormat="dd.MM.yyyy"
                        Style="width: 100%"/>
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="_model.FileName"
                                  For="@(() => _model.FileName)"
                                  Label="@Localizer["FileName"]"
                                  Placeholder="@Localizer["FileName"]"
                                  Required="true"
                                  FullWidth/>
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>

    <DialogActions>
        <MudLoadingButton @bind-Loading="_isExportingPdf"
                          LoadingAdornment="Adornment"
                          OnClick="@(async () => await ExportPdf())"
                          Color="Color.Primary">
            @Localizer["ExportPdf"]
        </MudLoadingButton>

        <MudLoadingButton @bind-Loading="_isExportingCsv"
                          LoadingAdornment="Adornment"
                          OnClick="@(async () => await ExportCsv())"
                          Color="Color.Primary">
            @Localizer["ExportCSV"]
        </MudLoadingButton>

        <MudButton
            Color="Color.Secondary"
            OnClick="@Cancel">
            @Localizer["Close"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    
    private MudForm _form = null!;
    private readonly ExportModel _model = new();
    private bool _isExportingCsv;
    private bool _isExportingPdf;
    private const Adornment Adornment = MudBlazor.Adornment.Start;
    private const int CExportTimeOut = 30;

    private List<CashRegisterModel> _cashRegisters = [];
    private CashRegisterModel? _selectedCashRegister;
    private readonly Func<CashRegisterModel, string> _cashRegisterConverter = p => p.Name;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        _cashRegisters = await CashRegisterService.GetAllCashRegisters();
        _selectedCashRegister = _cashRegisters.FirstOrDefault();
        _model.DateRange = new DateRange(_selectedCashRegister?.GetFiscalYearStart() ?? DateTime.Today, DateTime.Now);
    }

    private void OnCashRegisterChanged(CashRegisterModel? register)
    {
        _selectedCashRegister = register;
        _model.DateRange = new DateRange(register?.GetFiscalYearStart() ?? DateTime.Today, DateTime.Now);
    }

    private async Task ExportCsv()
    {
        await _form.Validate();
        var dateErrors = GetDateRangeErrors();
        if (!_form.IsValid || dateErrors is not null)
        {
            if (dateErrors is not null)
                await NotificationService.ShowOperationResultAsync(dateErrors);
            return;
        }

        _isExportingCsv = true;
        try
        {
            var start = _model.DateRange!.Start!.Value.Date;
            var end = _model.DateRange.End!.Value.Date;
            var filename = $"{_model.FileName}_{start:yyyyMMdd}_{end:yyyyMMdd}.csv";
            
            var result = await ExportService.ExportTransactionsToCsv(start, end, filename, _selectedCashRegister!.Id);

            MudDialog.Close(DialogResult.Ok(result));
        }
        catch (Exception ex)
        {
            Logger.LogCritical(ex, "Error occurred during export transactions to csv-file");
            MudDialog.Close(DialogResult.Ok(
                OperationResultFactory.ExportFailed($"{Localizer["Exception"]}")));
        }
        finally
        {
            _isExportingCsv = false;
        }
    }
    
    private async Task ExportPdf()
    {
        await _form.Validate();
        var dateErrors = GetDateRangeErrors();
        if (!_form.IsValid || dateErrors is not null)
        {
            if (dateErrors is not null)
                await NotificationService.ShowOperationResultAsync(dateErrors);
            return;
        }

        _isExportingPdf = true;
        try
        {
            var start = _model.DateRange!.Start!.Value.Date;
            var end = _model.DateRange.End!.Value.Date;
            var filename = $"{_model.FileName}_{start:yyyyMMdd}_{end:yyyyMMdd}.pdf";
            
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(CExportTimeOut));
            var result = await ExportService.ExportTransactionsToPdf(start, end, filename, _selectedCashRegister!.Id, _selectedCashRegister.Name, cts.Token);

            MudDialog.Close(DialogResult.Ok(result));
        }
        catch (OperationCanceledException)
        {
            Logger.LogWarning("PDF export was canceled (timeout {TimeOut}s) → {Filename}", CExportTimeOut, _model.FileName);
            MudDialog.Close(DialogResult.Ok(OperationResultFactory.Canceled()));
        }
        catch (Exception ex)
        {
            Logger.LogCritical(ex, "Error occurred during export transactions to pdf-file");
            MudDialog.Close(DialogResult.Ok(
                OperationResultFactory.ExportFailed($"{Localizer["Exception"]}")));
        }
        finally
        {
            _isExportingPdf = false;
        }
    }
    
    private IOperationResult? GetDateRangeErrors()
    {
        var result = ExportModelValidator.Validate(
            _model,
            options => options.IncludeProperties(x => x.DateRange));

        return result.IsValid
            ? null
            : OperationResultFactory.DateRangeInvalid(result.ToString());
    }
    
    private void Cancel()
    {
        MudDialog.Close(DialogResult.Ok(OperationResultFactory.Canceled()));
    }
}