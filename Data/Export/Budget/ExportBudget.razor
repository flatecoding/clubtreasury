@page "/exportbudget"
@using System.Globalization
@using Microsoft.Extensions.Localization
@using TTCCashRegister.Data.Export.Dialogs
@using TTCCashRegister.Data.Source
@using TTCCashRegister.Data.Transaction
@inject ITransactionService TransactionService
@inject IDialogService DialogService
@inject INotificationService NotificationService
@inject IStringLocalizer<Translation> Localizer

<MudPaper Class="mt-4" Style="width:50%;">
    <MudTable Class="mt-2" Items="@_transactions" Dense="@Dense" Hover="@Hover" Bordered="@Bordered" Striped="@Striped" FixedHeader="true">
        <ToolBarContent>
            <MudButton Class = "ml-2"
                       Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.Download"
                       Color="Color.Secondary"
                       OnClick="ShowExportBudgetDialog">
                @Localizer["Export"]
            </MudButton>
        </ToolBarContent>
        <ColGroup>
            <col style="width:200px;"/>    @*Cost center*@
            <col style="width:200px;"/>   @*Categories*@
            <col />    @*Position details*@
            <col style="min-width:80px;" />    @*Acc. mvm.*@
        </ColGroup>
        <HeaderContent>
            <MudTh>@Localizer["CostCenter"]</MudTh>
            <MudTh>@Localizer["Category"]</MudTh>
            <MudTh>@Localizer["ItemDetail"]</MudTh>
            <MudTh>@Localizer["Account"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="@Localizer["CostCenter"].Value">@context.Allocation.CostCenter.CostUnitName</MudTd>
            <MudTd DataLabel="@Localizer["Category"].Value">@context.Allocation.Category?.Name</MudTd>
            <MudTd DataLabel="@Localizer["ItemDetail"].Value">@context.Allocation.ItemDetail?.CostDetails</MudTd>
            <MudTd DataLabel="@Localizer["Account"].Value">@context.AccountMovement.ToString("C", CultureInfo.CurrentCulture)</MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
</MudPaper>

@code {
    private IEnumerable<TransactionModel> _transactions = [];
    private const bool Dense = true;
    private const bool Hover = true;
    private const bool Striped = true;
    private const bool Bordered = false;
    
    protected override async Task OnInitializedAsync()
    {
         await base.OnInitializedAsync();
         var result = await TransactionService.GetAllTransactions();
         _transactions = result ?? [];
    }

    private async Task ShowExportBudgetDialog()
    {
        var dialog = await DialogService.ShowAsync<ExportBudgetDialog>(Localizer["ExportBudget"], new DialogParameters());
        await NotificationService.ShowDialogResultAsync(await dialog.Result);
    }
}
