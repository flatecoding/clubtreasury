@page "/export-budget-dialog"
@using FluentValidation
@using Microsoft.Extensions.Localization
@using MudExtensions
@using ClubTreasury.Data.Export
@using ClubTreasury.Data.Notification
@using ClubTreasury.Data.OperationResult
@using ClubTreasury.Data.CashRegister
@inject IExportService ExportService
@inject ICashRegisterService CashRegisterService
@inject IResultFactory ResultFactory
@inject IStringLocalizer<Translation> Localizer
@inject ILogger<ExportBudgetDialog> Logger
@inject ExportModelValidator ExportModelValidator
@inject INotificationService NotificationService

<MudDialog>
    <DialogContent>
        <MudForm Model="@_model" @ref="_form" Validation="@(ExportModelValidator.ValidateValue)" ValidationDelay="0">
            <MudGrid Spacing="2">
                <MudItem xs="12">
                    <MudSelect T="CashRegisterModel"
                               Label="@Localizer["CashRegister"]"
                               Required="true"
                               ToStringFunc="@_cashRegisterConverter"
                               Value="_selectedCashRegister"
                               ValueChanged="OnCashRegisterChanged">
                        @foreach (var cr in _cashRegisters)
                        {
                            <MudSelectItem T="CashRegisterModel" Value="@cr">@cr.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12">
                    <MudDateRangePicker
                        Label="@Localizer["DateRange"]"
                        @bind-DateRange="_model.DateRange"
                        Editable="true"
                        DateFormat="dd.MM.yyyy"
                        Style="width: 100%" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="_model.FileName"
                                  For="@(() => _model.FileName)"
                                  Label="@Localizer["FileName"]"
                                  Placeholder="@Localizer["FileName"]"
                                  Required="true"
                                  FullWidth />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>

    <DialogActions>
        <MudLoadingButton @bind-Loading="_isExportingCsv"
                          LoadingAdornment="Adornment"
                          OnClick="@ExportCsv"
                          Color="Color.Primary">
            @Localizer["ExportCSV"]
        </MudLoadingButton>

        <MudLoadingButton @bind-Loading="_isExportingXlsx"
                          LoadingAdornment="Adornment"
                          OnClick="@ExportXlsx"
                          Color="Color.Primary">
            @Localizer["ExportXlsx"]
        </MudLoadingButton>

        <MudButton Variant="Variant.Text"
                   Color="Color.Secondary"
                   OnClick="@Cancel">
            @Localizer["Close"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    private MudForm _form = null!;
    private readonly ExportModel _model = new();
    private bool _isExportingCsv;
    private bool _isExportingXlsx;
    private const Adornment Adornment = MudBlazor.Adornment.Start;

    private List<CashRegisterModel> _cashRegisters = [];
    private CashRegisterModel? _selectedCashRegister;
    private readonly Func<CashRegisterModel?, string> _cashRegisterConverter = p => p?.Name ?? string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _cashRegisters = await CashRegisterService.GetAllCashRegistersAsync();
        _selectedCashRegister = _cashRegisters.FirstOrDefault();
        _model.DateRange = new DateRange(_selectedCashRegister?.GetFiscalYearStart() ?? DateTime.Today, DateTime.Now);
    }

    private void OnCashRegisterChanged(CashRegisterModel? register)
    {
        _selectedCashRegister = register;
        _model.DateRange = new DateRange(register?.GetFiscalYearStart() ?? DateTime.Today, DateTime.Now);
    }

    private async Task ExportCsv()
    {
        if (!await ValidateFormAsync())
            return;

        _isExportingCsv = true;
        try
        {
            var start = _model.DateRange!.Start!.Value.Date;
            var end = _model.DateRange.End!.Value.Date;
            var filename = $"{_model.FileName}_{start:yyyyMMdd}_{end:yyyyMMdd}.csv";

            var result = await ExportService.ExportBudgetToCsvAsync(start, end, filename, _selectedCashRegister!.Id);
            MudDialog.Close(DialogResult.Ok(result));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected error during export");
            MudDialog.Close(DialogResult.Ok(
                ResultFactory.ExportFailed(Localizer["Exception"])));
        }
        finally
        {
            _isExportingCsv = false;
        }
    }

    private async Task ExportXlsx()
    {
        if (!await ValidateFormAsync())
            return;

        _isExportingXlsx = true;
        try
        {
            var start = _model.DateRange!.Start!.Value.Date;
            var end = _model.DateRange.End!.Value.Date;
            var fileName = $"{_model.FileName}_{start:yyyyMMdd}_{end:yyyyMMdd}.xlsx";

            var result = await ExportService.ExportBudgetToExcelAsync(start, end, fileName, _selectedCashRegister!.Id);
            MudDialog.Close(DialogResult.Ok(result));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error occurred during export!");
            MudDialog.Close(DialogResult.Ok(
                ResultFactory.ExportFailed(Localizer["Exception"])));
        }
        finally
        {
            _isExportingXlsx = false;
        }
    }

    private async Task<bool> ValidateFormAsync()
    {
        await _form.Validate();
        var dateErrors = GetDateRangeErrors();
        if (_form.IsValid && dateErrors is null)
            return true;

        if (dateErrors is not null)
            await NotificationService.ShowResultAsync(dateErrors);
        return false;
    }

    private Result? GetDateRangeErrors()
    {
        var result = ExportModelValidator.Validate(
            _model,
            options => options.IncludeProperties(x => x.DateRange));

        return result.IsValid
            ? null
            : ResultFactory.DateRangeInvalid(result.ToString());
    }

    private void Cancel() => MudDialog.Close(DialogResult.Ok(ResultFactory.Canceled()));
}
