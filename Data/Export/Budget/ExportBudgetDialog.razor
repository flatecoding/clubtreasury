@page "/export-budget-dialog"
@using Microsoft.Extensions.Localization
@using MudExtensions
@using TTCCashRegister.Data.Export
@using TTCCashRegister.Data.OperationResult
@using TTCCashRegister.Data.CashRegister
@using TTCCashRegister.Data.Source
@inject IExportService ExportService
@inject ICashRegisterService CashRegisterService
@inject IOperationResultFactory OperationResultFactory
@inject IStringLocalizer<Translation> Localizer
@inject ILogger<ExportBudgetDialog> Logger

<MudDialog>
    <DialogContent>
        <MudForm Model="@_model" @ref="_form">
            <MudGrid Spacing="2">
                <MudItem xs="12">
                    <MudSelect T="CashRegisterModel"
                               Label="@Localizer["CashRegister"]"
                               Required="true"
                               ToStringFunc="@_cashRegisterConverter"
                               @bind-Value="_selectedCashRegister">
                        @foreach (var cr in _cashRegisters)
                        {
                            <MudSelectItem T="CashRegisterModel" Value="@cr">@cr.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12">
                    <MudDateRangePicker
                        Label="@Localizer["DateRange"]"
                        @bind-DateRange="_model.DateRange"
                        Editable="true"
                        DateFormat="dd.MM.yyyy"
                        Style="width: 100%" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="_model.FileName"
                                  For="@(() => _model.FileName)"
                                  Label="@Localizer["FileName"]"
                                  Placeholder="@Localizer["FileName"]"
                                  Required="true"
                                  FullWidth />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>

    <DialogActions>
        <MudLoadingButton @bind-Loading="_isExportingCsv"
                          LoadingAdornment="Adornment"
                          OnClick="@(async () => await ExportCsv())"
                          Color="Color.Primary">
            @Localizer["ExportCSV"]
        </MudLoadingButton>

        <MudLoadingButton @bind-Loading="_isExportingXlsx"
                          LoadingAdornment="Adornment"
                          OnClick="@(async () => await ExportXlsx())"
                          Color="Color.Primary">
            @Localizer["ExportXlsx"]
        </MudLoadingButton>

        <MudButton Variant="Variant.Text"
                   Color="Color.Secondary"
                   OnClick="@Cancel">
            @Localizer["Close"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    
    private MudForm _form = null!;
    private readonly ExportModel _model = new();
    private bool _isExportingCsv;
    private bool _isExportingXlsx;
    private const Adornment Adornment = MudBlazor.Adornment.Start;

    private List<CashRegisterModel> _cashRegisters = [];
    private CashRegisterModel? _selectedCashRegister;
    private readonly Func<CashRegisterModel, string> _cashRegisterConverter = p => p?.Name ?? string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        _model.DateRange = new DateRange(UTools.GetBeginDateTime(), DateTime.Now);
        _cashRegisters = await CashRegisterService.GetAllCashRegisters();
        _selectedCashRegister = _cashRegisters.FirstOrDefault();
    }

    private async Task ExportCsv()
    {
        await _form.Validate();
        if (!_form.IsValid)
            return;

        _isExportingCsv = true;
        try
        {
            var start = _model.DateRange!.Start!.Value.Date;
            var end = _model.DateRange.End!.Value.Date;
            var filename = $"{_model.FileName}_{start:yyyyMMdd}_{end:yyyyMMdd}.csv";
        
            var result = await ExportService.ExportBudgetToCsv(start, end, filename, _selectedCashRegister!.Id);
            MudDialog.Close(DialogResult.Ok(result));
        }
        catch (Exception ex)
        {
            Logger.LogCritical(ex, "Unexpected error during export");
            MudDialog.Close(DialogResult.Ok(
                OperationResultFactory.ExportFailed($"{Localizer["Exception"]}")));
        }
        finally
        {
            _isExportingCsv = false;
        }
    }

    private async Task ExportXlsx()
    {
        await _form.Validate();
        if (!_form.IsValid)
            return;

        _isExportingXlsx = true;
        try
        {
            var start = _model.DateRange!.Start!.Value.Date;
            var end = _model.DateRange.End!.Value.Date;
            var fileName = $"{_model.FileName}_{start:yyyyMMdd}_{end:yyyyMMdd}.xlsx";
            
            var result = await ExportService.ExportBudgetToExcel(start, end, fileName, _selectedCashRegister!.Id);

            MudDialog.Close(DialogResult.Ok(result));
        }
        catch (Exception ex)
        {
            Logger.LogCritical(ex, "Error occurred during export!");
            MudDialog.Close(DialogResult.Ok(
                OperationResultFactory.ExportFailed($"{Localizer["Exception"]}")));
        }
        finally
        {
            _isExportingXlsx = false;
        }
    }

    private void Cancel()
    {
        MudDialog.Close(DialogResult.Ok(OperationResultFactory.Canceled()));
    }
}