@page "/addunitdetail"
@using TTCCashRegister.Data.BasicUnit
@using TTCCashRegister.Data.UnitDetail
@using TTCCashRegister.Data.Accounts
@inject UnitDetailService UnitDetailService
@inject BasicUnitService BasicUnitService
@inject AccountsService AccountsService

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" Model="_newDetailModel" Validation="_unitDetailValidator.ValidateValue" ValidationDelay="0">
            
            <MudTextField @bind-Value="_newDetailModel.CostDetails" 
                          Label="Detailed position"
                          For="@(() => _newDetailModel.CostDetails)"
                          Required="true" 
                          Immediate="true" />

            <MudSelect T="BasicUnitModel" 
                       Label="Basic Unit" 
                       @bind-SelectedValues="_selectedBasicUnits"
                       MultiSelection="true"
                       Required="true">
                @foreach (var basicUnit in _allBasicUnits)
                {
                    <MudSelectItem T="BasicUnitModel" Value="@basicUnit">@basicUnit.Name</MudSelectItem>
                }
            </MudSelect>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(async () => await AddUnitDetailAsync())">
            Add
        </MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel">
            Cancel
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    private MudForm _form = new();
    private readonly UnitDetailsModel _newDetailModel = new();
    private readonly UnitDetailValidator _unitDetailValidator = new();
    private IEnumerable<BasicUnitModel> _allBasicUnits = new List<BasicUnitModel>();
    private IEnumerable<BasicUnitModel> _selectedBasicUnits = new List<BasicUnitModel>();

    protected override async Task OnInitializedAsync()
    {
        // Alle BasicUnits laden
        _allBasicUnits = await BasicUnitService.GetAllBasicUnitsAsync();
    }

    private async Task AddUnitDetailAsync()
    {
        await _form.Validate();
        if (!_form.IsValid || !_selectedBasicUnits.Any())
            return;

        // 1. UnitDetail speichern
        var createdDetail = await UnitDetailService.AddUnitDetailAsync(_newDetailModel);

        // 2. N:M-Beziehung über Accounts erstellen
        foreach (var account in _selectedBasicUnits.Select(basicUnit => new AccountsModel
                 {
                     BasicUnitId = basicUnit.Id,
                     CostUnitId = basicUnit.CostUnitId,
                     UnitDetailsId = createdDetail?.Id
                 }))
        {
            await AccountsService.EnsureAccountExistsAsync(account);
        }

        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel()
    {
        MudDialog.Close(DialogResult.Cancel());
    }
}
