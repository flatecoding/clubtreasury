@page "/addunitdetail"
@using TTCCashRegister.Data.BasicUnit
@using TTCCashRegister.Data.CostUnit
@using TTCCashRegister.Data.UnitDetail
@inject UnitDetailService UnitDetailService
@inject BasicUnitService BasicUnitService

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" Model="_newDetailModel" Validation="_unitDetailValidator.ValidateValue" ValidationDelay="0">
            <MudTextField @bind-Value="_newDetailModel.CostDetails" Label="Detailed position"
                          For="@(() => _newDetailModel.CostDetails)"/>
            <MudSelect T="int" Label="Basic Unit" @bind-Value="_newDetailModel.BasicUnitId" Placeholder="Select a basic position"
                       For="@(() => _newDetailModel.BasicUnitId)">
                @foreach (var basicUnit in _allBasicUnits)
                {
                    <MudSelectItem T="int" Value="@basicUnit.Id">@basicUnit.Name</MudSelectItem>
                }
            </MudSelect>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(async () => await AddUnitDetail())">Add</MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;
    private MudForm _form = new();
    private readonly UnitDetailsModel _newDetailModel = new();
    private IEnumerable<BasicUnitModel> _allBasicUnits = new List<BasicUnitModel>();
    private readonly UnitDetailValidator _unitDetailValidator = new();
    
    protected override async Task OnInitializedAsync()
    {
        _allBasicUnits = await BasicUnitService.GetAllBasicUnitsAsync();
    }


    private async Task AddUnitDetail()
    {
        await _form.Validate();
        if (_form.IsValid)
        {
            await UnitDetailService.AddUnitDetailAsync(_newDetailModel);
            MudDialog.Close(DialogResult.Ok(true));
        }
    }

    private void Cancel()
    {
        MudDialog.Close(DialogResult.Cancel());
    }
}
