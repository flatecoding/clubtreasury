@page "/allocationdialog"
@using Microsoft.Extensions.Localization
@using TTCCashRegister.Data.Category
@using TTCCashRegister.Data.CostCenter
@using TTCCashRegister.Data.ItemDetail
@inject IAllocationService AllocationService
@inject ICostCenterService CostCenterService
@inject ICategoryService CategoryService
@inject IItemDetailService ItemDetailService
@inject IStringLocalizer<Translation> Localizer

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" Model="_allocationModel">
            <MudSelect T="int" Label="@Localizer["CostCenter"]" @bind-Value="_allocationModel.CostCenterId" Required="true">
                @foreach (var cc in _costCenters)
                {
                    <MudSelectItem T="int" Value="@cc.Id">@cc.CostUnitName</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="int" Label="@Localizer["Category"]" @bind-Value="_allocationModel.CategoryId" Required="true">
                @foreach (var cat in _categories)
                {
                    <MudSelectItem T="int" Value="@cat.Id">@cat.Name</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="int?" Label="@Localizer["ItemDetail"]" @bind-Value="_allocationModel.ItemDetailId">
                <MudSelectItem T="int?" Value="null">None</MudSelectItem>
                @foreach (var item in _itemDetails)
                {
                    <MudSelectItem T="int?" Value="@item.Id">@item.CostDetails</MudSelectItem>
                }
            </MudSelect>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" OnClick="@(async () => await Save())">
            @(_isEditMode ? $"{Localizer["Save"]}" : $"{@Localizer["AddEntry"]}")
        </MudButton>
        <MudButton Color="Color.Error" OnClick="@(() => Cancel())">@Localizer["Cancel"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int? AllocationId { get; set; }
    private MudForm _form = new();
    private AllocationModel _allocationModel = new();
    private bool _isEditMode;

    private List<CostCenterModel> _costCenters = new();
    private List<CategoryModel> _categories = new();
    private List<ItemDetailModel> _itemDetails = new();

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        _isEditMode = AllocationId.HasValue;

        
        _costCenters = (await CostCenterService.GetAllCostCentersAsync())
            .OrderBy(c => c.CostUnitName)
            .ToList();
        _categories = (await CategoryService.GetAllCategoriesAsync())
            .OrderBy(c => c.Name)
            .ToList();
        _itemDetails = (await ItemDetailService.GetAllItemDetailsAsync())
            .OrderBy(i => i.CostDetails)
            .ToList();
            
        if (_isEditMode && AllocationId is not null)
        {
            _allocationModel = await AllocationService.GetAllocationsByIdAsync(AllocationId.Value) ?? new AllocationModel();
            await MudDialog.SetTitleAsync($"{Localizer["Edit"]}");
        }
        else
        {
            _allocationModel = new AllocationModel();
            await MudDialog.SetTitleAsync($"{Localizer["AddEntry"]}");
        }

        StateHasChanged();
    }

    private async Task Save()
    {
        await _form.Validate();
        if (_form.IsValid)
        {
            bool result;
            if (_isEditMode) 
                result = await AllocationService.UpdateAllocationAsync(_allocationModel);
            else
                result = await AllocationService.AddAllocationAsync(_allocationModel);

            MudDialog.Close(DialogResult.Ok(result));
        }
    }

    private void Cancel()
    {
        MudDialog.Close(DialogResult.Cancel());
    }
}
