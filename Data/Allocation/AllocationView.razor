@page "/allocations"
@using ClubTreasury.Components.View
@using ClubTreasury.Data.OperationResult

@inherits CrudViewBase<AllocationModel, AllocationDialog>

@inject IAllocationService AllocationService

<MudGrid Spacing="0">
    <MudItem xs="12">
        <MudText Typo="Typo.h6">
            @Localizer["AllocationPlural"]
        </MudText>
    </MudItem>
    <MudItem xs="12" md="10" lg="6">
        <MudPaper Elevation="0">
            <MudTable Items="@AllEntries"
                      Dense="true"
                      Hover="true"
                      Bordered="false"
                      Striped="true"
                      Filter="new Func<AllocationModel,bool>(FilterFunc)"
                      SortLabel="Sort By">
                <ToolBarContent>
                    <MudIconButton Variant="Variant.Filled"
                               Icon="@Icons.Material.Filled.Add"
                               Color="Color.Primary"
                               OnClick="@ShowAddDialog">
                    </MudIconButton>
                    <MudSpacer />
                    <MudTextField @bind-Value="SearchTerm"
                                  Placeholder="Search"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  IconSize="Size.Medium"
                                  Class="mt-0" />
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>
                        <MudTableSortLabel
                            SortBy="new Func<AllocationModel, object>(x => x.Id)">
                            @Localizer["Id"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel
                            SortBy="new Func<AllocationModel, object>(x => x.CostCenter.CostUnitName)">
                            @Localizer["CostCenter"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel
                            SortBy="new Func<AllocationModel, object>(x => x.Category.Name)">
                            @Localizer["Category"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel
                            SortBy="new Func<AllocationModel, object?>(x => x.ItemDetail?.CostDetails)">
                            @Localizer["ItemDetail"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>@Localizer["Actions"]</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="@Localizer["Id"]">
                        @context.Id
                    </MudTd>
                    <MudTd DataLabel="@Localizer["CostCenter"]">
                        @context.CostCenter.CostUnitName
                    </MudTd>
                    <MudTd DataLabel="@Localizer["Category"]">
                        @context.Category.Name
                    </MudTd>
                    <MudTd DataLabel="@Localizer["ItemDetail"]">
                        @context.ItemDetail?.CostDetails
                    </MudTd>
                    <MudTd DataLabel="@Localizer["Actions"]">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Info"
                                       aria-label="edit"
                                       OnClick="@(() => ShowEditDialog(context.Id))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       aria-label="delete"
                                       OnClick="@(() => ShowDeleteDialog(context))" />
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    protected override string EntityIdParameterName => "AllocationId";
    protected override string EntityLocalizedName => Localizer["Allocation"];
    protected override int GetEntityId(AllocationModel entity) => entity.Id;
    protected override Task<List<AllocationModel>> LoadAllAsync() => AllocationService.GetAllAllocationsAsync();
    protected override Task<Result> DeleteEntityAsync(int id) => AllocationService.DeleteAllocationAsync(id);

    protected override string GetEntityDisplayName(AllocationModel entity) =>
        $"{entity.CostCenter.CostUnitName} - {entity.Category.Name} - {entity.ItemDetail?.CostDetails}";

    protected override bool MatchesFilter(AllocationModel? element, string searchTerm)
    {
        if (element == null)
            return false;
        if (string.IsNullOrWhiteSpace(searchTerm))
            return true;

        var term = searchTerm.Trim().ToLowerInvariant();
        return element.CostCenter.CostUnitName.ToLowerInvariant().Contains(term)
               || element.Category.Name.ToLowerInvariant().Contains(term)
               || (element.ItemDetail != null && element.ItemDetail.CostDetails.ToLowerInvariant().Contains(term));
    }
}
