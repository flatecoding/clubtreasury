@page "/allocations"
@using Microsoft.Extensions.Localization
@using TTCCashRegister.Data.Allocation.Dialog
@using TTCCashRegister.Data.Dialog
@using TTCCashRegister.Data.Source
@inject IAllocationService AllocationService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject INotificationService NotificationService
@inject IStringLocalizer<Translation> Localizer

<h2>@Localizer["AllocationPlural"]</h2>

<MudPaper Class="mt-4" Style="width:70%;">
    <MudTable Items="@_allAllocations" Dense="true" Hover="true" Bordered="false" Striped="true"
              @bind-SelectedItem="_selectedAllocation"
              Filter="new Func<AllocationModel,bool>(FilterFunc)">
        <ToolBarContent>
            <MudButton Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.Add"
                       Color="Color.Primary"
                       @onclick="ShowAddAllocationDialog">
                @Localizer["AddEntry"]
            </MudButton>
            <MudSpacer />
            <MudTextField @bind-Value="_searchString"
                          Placeholder="Search"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium"
                          Class="mt-0">
            </MudTextField>
        </ToolBarContent>
        <HeaderContent>
            <MudTh>@Localizer["Id"]<MudTableSortLabel SortBy="new Func<AllocationModel, object>(x => x.Id)" /></MudTh>
            <MudTh>@Localizer["CostCenter"]<MudTableSortLabel SortBy="new Func<AllocationModel, object>(x => x.CostCenter.CostUnitName)" /></MudTh>
            <MudTh>@Localizer["Category"]<MudTableSortLabel SortBy="new Func<AllocationModel, object>(x => x.Category.Name)" /></MudTh>
            <MudTh>@Localizer["ItemDetail"]<MudTableSortLabel SortBy="new Func<AllocationModel, object>(x => x.ItemDetail?.CostDetails)" /></MudTh>
            <MudTh>@Localizer["Actions"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="@Localizer["Id"]">@context.Id</MudTd>
            <MudTd DataLabel="@Localizer["CostCenter"]">@context.CostCenter?.CostUnitName</MudTd>
            <MudTd DataLabel="@Localizer["Category"]">@context.Category?.Name</MudTd>
            <MudTd DataLabel="@Localizer["ItemDetail"]">@context.ItemDetail?.CostDetails</MudTd>
            <MudTd DataLabel="@Localizer["Actions"]">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Info" aria-label="edit" @onclick="() => ShowEditAllocationDialog(context.Id)" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" aria-label="delete" @onclick="() => ShowDeleteAllocationDialog(context)" />
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
</MudPaper>

@code {
    private IEnumerable<AllocationModel>? _allAllocations;
    private AllocationModel? _selectedAllocation;
    private string _searchString = string.Empty;

    private readonly DialogOptions _dialogOptions = new()
    {
        MaxWidth = MaxWidth.Medium,
        FullWidth = true,
        BackdropClick = false,
        CloseButton = true
    };

    protected override async Task OnInitializedAsync()
    {
        await UpdateAllocations();
    }

    private async Task UpdateAllocations()
    {
        _allAllocations = await AllocationService.GetAllAllocationsAsync();
        await InvokeAsync(StateHasChanged);
    }

    private bool FilterFunc(AllocationModel? allocation)
    {
        if (allocation == null)
            return false;

        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        var term = _searchString.Trim().ToLowerInvariant();

        var matchesCostCenter = allocation.CostCenter.CostUnitName.ToLowerInvariant().Contains(term);
        var matchesCategory = allocation.Category.Name.ToLowerInvariant().Contains(term);
        var matchesItemDetail = allocation.ItemDetail != null && allocation.ItemDetail.CostDetails.ToLowerInvariant().Contains(term);

        return matchesCostCenter || matchesCategory || matchesItemDetail;
    }

    private async Task ShowAddAllocationDialog()
    {
        var dialog = await DialogService.ShowAsync<AllocationDialog>(string.Empty);
        await NotificationService.ShowDialogResultAsync(await dialog.Result);
        await UpdateAllocations();
    }

    private async Task ShowEditAllocationDialog(int allocationId)
    {
        var parameters = new DialogParameters { ["AllocationId"] = allocationId };
        var dialog = await DialogService.ShowAsync<AllocationDialog>($"{Localizer["Edit"]} ", parameters, _dialogOptions);
        await NotificationService.ShowDialogResultAsync(await dialog.Result);
        await UpdateAllocations();
    }

    private async Task ShowDeleteAllocationDialog(AllocationModel allocation)
    {
        var parameters = new DialogParameters
        {
            ["EntityName"] = Localizer["Allocation"].Value,
            ["ItemName"] = $"{allocation.CostCenter.CostUnitName} - {allocation.Category.Name}",
            ["OnConfirm"] = EventCallback.Factory.Create(this, async () =>
            {
                await AllocationService.DeleteAllocationAsync(allocation.Id);
                await UpdateAllocations();
                Snackbar.Add($"{Localizer["DeleteSuccessful"]}", Severity.Success);
            })
        };

        await DialogService.ShowAsync<ConfirmDeleteDialog>($"{Localizer["Delete"]}", parameters, _dialogOptions);
    }
}
