@page "/allocations"
@using Microsoft.Extensions.Localization
@using TTCCashRegister.Data.DialogService
@using TTCCashRegister.Data.Notification
@using TTCCashRegister.Data.OperationResult
@inject IAllocationService AllocationService
@inject IDialogService DialogService
@inject INotificationService NotificationService
@inject IStringLocalizer<Translation> Localizer

<MudGrid Spacing="0">
    <MudItem xs="12">
        <MudText Typo="Typo.h6">
            @Localizer["AllocationPlural"]
        </MudText>
    </MudItem>

    <MudItem xs="12" md="10" lg="6">
        <MudPaper Elevation="0">
            <MudTable Items="@_allAllocations"
                      Dense="true"
                      Hover="true"
                      Bordered="false"
                      Striped="true"
                      @bind-SelectedItem="_selectedAllocation"
                      Filter="new Func<AllocationModel,bool>(FilterFunc)"
                      SortLabel="Sort By">
                <ToolBarContent>
                    <MudIconButton Variant="Variant.Filled"
                               Icon="@Icons.Material.Filled.Add"
                               Color="Color.Primary"
                               OnClick="@ShowAddAllocationDialog">
                    </MudIconButton>
                    <MudSpacer />
                    <MudTextField @bind-Value="_searchString"
                                  Placeholder="Search"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  IconSize="Size.Medium"
                                  Class="mt-0" />
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>
                        <MudTableSortLabel
                            SortBy="new Func<AllocationModel, object>(x => x.Id)">
                            @Localizer["Id"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel
                            SortBy="new Func<AllocationModel, object>(x => x.CostCenter.CostUnitName)">
                            @Localizer["CostCenter"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel
                            SortBy="new Func<AllocationModel, object>(x => x.Category.Name)">
                            @Localizer["Category"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel
                            SortBy="new Func<AllocationModel, object?>(x => x.ItemDetail?.CostDetails)">
                            @Localizer["ItemDetail"]
                        </MudTableSortLabel>
                    </MudTh>

                    <MudTh>@Localizer["Actions"]</MudTh>
                </HeaderContent>

                <RowTemplate>
                    <MudTd DataLabel="@Localizer["Id"]">
                        @context.Id
                    </MudTd>

                    <MudTd DataLabel="@Localizer["CostCenter"]">
                        @context.CostCenter.CostUnitName
                    </MudTd>
                    <MudTd DataLabel="@Localizer["Category"]">
                        @context.Category.Name
                    </MudTd>
                    <MudTd DataLabel="@Localizer["ItemDetail"]">
                        @context.ItemDetail?.CostDetails
                    </MudTd>
                    <MudTd DataLabel="@Localizer["Actions"]">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Info"
                                       aria-label="edit"
                                       OnClick="@(() => ShowEditAllocationDialog(context.Id))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       aria-label="delete"
                                       OnClick="@(() => ShowDeleteAllocationDialog(context))" />
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private IEnumerable<AllocationModel>? _allAllocations;
    private AllocationModel? _selectedAllocation;
    private string _searchString = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await UpdateAllocations();
    }

    private async Task UpdateAllocations()
    {
        _allAllocations = await AllocationService.GetAllAllocationsAsync();
        await InvokeAsync(StateHasChanged);
    }

    private bool FilterFunc(AllocationModel? allocation)
    {
        if (allocation == null)
            return false;

        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        var term = _searchString.Trim().ToLowerInvariant();

        var matchesCostCenter = allocation.CostCenter.CostUnitName.ToLowerInvariant().Contains(term);
        var matchesCategory = allocation.Category.Name.ToLowerInvariant().Contains(term);
        var matchesItemDetail = allocation.ItemDetail != null && allocation.ItemDetail.CostDetails.ToLowerInvariant().Contains(term);

        return matchesCostCenter || matchesCategory || matchesItemDetail;
    }

    private async Task ShowAddAllocationDialog()
    {
        var result = await DialogService.ShowDialogWithNotificationAsync<AllocationDialog>(
            NotificationService);
    
        if (result?.Status == OperationResultStatus.Success)
        {
            await UpdateAllocations();
        }
    }

    private async Task ShowEditAllocationDialog(int allocationId)
    {
        var parameters = new DialogParameters { ["AllocationId"] = allocationId };
    
        var result = await DialogService.ShowDialogWithNotificationAsync<AllocationDialog>(
            NotificationService,
            $"{Localizer["Edit"]} ",
            parameters);
    
        if (result?.Status == OperationResultStatus.Success)
        {
            await UpdateAllocations();
        }
    }

    private async Task ShowDeleteAllocationDialog(AllocationModel allocation)
    {
        await DialogService.ShowConfirmDeleteDialogAsync(
            NotificationService,
            entityName: Localizer["Allocation"].Value,
            itemName: $"{allocation.CostCenter.CostUnitName} - {allocation.Category.Name} - {allocation.ItemDetail?.CostDetails}",
            onConfirm: () => AllocationService.DeleteAllocationAsync(allocation.Id),
            onSuccess: UpdateAllocations,
            deleteTitle: Localizer["Delete"]);
    }
}
