@page "/allocationdialog"
@using Microsoft.Extensions.Localization
@using ClubTreasury.Data.Category
@using ClubTreasury.Data.CostCenter
@using ClubTreasury.Data.ItemDetail
@using ClubTreasury.Data.Notification
@using ClubTreasury.Data.OperationResult
@inject IAllocationService AllocationService
@inject ICostCenterService CostCenterService
@inject ICategoryService CategoryService
@inject IItemDetailService ItemDetailService
@inject IStringLocalizer<Translation> Localizer
@inject INotificationService NotificationService
@inject IResultFactory ResultFactory
@inject AllocationValidator AllocationValidator

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" Model="_allocationModel" Validation="AllocationValidator.ValidateValue" OnEnterPressed="@Save">
            <MudSelect T="int" Label="@Localizer["CostCenter"]" @bind-Value="_allocationModel.CostCenterId"
                       ToStringFunc="@CostCenterIdToString"
                       For="@(() => _allocationModel.CostCenterId)"
                       Immediate="true">
                @foreach (var cc in _costCenters)
                {
                    <MudSelectItem T="int" Value="@cc.Id">@cc.CostUnitName</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="int" Label="@Localizer["Category"]" @bind-Value="_allocationModel.CategoryId"
                       ToStringFunc="@CategoryIdToString"
                       For="@(() => _allocationModel.CategoryId)"
                       Immediate="true">
                @foreach (var cat in _categories)
                {
                    <MudSelectItem T="int" Value="@cat.Id">@cat.Name</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="int?" Label="@Localizer["ItemDetail"]" @bind-Value="_allocationModel.ItemDetailId"
                       ToStringFunc="@ItemDetailIdToString"
                       Clearable="true">
                @foreach (var item in _itemDetails)
                {
                    <MudSelectItem T="int?" Value="@item.Id">@item.CostDetails</MudSelectItem>
                }
            </MudSelect>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" OnClick="@(async () => await Save())">
            @(_isEditMode ? Localizer["Save"] : Localizer["AddEntry"])
        </MudButton>
        <MudButton Color="Color.Secondary" OnClick="@Cancel">@Localizer["Cancel"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int? AllocationId { get; set; }
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    private MudForm _form = new();
    private AllocationModel _allocationModel = new();
    private bool _isEditMode;

    private List<CostCenterModel> _costCenters = new();
    private List<CategoryModel> _categories = new();
    private List<ItemDetailModel> _itemDetails = new();

    protected override async Task OnInitializedAsync()
    {
        _isEditMode = AllocationId.HasValue;
        await MudDialog.SetTitleAsync(_isEditMode ? Localizer["Edit"] : Localizer["AddEntry"]);
        await LoadReferenceDataAsync();
        await LoadAllocationAsync();
    }

    private async Task LoadReferenceDataAsync()
    {
        _costCenters = (await CostCenterService.GetAllCostCentersAsync())
            .OrderBy(c => c.CostUnitName)
            .ToList();
        _categories = (await CategoryService.GetAllCategoriesAsync())
            .OrderBy(c => c.Name)
            .ToList();
        _itemDetails = (await ItemDetailService.GetAllItemDetailsAsync())
            .OrderBy(i => i.CostDetails)
            .ToList();
    }

    private async Task LoadAllocationAsync()
    {
        if (!_isEditMode)
        {
            _allocationModel = new AllocationModel();
            return;
        }

        _allocationModel = await AllocationService.GetAllocationsByIdAsync(AllocationId!.Value)
                           ?? new AllocationModel();
    }

    private async Task Save()
    {
        await _form.Validate();
        if (!_form.IsValid)
            return;

        var result = _isEditMode
            ? await AllocationService.UpdateAllocationAsync(_allocationModel)
            : await AllocationService.AddAllocationAsync(_allocationModel);

        if (result.IsSuccess)
            MudDialog.Close(DialogResult.Ok(result));
        else
            await NotificationService.ShowResultAsync(result);
    }

    private void Cancel() => MudDialog.Close(DialogResult.Ok(ResultFactory.Canceled()));

    private string CostCenterIdToString(int id)
        => _costCenters.FirstOrDefault(p => p.Id == id)?.CostUnitName ?? string.Empty;

    private string CategoryIdToString(int id)
        => _categories.FirstOrDefault(c => c.Id == id)?.Name ?? string.Empty;

    private string ItemDetailIdToString(int? id)
        => id is null ? string.Empty : _itemDetails.FirstOrDefault(i => i.Id == id.Value)?.CostDetails ?? string.Empty;
}
