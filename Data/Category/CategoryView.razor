@page "/categories"
@using Microsoft.Extensions.Localization
@using TTCCashRegister.Data.Category.Dialogs
@using TTCCashRegister.Data.Source
@inject ICategoryService CategoryService
@inject IDialogService DialogService
@inject INotificationService NotificationService
@inject IStringLocalizer<Translation> Localizer

<MudGrid Spacing="0">
    <MudItem xs="12">
        <MudText Typo="Typo.h6">
            @Localizer["CategoryPlural"]
        </MudText>
    </MudItem>
    <MudItem xs="12" md="10" lg="4">
        <MudPaper Elevation="0">
            <MudTable Items="@_allEntries"
                      Dense="@Dense"
                      Hover="@Hover"
                      Bordered="@Bordered"
                      Striped="@Striped"
                      FixedHeader="true"
                      @bind-SelectedItem="_selectedItem"
                      Filter="new Func<CategoryModel,bool>(FilterFunc)"
                      SortLabel="Sort By">
                <ToolBarContent>
                    <MudButton Variant="Variant.Filled"
                               StartIcon="@Icons.Material.Filled.Add"
                               Color="Color.Primary"
                               OnClick="@ShowAddCategoryDialog">
                        @Localizer["AddEntry"]
                    </MudButton>
                    <MudSpacer/>
                    <MudTextField @bind-Value="_searchString1"
                                  Placeholder="Search"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  IconSize="Size.Medium"
                                  Class="mt-0" />
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>
                        <MudTableSortLabel
                            SortBy="new Func<CategoryModel, object>(x => x.Id)">
                            @Localizer["Id"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel
                            SortBy="new Func<CategoryModel, object>(x => x.Name)">
                            @Localizer["Category"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>@Localizer["Actions"]</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="@Localizer["Id"]">
                        @context.Id
                    </MudTd>
                    <MudTd DataLabel="@Localizer["Category"]">
                        @context.Name
                    </MudTd>
                    <MudTd DataLabel="Actions">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Info"
                                       aria-label="edit"
                                       OnClick="@(() => ShowEditCategoryDialog(context.Id))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       aria-label="delete"
                                       OnClick="@(() => ShowDeleteCategoryDialog(context.Id))" />
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudPaper>
    </MudItem>
</MudGrid>
@code {
    private IEnumerable<CategoryModel>? _allEntries;
    private const bool Dense = true;
    private const bool Hover = true;
    private const bool Striped = true;
    private const bool Bordered = false;
    private string _searchString1 = string.Empty;
    private CategoryModel _selectedItem = new();

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        _allEntries = await CategoryService.GetAllCategoriesAsync();
    }

    private bool FilterFunc(CategoryModel? element) => FilterFunc1(element, _searchString1);

    private bool FilterFunc1(CategoryModel? element, string searchstring)
    {
        if (string.IsNullOrWhiteSpace(searchstring))
            return true;
        if (element == null) return false;

        searchstring = searchstring.ToLowerInvariant();

        // Suche über UnitDetails in Accounts
        return element.Allocations.Any(a =>
            a.ItemDetail != null &&
            a.ItemDetail.CostDetails.ToLower().Contains(searchstring)) || element.Name.ToLower().Contains(searchstring);
    }


    private async Task ShowAddCategoryDialog()
    {
        var dialog = await DialogService.ShowAsync<AddCategoryDialog>($"{Localizer["AddEntry"]}", new DialogParameters());
        await NotificationService.ShowDialogResultAsync(await dialog.Result);
        await UpdateView();
    }

    private async Task ShowEditCategoryDialog(int basicUnitId)
    {
        var dialog = await DialogService.ShowAsync<EditCategoryDialog>($"{Localizer["Edit"]}", 
            new DialogParameters { ["CategoryId"] = basicUnitId });
        await NotificationService.ShowDialogResultAsync(await dialog.Result);
        await UpdateView();
    }

    private async Task ShowDeleteCategoryDialog(int basicUnitId)
    {
        var dialog = await DialogService.ShowAsync<DeleteCategoryDialog>($"{Localizer["Delete"]}", 
            new DialogParameters { ["CategoryId"] = basicUnitId });
        await NotificationService.ShowDialogResultAsync(await dialog.Result);
        await UpdateView();
    }
    
    private async Task UpdateView() 
    {    
        _allEntries = await CategoryService.GetAllCategoriesAsync();
        await InvokeAsync(StateHasChanged);
    }
}
