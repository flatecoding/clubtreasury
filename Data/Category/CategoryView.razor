@page "/categories"
@using Microsoft.Extensions.Localization
@using ClubTreasury.Data.DialogService
@using ClubTreasury.Data.Notification
@using ClubTreasury.Data.OperationResult
@inject ICategoryService CategoryService
@inject IDialogService DialogService
@inject INotificationService NotificationService
@inject IStringLocalizer<Translation> Localizer

<MudGrid Spacing="0">
    <MudItem xs="12">
        <MudText Typo="Typo.h6">
            @Localizer["CategoryPlural"]
        </MudText>
    </MudItem>
    <MudItem xs="12" md="10" lg="4">
        <MudPaper Elevation="0">
            <MudTable Items="@_allEntries"
                      Dense="@Dense"
                      Hover="@Hover"
                      Bordered="@Bordered"
                      Striped="@Striped"
                      FixedHeader="true"
                      @bind-SelectedItem="_selectedItem"
                      Filter="new Func<CategoryModel,bool>(FilterFunc)"
                      SortLabel="Sort By">
                <ToolBarContent>
                    <MudIconButton Variant="Variant.Filled"
                               Icon="@Icons.Material.Filled.Add"
                               Color="Color.Primary"
                               OnClick="@ShowAddCategoryDialog">
                    </MudIconButton>
                    <MudSpacer/>
                    <MudTextField @bind-Value="_searchTerm"
                                  Placeholder="Search"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  IconSize="Size.Medium"
                                  Class="mt-0" />
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>
                        <MudTableSortLabel
                            SortBy="new Func<CategoryModel, object>(x => x.Id)">
                            @Localizer["Id"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel
                            SortBy="new Func<CategoryModel, object>(x => x.Name)">
                            @Localizer["Category"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>@Localizer["Actions"]</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="@Localizer["Id"]">
                        @context.Id
                    </MudTd>
                    <MudTd DataLabel="@Localizer["Category"]">
                        @context.Name
                    </MudTd>
                    <MudTd DataLabel="Actions">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Info"
                                       aria-label="edit"
                                       OnClick="@(() => ShowEditCategoryDialog(context.Id))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       aria-label="delete"
                                       OnClick="@(() => ShowDeleteCategoryDialog(context))" />
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudPaper>
    </MudItem>
</MudGrid>
@code {
    private IEnumerable<CategoryModel>? _allEntries;
    private const bool Dense = true;
    private const bool Hover = true;
    private const bool Striped = true;
    private const bool Bordered = false;
    private string _searchTerm = string.Empty;
    private CategoryModel _selectedItem = new();

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        _allEntries = await CategoryService.GetAllCategoriesAsync();
    }

    private bool FilterFunc(CategoryModel? element) => MatchesFilter(element, _searchTerm);

    private static bool MatchesFilter(CategoryModel? element, string searchTerm)
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
            return true;
        if (element == null) return false;

        searchTerm = searchTerm.ToLowerInvariant();
        
        return element.Allocations.Any(a =>
            a.ItemDetail != null &&
            a.ItemDetail.CostDetails.ToLower().Contains(searchTerm)) || element.Name.ToLower().Contains(searchTerm);
    }


    private async Task ShowAddCategoryDialog()
    {
        var result = await DialogService.ShowDialogWithNotificationAsync<CategoryDialog>(NotificationService);
        if (result?.Status is OperationResultStatus.Success)
        {
            await UpdateView();
        }
    }

    private async Task ShowEditCategoryDialog(int categoryId)
    {
        var result = await DialogService.ShowDialogWithNotificationAsync<CategoryDialog>(NotificationService,
            $"{Localizer["Edit"]}",
            new DialogParameters(){["CategoryId"] = categoryId});

        if (result?.Status is OperationResultStatus.Success)
        {
            await UpdateView();
        }
    }

    private async Task ShowDeleteCategoryDialog(CategoryModel category)
    {
        await DialogService.ShowConfirmDeleteDialogAsync(
            NotificationService,
            entityName: Localizer["Category"].Value,
            itemName: $"{category.Name}",
            onConfirm: () => CategoryService.DeleteCategoryAsync(category.Id),
            onSuccess: UpdateView,
            deleteTitle: Localizer["Delete"]);
    }
    
    private async Task UpdateView() 
    {    
        _allEntries = await CategoryService.GetAllCategoriesAsync();
        await InvokeAsync(StateHasChanged);
    }
}
