@page "/editcategory"
@inject CategoryService CategoryService

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" Model="_editCategoryModel" Validation="_categoryValidator.ValidateValue" ValidationDelay="0">
            <MudTextField @bind-Value="_editCategoryModel.Name" Label="Name"
                          For="@(() => _editCategoryModel.Name)" Immediate="true"/>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(async () => await SaveCategory())">Save</MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="@(() => Cancel())">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int CategoryId { get; set; }
    private MudForm _form = new();
    private CategoryModel _editCategoryModel = new();
    private readonly CategoryValidator _categoryValidator = new();

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        _editCategoryModel = await CategoryService.GetCategoryByIdAsync(CategoryId) ?? new CategoryModel();
    }

    private async Task SaveCategory()
    {
        await _form.Validate();
        if (_form.IsValid)
        {
            await CategoryService.UpdateCategoryAsync(_editCategoryModel);
            MudDialog.Close(DialogResult.Ok(true));
        }
    }

    private void Cancel()
    {
        MudDialog.Close(DialogResult.Cancel());
    }
}
