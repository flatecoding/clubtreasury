@using Microsoft.Extensions.Localization
@inject ICategoryService CategoryService
@inject IStringLocalizer<Translation> Localizer

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" Model="_newCategoryModel" Validation="_categoryValidator.ValidateValue" ValidationDelay="0">
            <MudTextField @bind-Value="_newCategoryModel.Name" Label="@Localizer["CostCenter"]"
                          For="@(() => _newCategoryModel.Name)" Immediate="true"/>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" 
                   OnClick="@(async () => await AddCategory())">@Localizer["AddEntry"]</MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Default" 
                   OnClick="@(() => Cancel())">@Localizer["Cancel"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    private MudForm _form = new();
    private readonly CategoryModel _newCategoryModel = new();
    private readonly CategoryValidator _categoryValidator= new ();

    private async Task AddCategory()
    {
        await _form.Validate();
        if (_form.IsValid)
        {
            await CategoryService.AddCategoryAsync(_newCategoryModel);
            MudDialog.Close(DialogResult.Ok(true));
        }
    }

    private void Cancel()
    {
        MudDialog.Close(DialogResult.Cancel());
    }
}
