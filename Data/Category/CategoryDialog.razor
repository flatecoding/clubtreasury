@using Microsoft.Extensions.Localization
@using TTCCashRegister.Data.Notification
@using TTCCashRegister.Data.OperationResult

@inject ICategoryService CategoryService
@inject IStringLocalizer<Translation> Localizer
@inject INotificationService NotificationService
@inject IOperationResultFactory OperationResultFactory
@inject CategoryValidator CategoryValidator

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form"
                 Model="_categoryModel"
                 Validation="CategoryValidator.ValidateValue"
                 ValidationDelay="0">

            <MudTextField @bind-Value="_categoryModel.Name"
                          Label="@Localizer["Category"]"
                          For="@(() => _categoryModel.Name)"
                          Immediate="true" />
        </MudForm>
    </DialogContent>

    <DialogActions>
        <MudButton Color="Color.Primary"
                   OnClick="@(async () => await Save())">
            @(_isEditMode ? Localizer["Save"] : Localizer["AddEntry"])
        </MudButton>

        <MudButton Color="Color.Secondary"
                   OnClick="@Cancel">
            @Localizer["Cancel"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int? CategoryId { get; set; }

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    private MudForm _form = new();
    private CategoryModel _categoryModel = new();
    private bool _isEditMode;

    protected override async Task OnInitializedAsync()
    {
        _isEditMode = CategoryId.HasValue;
        await MudDialog.SetTitleAsync(_isEditMode ? Localizer["Edit"] : Localizer["AddEntry"]);
        await LoadCategoryAsync();
    }

    private async Task LoadCategoryAsync()
    {
        if (!_isEditMode)
        {
            _categoryModel = new CategoryModel();
            return;
        }

        _categoryModel = await CategoryService.GetCategoryByIdAsync(CategoryId!.Value)
                         ?? new CategoryModel();
    }

    private async Task Save()
    {
        await _form.Validate();
        if (!_form.IsValid)
            return;

        var result = _isEditMode
            ? await CategoryService.UpdateCategoryAsync(_categoryModel)
            : await CategoryService.AddCategoryAsync(_categoryModel);

        if (result.Status is OperationResultStatus.Success)
            MudDialog.Close(DialogResult.Ok(result));
        else
            await NotificationService.ShowOperationResultAsync(result);
    }

    private void Cancel() => MudDialog.Close(DialogResult.Ok(OperationResultFactory.Canceled()));
}
