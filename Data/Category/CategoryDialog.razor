@using ClubTreasury.Components.Dialog
@using ClubTreasury.Data.OperationResult

@inherits SimpleEntityDialogBase<CategoryModel>

@inject ICategoryService CategoryService
@inject CategoryValidator CategoryValidator

<MudDialog>
    <DialogContent>
        <MudForm @ref="Form"
                 Model="Model"
                 Validation="ValidateValue"
                 ValidationDelay="0"
                 OnEnterPressed="@Save">

            <MudTextField @bind-Value="Model.Name"
                          Label="@Localizer["Category"]"
                          For="@(() => Model.Name)"
                          Immediate="true" />
        </MudForm>
    </DialogContent>

    <DialogActions>
        <MudButton Color="Color.Primary"
                   OnClick="@(async () => await Save())">
            @(IsEditMode ? Localizer["Save"] : Localizer["AddEntry"])
        </MudButton>

        <MudButton Color="Color.Secondary"
                   OnClick="@Cancel">
            @Localizer["Cancel"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int? CategoryId { get; set; }

    protected override int? EntityId => CategoryId;
    protected override Func<object, string, Task<IEnumerable<string>>> ValidateValue => CategoryValidator.ValidateValue;
    protected override Task<CategoryModel?> LoadEntityAsync(int id) => CategoryService.GetCategoryByIdAsync(id);
    protected override Task<Result> AddEntityAsync(CategoryModel model) => CategoryService.AddCategoryAsync(model);
    protected override Task<Result> UpdateEntityAsync(CategoryModel model) => CategoryService.UpdateCategoryAsync(model);
}
