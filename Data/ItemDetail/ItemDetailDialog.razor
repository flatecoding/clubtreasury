@using Microsoft.Extensions.Localization
@using ClubTreasury.Data.Notification
@using ClubTreasury.Data.OperationResult

@inject IItemDetailService ItemDetailService
@inject IStringLocalizer<Translation> Localizer
@inject INotificationService NotificationService
@inject IOperationResultFactory OperationResultFactory
@inject ItemDetailValidator ItemDetailValidator

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form"
                 Model="_itemDetailModel"
                 Validation="ItemDetailValidator.ValidateValue"
                 ValidationDelay="0"
                 OnEnterPressed="@Save">

            <MudTextField @bind-Value="_itemDetailModel.CostDetails"
                          Label="@Localizer["Name"]"
                          For="@(() => _itemDetailModel.CostDetails)"
                          Immediate="true" />
        </MudForm>
    </DialogContent>

    <DialogActions>
        <MudButton Color="Color.Primary"
                   OnClick="@(async () => await Save())">
            @(_isEditMode ? Localizer["Save"] : Localizer["AddEntry"])
        </MudButton>

        <MudButton Color="Color.Secondary"
                   OnClick="@Cancel">
            @Localizer["Cancel"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int? ItemDetailId { get; set; }

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    private MudForm _form = new();
    private ItemDetailModel _itemDetailModel = new();
    private bool _isEditMode;

    protected override async Task OnInitializedAsync()
    {
        _isEditMode = ItemDetailId.HasValue;
        await MudDialog.SetTitleAsync(_isEditMode ? Localizer["Edit"] : Localizer["AddEntry"]);
        await LoadItemDetailAsync();
    }

    private async Task LoadItemDetailAsync()
    {
        if (!_isEditMode)
        {
            _itemDetailModel = new ItemDetailModel();
            return;
        }

        _itemDetailModel = await ItemDetailService.GetItemDetailByIdAsync(ItemDetailId!.Value)
                           ?? new ItemDetailModel();
    }

    private async Task Save()
    {
        await _form.Validate();
        if (!_form.IsValid)
            return;

        var result = _isEditMode
            ? await ItemDetailService.UpdateItemDetailAsync(_itemDetailModel)
            : await ItemDetailService.AddItemDetailAsync(_itemDetailModel);

        if (result.Status is OperationResultStatus.Success)
            MudDialog.Close(DialogResult.Ok(result));
        else
            await NotificationService.ShowOperationResultAsync(result);
    }

    private void Cancel() => MudDialog.Close(DialogResult.Ok(OperationResultFactory.Canceled()));
}
