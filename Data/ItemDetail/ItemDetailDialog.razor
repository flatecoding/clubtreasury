@using ClubTreasury.Components.Dialog
@using ClubTreasury.Data.OperationResult

@inherits SimpleEntityDialogBase<ItemDetailModel>

@inject IItemDetailService ItemDetailService
@inject ItemDetailValidator ItemDetailValidator

<MudDialog>
    <DialogContent>
        <MudForm @ref="Form"
                 Model="Model"
                 Validation="ValidateValue"
                 ValidationDelay="0"
                 OnEnterPressed="@Save">

            <MudTextField @bind-Value="Model.CostDetails"
                          Label="@Localizer["Name"]"
                          For="@(() => Model.CostDetails)"
                          Immediate="true" />
        </MudForm>
    </DialogContent>

    <DialogActions>
        <MudButton Color="Color.Primary"
                   OnClick="@(async () => await Save())">
            @(IsEditMode ? Localizer["Save"] : Localizer["AddEntry"])
        </MudButton>

        <MudButton Color="Color.Secondary"
                   OnClick="@Cancel">
            @Localizer["Cancel"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int? ItemDetailId { get; set; }

    protected override int? EntityId => ItemDetailId;
    protected override Func<object, string, Task<IEnumerable<string>>> ValidateValue => ItemDetailValidator.ValidateValue;
    protected override Task<ItemDetailModel?> LoadEntityAsync(int id) => ItemDetailService.GetItemDetailByIdAsync(id);
    protected override Task<Result> AddEntityAsync(ItemDetailModel model) => ItemDetailService.AddItemDetailAsync(model);
    protected override Task<Result> UpdateEntityAsync(ItemDetailModel model) => ItemDetailService.UpdateItemDetailAsync(model);
}
