@page "/deleteitemdetail"
@using Microsoft.Extensions.Localization
@inject IItemDetailService ItemDetailService
@inject IStringLocalizer<Translation> Localizer

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h6">@Localizer["DeleteQuestion"]</MudText>
        <MudText Typo="Typo.subtitle1">@_itemDetailName</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="@(() => DeleteItemDetail())">@Localizer["Delete"]</MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="@(() => Cancel())">@Localizer["Cancel"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int ItemDetailId { get; set; }
    private string _itemDetailName = string.Empty;

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        var itemDetail = await ItemDetailService.GetItemDetailByIdAsync(ItemDetailId);
        if (itemDetail != null)
        {
            _itemDetailName = itemDetail.CostDetails;
        }
    }

    private async Task DeleteItemDetail()
    {
        var success = await ItemDetailService.DeleteItemDetailAsync(ItemDetailId);
        MudDialog.Close(success ? DialogResult.Ok(true) : DialogResult.Ok(false));
    }

    private void Cancel()
    {
        MudDialog.Close(DialogResult.Cancel());
    }
}
