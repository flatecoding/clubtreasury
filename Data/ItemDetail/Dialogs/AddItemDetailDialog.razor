@page "/additemdetail"
@using TTCCashRegister.Data.Accounts
@using TTCCashRegister.Data.Category
@inject ItemDetailService ItemDetailService
@inject CategoryService CategoryService
@inject AccountsService AccountsService

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" Model="_newItemDetailModel" Validation="_itemDetailValidator.ValidateValue" ValidationDelay="0">
            
            <MudTextField @bind-Value="_newItemDetailModel.CostDetails" 
                          Label="Detailed position"
                          For="@(() => _newItemDetailModel.CostDetails)"
                          Required="true" 
                          Immediate="true" />

            <MudSelect T="CategoryModel" 
                       Label="Category" 
                       @bind-SelectedValues="_selectedCategories"
                       MultiSelection="true"
                       Required="true">
                @foreach (var category in _allCategories)
                {
                    <MudSelectItem T="CategoryModel" Value="@category">@category.Name</MudSelectItem>
                }
            </MudSelect>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(async () => await AddItemDetailAsync())">
            Add
        </MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel">
            Cancel
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    private MudForm _form = new();
    private readonly ItemDetailModel _newItemDetailModel = new();
    private readonly ItemDetailValidator _itemDetailValidator = new();
    private IEnumerable<CategoryModel> _allCategories = new List<CategoryModel>();
    private IEnumerable<CategoryModel> _selectedCategories = new List<CategoryModel>();

    protected override async Task OnInitializedAsync()
    {
        // Alle BasicUnits laden
        _allCategories = await CategoryService.GetAllCategoriesAsync();
    }

    private async Task AddItemDetailAsync()
    {
        await _form.Validate();
        if (!_form.IsValid || !_selectedCategories.Any())
            return;

        // 1. UnitDetail speichern
        var createdDetail = await ItemDetailService.AddItemDetailAsync(_newItemDetailModel);

        // 2. N:M-Beziehung über Accounts erstellen
        foreach (var account in _selectedCategories.Select(category => new AccountsModel
                 {
                     CategoryId = category.Id,
                     CostCenterId = category.CostCenterId,
                     ItemDetailId = createdDetail?.Id
                 }))
        {
            await AccountsService.EnsureAccountExistsAsync(account);
        }

        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel()
    {
        MudDialog.Close(DialogResult.Cancel());
    }
}
