@page "/itemdetails"
@using Microsoft.Extensions.Localization
@using NuGet.Frameworks
@using TTCCashRegister.Data.DialogService
@using TTCCashRegister.Data.Notification
@using TTCCashRegister.Data.OperationResult
@inject IItemDetailService ItemDetailService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IStringLocalizer<Translation> Localizer
@inject INotificationService NotificationService

<MudGrid Spacing="0">
    <MudItem xs="12">
        <MudText Typo="Typo.h6">
            @Localizer["ItemDetail"]
        </MudText>
    </MudItem>

    <MudItem xs="12" md="10" lg="4">
        <MudPaper Elevation="0">
            <MudTable Items="@_allEntries"
                      Dense="@Dense"
                      Hover="@Hover"
                      Bordered="@Bordered"
                      Striped="@Striped"
                      FixedHeader="true"
                      @bind-SelectedItem="_selectedItem"
                      Filter="new Func<ItemDetailModel,bool>(FilterFunc)"
                      SortLabel="Sort By">
                <ToolBarContent>
                    <MudIconButton Variant="Variant.Filled"
                               Icon="@Icons.Material.Filled.Add"
                               Color="Color.Primary"
                               OnClick="@ShowAddUnitDetailsDialog">
                    </MudIconButton>
                    <MudSpacer />
                    <MudTextField @bind-Value="_searchString1"
                                  Placeholder="Search"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  IconSize="Size.Medium"
                                  Class="mt-0" />
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>
                        <MudTableSortLabel
                            SortBy="new Func<ItemDetailModel, object>(x => x.Id)">
                            @Localizer["Id"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel
                            SortBy="new Func<ItemDetailModel, object>(x => x.CostDetails)">
                            @Localizer["ItemDetail"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>@Localizer["Actions"]</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="@Localizer["Id"].Value">
                        @context.Id
                    </MudTd>
                    <MudTd DataLabel="@Localizer["ItemDetail"].Value">
                        @context.CostDetails
                    </MudTd>
                    <MudTd DataLabel="Actions">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Info"
                                       aria-label="edit"
                                       OnClick="@(() => ShowEditUnitDetailsDialog(context.Id))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       aria-label="delete"
                                       OnClick="@(() => ShowDeleteUnitDetailsDialog(context))" />
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudPaper>
    </MudItem>
</MudGrid>


@code {
    private IEnumerable<ItemDetailModel>? _allEntries;
    private const bool Dense = true;
    private const bool Hover = true;
    private const bool Striped = true;
    private const bool Bordered = false;
    private string _searchString1 = string.Empty;
    private ItemDetailModel _selectedItem = new();

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        _allEntries = await ItemDetailService.GetAllItemDetailsAsync();
    }

    private bool FilterFunc(ItemDetailModel? element) => FilterFunc1(element, _searchString1);

    private bool FilterFunc1(ItemDetailModel? element, string searchstring)
    {
        if (string.IsNullOrWhiteSpace(searchstring))
            return true;
        if (element is not null && !string.IsNullOrWhiteSpace(searchstring))
        {
            if (element.CostDetails.ToLower().Contains(searchstring.ToLowerInvariant()))
                return true;
          //  if (element.BasicUnits is not null && element.BasicUnit.Name.ToLower().Contains(searchstring.ToLowerInvariant()))
          //  return true;
        }
        return false;
    }

    private async Task ShowAddUnitDetailsDialog()
    {
        var result = await DialogService.ShowDialogWithNotificationAsync<ItemDetailDialog>(NotificationService);

        if (result?.Status is OperationResultStatus.Success)
        {
            await UpdateView();
        }
    }

    private async Task UpdateView()
    {
        _allEntries = await ItemDetailService.GetAllItemDetailsAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task ShowEditUnitDetailsDialog(int itemDetailId)
    {
        var result = await DialogService.ShowDialogWithNotificationAsync<ItemDetailDialog>(NotificationService, 
            $"{Localizer["Edit"]}",
            new DialogParameters { ["ItemDetailId"] = itemDetailId }
            );
        
        if (result?.Status is OperationResultStatus.Success)
        {
            await UpdateView();
        }
    }

    private async Task ShowDeleteUnitDetailsDialog(ItemDetailModel itemDetail)
    {
        await DialogService.ShowConfirmDeleteDialogAsync(
            NotificationService,
            entityName: Localizer["ItemDetail"].Value,
            itemName: $"{itemDetail.CostDetails}",
            onConfirm: () => ItemDetailService.DeleteItemDetailAsync(itemDetail.Id),
            onSuccess: UpdateView,
            deleteTitle: Localizer["Delete"]);
    }
}
