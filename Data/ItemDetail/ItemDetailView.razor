@page "/itemdetails"
@using ClubTreasury.Components.View
@using ClubTreasury.Data.OperationResult

@inherits CrudViewBase<ItemDetailModel, ItemDetailDialog>

@inject IItemDetailService ItemDetailService

<MudGrid Spacing="0">
    <MudItem xs="12">
        <MudText Typo="Typo.h6">
            @Localizer["ItemDetail"]
        </MudText>
    </MudItem>
    <MudItem xs="12" md="10" lg="4">
        <MudPaper Elevation="0">
            <MudTable Items="@AllEntries"
                      Dense="true"
                      Hover="true"
                      Bordered="false"
                      Striped="true"
                      FixedHeader="true"
                      @bind-SelectedItem="SelectedItem"
                      Filter="new Func<ItemDetailModel,bool>(FilterFunc)"
                      SortLabel="Sort By">
                <ToolBarContent>
                    <MudIconButton Variant="Variant.Filled"
                               Icon="@Icons.Material.Filled.Add"
                               Color="Color.Primary"
                               OnClick="@ShowAddDialog">
                    </MudIconButton>
                    <MudSpacer />
                    <MudTextField @bind-Value="SearchTerm"
                                  Placeholder="Search"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  IconSize="Size.Medium"
                                  Class="mt-0" />
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>
                        <MudTableSortLabel
                            SortBy="new Func<ItemDetailModel, object>(x => x.Id)">
                            @Localizer["Id"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel
                            SortBy="new Func<ItemDetailModel, object>(x => x.CostDetails)">
                            @Localizer["ItemDetail"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>@Localizer["Actions"]</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="@Localizer["Id"].Value">
                        @context.Id
                    </MudTd>
                    <MudTd DataLabel="@Localizer["ItemDetail"].Value">
                        @context.CostDetails
                    </MudTd>
                    <MudTd DataLabel="Actions">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Info"
                                       aria-label="edit"
                                       OnClick="@(() => ShowEditDialog(context.Id))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       aria-label="delete"
                                       OnClick="@(() => ShowDeleteDialog(context))" />
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    protected override string EntityIdParameterName => "ItemDetailId";
    protected override string EntityLocalizedName => Localizer["ItemDetail"];
    protected override int GetEntityId(ItemDetailModel entity) => entity.Id;
    protected override string GetEntityDisplayName(ItemDetailModel entity) => entity.CostDetails;
    protected override Task<List<ItemDetailModel>> LoadAllAsync() => ItemDetailService.GetAllItemDetailsAsync();
    protected override Task<Result> DeleteEntityAsync(int id) => ItemDetailService.DeleteItemDetailAsync(id);

    protected override bool MatchesFilter(ItemDetailModel? element, string searchTerm)
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
            return true;
        if (element is null)
            return false;
        return element.CostDetails.ToLower().Contains(searchTerm.ToLowerInvariant());
    }
}
