@page "/itemdetails"
@using TTCCashRegister.Data.ItemDetail.Dialogs
@inject IItemDetailService ItemDetailService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<h2>Item details</h2>
<MudPaper Class="mt-4" Style="width:55%;">
    <MudTable Class="mt-2" Items="@_allEntries" Dense="@Dense" Hover="@Hover" Bordered="@Bordered" Striped="@Striped" FixedHeader="true"
              @bind-SelectedItem="_selectedItem"
              Filter="new Func<ItemDetailModel,bool>(FilterFunc)"
              SortLabel="Sort By">
        <ToolBarContent>
            <MudButton Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.Add"
                       Color="Color.Primary"
                       @onclick="ShowAddUnitDetailsDialog">
                Add item detail
            </MudButton>
            <MudSpacer />
            <MudTextField @bind-Value="_searchString1"
                          Placeholder="Search"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium"
                          Class="mt-0">
            </MudTextField>
        </ToolBarContent>
        <ColGroup>
            <col style="width: 20px;" />
            <col style="width: 110px;" />
            <col style="width: 110px;" />
            <col style="width: 110px;" />
        </ColGroup>
        <HeaderContent>
            <MudTh>Id<MudTableSortLabel SortBy="new Func<ItemDetailModel, object>(x => x.Id)"></MudTableSortLabel></MudTh>
            <MudTh>Details<MudTableSortLabel SortBy="new Func<ItemDetailModel, object>(x => x.CostDetails)"></MudTableSortLabel></MudTh>
            <MudTh>Category</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="ID">@context.Id</MudTd>
            <MudTd DataLabel="Details">@context.CostDetails</MudTd>
            <MudTd DataLabel="Category">
                @if (context.Allocations.Any())
                {
                    @foreach (var account in context.Allocations)
                    {
                        <li> @account.Category.Name</li>
                    }
                }
                else
                {
                    <em>No details assigned</em>
                }
                </MudTd>
            <MudTd DataLabel="Actions">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Info" aria-label="edit" @onclick="() => ShowEditUnitDetailsDialog(context.Id)"></MudIconButton>
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" aria-label="delete" @onclick="() => ShowDeleteUnitDetailsDialog(context.Id)">Delete</MudIconButton>
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
</MudPaper>

@code {
    private IEnumerable<ItemDetailModel>? _allEntries;
    private const bool Dense = true;
    private const bool Hover = true;
    private const bool Striped = true;
    private const bool Bordered = false;
    private string _searchString1 = string.Empty;
    private ItemDetailModel _selectedItem = new();
    private readonly DialogOptions _dialogOptions = new()
    {
        MaxWidth = MaxWidth.Medium,
        FullWidth = true,
        BackdropClick = false,
        BackgroundClass= "custom-dialog-background"
    };

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        _allEntries = await ItemDetailService.GetAllItemDetailsAsync();
    }

    private bool FilterFunc(ItemDetailModel? element) => FilterFunc1(element, _searchString1);

    private bool FilterFunc1(ItemDetailModel? element, string searchstring)
    {
        if (string.IsNullOrWhiteSpace(searchstring))
            return true;
        if (element is not null && !string.IsNullOrWhiteSpace(searchstring))
        {
            if (element.CostDetails.ToLower().Contains(searchstring.ToLowerInvariant()))
                return true;
          //  if (element.BasicUnits is not null && element.BasicUnit.Name.ToLower().Contains(searchstring.ToLowerInvariant()))
          //  return true;
        }
        return false;
    }

    private async Task ShowAddUnitDetailsDialog()
    {
        var parameters = new DialogParameters();
        
        var dialog = await DialogService.ShowAsync<AddItemDetailDialog>("Add item detail", 
            parameters, _dialogOptions);
        if ((await dialog.Result)?.Canceled == false)
        {
            _allEntries = await ItemDetailService.GetAllItemDetailsAsync();
            Snackbar.Add("New item detail were added successfully", Severity.Success);
        }
    }

    private async Task ShowEditUnitDetailsDialog(int itemDetailId)
    {
        var parameters = new DialogParameters { ["ItemDetailId"] = itemDetailId };
        var dialog = await DialogService.ShowAsync<EditItemDetailDialog>("Edit item detail", 
            parameters, _dialogOptions);
        if ((await dialog.Result)?.Canceled == false)
        {
            _allEntries = await ItemDetailService.GetAllItemDetailsAsync();
            Snackbar.Add("Item detail were updated successfully", Severity.Success);
        }
    }

    private async Task ShowDeleteUnitDetailsDialog(int itemDetailId)
    {
        var parameters = new DialogParameters { ["ItemDetailId"] = itemDetailId };
        var dialog = await DialogService.ShowAsync<DeleteItemDetailDialog>("Delete item detail", 
            parameters, _dialogOptions);
        if ((await dialog.Result)?.Canceled == false)
        {
            _allEntries = await ItemDetailService.GetAllItemDetailsAsync();
            Snackbar.Add("Item detail were deleted successfully", Severity.Success);
        }
    }
}
