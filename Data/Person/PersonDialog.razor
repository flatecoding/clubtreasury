@using ClubTreasury.Components.Dialog
@using ClubTreasury.Data.OperationResult

@inherits SimpleEntityDialogBase<PersonModel>

@inject IPersonService PersonService
@inject PersonValidator PersonValidator

<MudDialog>
    <DialogContent>
        <MudForm @ref="Form"
                 Model="Model"
                 Validation="ValidateValue"
                 ValidationDelay="0"
                 OnEnterPressed="@Save">

            <MudTextField @bind-Value="Model.Name"
                          Label="@Localizer["Name"]"
                          For="@(() => Model.Name)"
                          Immediate="true" />
        </MudForm>
    </DialogContent>

    <DialogActions>
        <MudButton Color="Color.Primary"
                   OnClick="@(async () => await Save())">
            @(IsEditMode ? Localizer["Save"] : Localizer["AddEntry"])
        </MudButton>

        <MudButton Color="Color.Secondary"
                   OnClick="@Cancel">
            @Localizer["Cancel"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int? PersonId { get; set; }

    protected override int? EntityId => PersonId;
    protected override Func<object, string, Task<IEnumerable<string>>> ValidateValue => PersonValidator.ValidateValue;
    protected override Task<PersonModel?> LoadEntityAsync(int id) => PersonService.GetPersonByIdAsync(id);
    protected override Task<Result> AddEntityAsync(PersonModel model) => PersonService.AddPersonAsync(model);
    protected override Task<Result> UpdateEntityAsync(PersonModel model) => PersonService.UpdatePersonAsync(model);
}
