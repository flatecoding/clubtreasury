@page "/persons"
@using ClubTreasury.Components.View
@using ClubTreasury.Data.OperationResult

@inherits CrudViewBase<PersonModel, PersonDialog>

@inject IPersonService PersonService

<MudGrid Spacing="0">
    <MudItem xs="12">
        <MudText Typo="Typo.h6">
            @Localizer["PersonPlural"]
        </MudText>
    </MudItem>
    <MudItem xs="12" md="10" lg="4">
        <MudPaper Elevation="0">
            <MudTable Items="@AllEntries"
                      Dense="true"
                      Hover="true"
                      Bordered="false"
                      Striped="true"
                      FixedHeader="true"
                      @bind-SelectedItem="SelectedItem"
                      Filter="new Func<PersonModel,bool>(FilterFunc)"
                      SortLabel="Sort By">
                <ToolBarContent>
                    <MudIconButton Variant="Variant.Filled"
                               Icon="@Icons.Material.Filled.Add"
                               Color="Color.Primary"
                               OnClick="@ShowAddDialog">
                    </MudIconButton>
                    <MudSpacer />
                    <MudTextField @bind-Value="SearchTerm"
                                  Placeholder="Search"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  IconSize="Size.Medium"
                                  Class="mt-0" />
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>
                        <MudTableSortLabel
                            SortBy="new Func<PersonModel, object>(x => x.Id)">
                            @Localizer["Id"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel
                            SortBy="new Func<PersonModel, object>(x => x.Name)">
                            @Localizer["Name"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>@Localizer["Actions"]</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="@Localizer["Id"].Value">
                        @context.Id
                    </MudTd>
                    <MudTd DataLabel="@Localizer["Name"].Value">
                        @context.Name
                    </MudTd>
                    <MudTd DataLabel="@Localizer["Actions"].Value">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Info"
                                       aria-label="edit"
                                       OnClick="@(() => ShowEditDialog(context.Id))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       aria-label="delete"
                                       OnClick="@(() => ShowDeleteDialog(context))" />
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    protected override string EntityIdParameterName => "PersonId";
    protected override string EntityLocalizedName => Localizer["Person"];
    protected override int GetEntityId(PersonModel entity) => entity.Id;
    protected override string GetEntityDisplayName(PersonModel entity) => entity.Name;
    protected override Task<List<PersonModel>> LoadAllAsync() => PersonService.GetAllPersonsAsync();
    protected override Task<Result> DeleteEntityAsync(int id) => PersonService.DeletePersonAsync(id);

    protected override bool MatchesFilter(PersonModel? element, string searchTerm)
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
            return true;
        return element is not null && element.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase);
    }
}
