@page "/persons"
@using Microsoft.Extensions.Localization
@using TTCCashRegister.Data.DialogService
@using TTCCashRegister.Data.Notification
@using TTCCashRegister.Data.OperationResult
@inject IPersonService PersonService
@inject IDialogService DialogService
@inject INotificationService NotificationService
@inject IStringLocalizer<Translation> Localizer

<MudGrid Spacing="0">
    <MudItem xs="12">
        <MudText Typo="Typo.h6">
            @Localizer["PersonPlural"]
        </MudText>
    </MudItem>
    <MudItem xs="12" md="10" lg="4">
        <MudPaper Elevation="0">
            <MudTable Items="@_allEntries"
                      Dense="@Dense"
                      Hover="@Hover"
                      Bordered="@Bordered"
                      Striped="@Striped"
                      FixedHeader="true"
                      @bind-SelectedItem="_selectedItem"
                      Filter="new Func<PersonModel,bool>(FilterFunc)"
                      SortLabel="Sort By">
                <ToolBarContent>
                    <MudIconButton Variant="Variant.Filled"
                               Icon="@Icons.Material.Filled.Add"
                               Color="Color.Primary"
                               OnClick="@ShowAddPersonDialog">
                    </MudIconButton>
                    <MudSpacer />
                    <MudTextField @bind-Value="_searchString1"
                                  Placeholder="Search"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  IconSize="Size.Medium"
                                  Class="mt-0" />
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>
                        <MudTableSortLabel
                            SortBy="new Func<PersonModel, object>(x => x.Id)">
                            @Localizer["Id"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel
                            SortBy="new Func<PersonModel, object>(x => x.Name)">
                            @Localizer["Name"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>@Localizer["Actions"]</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="@Localizer["Id"].Value">
                        @context.Id
                    </MudTd>
                    <MudTd DataLabel="@Localizer["Name"].Value">
                        @context.Name
                    </MudTd>
                    <MudTd DataLabel="@Localizer["Actions"].Value">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Info"
                                       aria-label="edit"
                                       OnClick="@(() => ShowEditPersonDialog(context.Id))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       aria-label="delete"
                                       OnClick="@(() => ShowDeletePersonDialog(context))" />
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private IEnumerable<PersonModel>? _allEntries;
    private const bool Dense = true;
    private const bool Hover = true;
    private const bool Striped = true;
    private const bool Bordered = false;
    private string _searchString1 = string.Empty;
    private PersonModel _selectedItem = new();

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        _allEntries = await PersonService.GetAllPersonsAsync();
    }

    private bool FilterFunc(PersonModel? element) => FilterFunc1(element, _searchString1);

    private static bool FilterFunc1(PersonModel? element, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        return element is not null && element.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase);
    }

    private async Task ShowAddPersonDialog()
    {
        var result = await DialogService.ShowDialogWithNotificationAsync<PersonDialog>(NotificationService);
        
        if(result?.Status is OperationResultStatus.Success)
            await UpdateView();
    }

    private async Task ShowEditPersonDialog(int personId)
    {
        var result = await DialogService.ShowDialogWithNotificationAsync<PersonDialog>(NotificationService,
            $"{Localizer["Edit"]}",
            new DialogParameters() { ["PersonId"] = personId });
        if(result?.Status is OperationResultStatus.Success)
            await UpdateView();
    }

    private async Task ShowDeletePersonDialog(PersonModel person)
    {
        await DialogService.ShowConfirmDeleteDialogAsync(
            NotificationService,
            entityName: Localizer["Person"].Value,
            itemName: $"{person.Name}",
            onConfirm: () => PersonService.DeletePersonAsync(person.Id),
            onSuccess: UpdateView,
            deleteTitle: Localizer["Delete"]);
    }

    
    private async Task UpdateView()
    {
        _allEntries = await PersonService.GetAllPersonsAsync();
        await InvokeAsync(StateHasChanged);
    }
}
