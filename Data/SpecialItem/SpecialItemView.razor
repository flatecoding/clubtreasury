@page "/specialitems"
@using System.Globalization
@using Microsoft.Extensions.Localization
@using ClubTreasury.Data.DialogService
@using ClubTreasury.Data.Notification
@inject ISpecialItemService SpecialItemService
@inject IDialogService DialogService
@inject INotificationService NotificationService
@inject IStringLocalizer<Translation> Localizer

<MudGrid Spacing="0">
    <MudItem xs="12">
        <MudText Typo="Typo.h6">
            @Localizer["SpecialPosition"]
        </MudText>
    </MudItem>
    <MudItem xs="12" md="12" lg="10">
        <MudPaper Elevation="0">
            <MudTable Items="@_allEntries"
                      Dense="@Dense"
                      Hover="@Hover"
                      Bordered="@Bordered"
                      Striped="@Striped"
                      FixedHeader="true"
                      @bind-SelectedItem="_selectedItemModel"
                      Filter="new Func<SpecialItemModel,bool>(FilterFunc)"
                      SortLabel="Sort By">
                <ToolBarContent>
                    <MudIconButton Variant="Variant.Filled"
                               Icon="@Icons.Material.Filled.Add"
                               Color="Color.Primary"
                               OnClick="@ShowAddSpecialItemDialog">
                    </MudIconButton>
                    <MudSpacer />
                    <MudTextField @bind-Value="_searchTerm"
                                  Placeholder="Search"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  IconSize="Size.Medium"
                                  Class="mt-0" />
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>
                        <MudTableSortLabel
                            SortBy="new Func<SpecialItemModel, object>(x => x.Id)">
                            @Localizer["Id"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel
                            SortBy="new Func<SpecialItemModel, object>(x => x.Name)">
                            @Localizer["Name"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>@Localizer["Sum"]</MudTh>
                    <MudTh>@Localizer["Actions"]</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="@Localizer["Id"]">
                        @context.Id
                    </MudTd>
                    <MudTd DataLabel="@Localizer["Name"]">
                        @context.Name
                    </MudTd>
                    <MudTd DataLabel="@Localizer["Sum"]">
                        @context.Sum.ToString("C", CultureInfo.CurrentCulture)
                    </MudTd>

                    <MudTd DataLabel="@Localizer["Actions"]">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Info"
                                       aria-label="edit"
                                       OnClick="@(() => ShowEditSpecialItemDialog(context.Id))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       aria-label="delete"
                                       OnClick="@(() => ShowDeleteSpecialItemDialog(context))" />
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private IEnumerable<SpecialItemModel>? _allEntries;
    private const bool Dense = true;
    private const bool Hover = true;
    private const bool Striped = true;
    private const bool Bordered = false;
    private string _searchTerm = string.Empty;
    private SpecialItemModel _selectedItemModel = new();

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        _allEntries = await SpecialItemService.GetAllSpecialItems();
    }

    private bool FilterFunc(SpecialItemModel? element) => MatchesFilter(element, _searchTerm);

    private static bool MatchesFilter(SpecialItemModel? element, string searchTerm)
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
            return true;
        if (element is null || string.IsNullOrWhiteSpace(searchTerm)) return false;
        return element.Name.ToLower().Contains(searchTerm.ToLowerInvariant());
    }

    private async Task ShowAddSpecialItemDialog()
    {
        var result = await DialogService.ShowDialogWithNotificationAsync<SpecialItemDialog>(NotificationService);
        if(result is { IsSuccess: true })
            await UpdateView();
    }

    private async Task UpdateView()
    {
        _allEntries = await SpecialItemService.GetAllSpecialItems();
        await InvokeAsync(StateHasChanged);
    }

    private async Task ShowEditSpecialItemDialog(int specialItemId)
    {
        var result = await DialogService.ShowDialogWithNotificationAsync<SpecialItemDialog>(NotificationService,
            $"{Localizer["Edit"]}",
            new DialogParameters() { ["SpecialItemId"] = specialItemId });
        
        if(result is { IsSuccess: true })
            await UpdateView();
    }

    private async Task ShowDeleteSpecialItemDialog(SpecialItemModel specialItem)
    {
        await DialogService.ShowConfirmDeleteDialogAsync(
            NotificationService,
            entityName: Localizer["SpecialPosition"].Value,
            itemName: $"{specialItem.Name}",
            onConfirm: () => SpecialItemService.DeleteSpecialPositionAsync(specialItem.Id),
            onSuccess: UpdateView,
            deleteTitle: Localizer["Delete"]);
    }
}
