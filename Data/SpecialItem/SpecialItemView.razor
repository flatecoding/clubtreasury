@page "/specialitems"
@using System.Globalization
@using ClubTreasury.Components.View
@using ClubTreasury.Data.OperationResult

@inherits CrudViewBase<SpecialItemModel, SpecialItemDialog>

@inject ISpecialItemService SpecialItemService

<MudGrid Spacing="0">
    <MudItem xs="12">
        <MudText Typo="Typo.h6">
            @Localizer["SpecialPosition"]
        </MudText>
    </MudItem>
    <MudItem xs="12" md="12" lg="10">
        <MudPaper Elevation="0">
            <MudTable Items="@AllEntries"
                      Dense="true"
                      Hover="true"
                      Bordered="false"
                      Striped="true"
                      FixedHeader="true"
                      @bind-SelectedItem="SelectedItem"
                      Filter="new Func<SpecialItemModel,bool>(FilterFunc)"
                      SortLabel="Sort By">
                <ToolBarContent>
                    <MudIconButton Variant="Variant.Filled"
                               Icon="@Icons.Material.Filled.Add"
                               Color="Color.Primary"
                               OnClick="@ShowAddDialog">
                    </MudIconButton>
                    <MudSpacer />
                    <MudTextField @bind-Value="SearchTerm"
                                  Placeholder="Search"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  IconSize="Size.Medium"
                                  Class="mt-0" />
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>
                        <MudTableSortLabel
                            SortBy="new Func<SpecialItemModel, object>(x => x.Id)">
                            @Localizer["Id"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel
                            SortBy="new Func<SpecialItemModel, object>(x => x.Name)">
                            @Localizer["Name"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>@Localizer["Sum"]</MudTh>
                    <MudTh>@Localizer["Actions"]</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="@Localizer["Id"]">
                        @context.Id
                    </MudTd>
                    <MudTd DataLabel="@Localizer["Name"]">
                        @context.Name
                    </MudTd>
                    <MudTd DataLabel="@Localizer["Sum"]">
                        @context.Sum.ToString("C", CultureInfo.CurrentCulture)
                    </MudTd>
                    <MudTd DataLabel="@Localizer["Actions"]">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Info"
                                       aria-label="edit"
                                       OnClick="@(() => ShowEditDialog(context.Id))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       aria-label="delete"
                                       OnClick="@(() => ShowDeleteDialog(context))" />
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    protected override string EntityIdParameterName => "SpecialItemId";
    protected override string EntityLocalizedName => Localizer["SpecialPosition"];
    protected override int GetEntityId(SpecialItemModel entity) => entity.Id;
    protected override string GetEntityDisplayName(SpecialItemModel entity) => entity.Name;
    protected override Task<List<SpecialItemModel>> LoadAllAsync() => SpecialItemService.GetAllSpecialItemsAsync();
    protected override Task<Result> DeleteEntityAsync(int id) => SpecialItemService.DeleteSpecialPositionAsync(id);

    protected override bool MatchesFilter(SpecialItemModel? element, string searchTerm)
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
            return true;
        if (element is null)
            return false;
        return element.Name.ToLower().Contains(searchTerm.ToLowerInvariant());
    }
}
