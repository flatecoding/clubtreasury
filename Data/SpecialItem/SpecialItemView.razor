@page "/specialitems"
@using System.Globalization
@using TTCCashRegister.Data.Source
@using TTCCashRegister.Data.SpecialItem.Dialogs
@inject ISpecialItemService SpecialItemService
@inject IDialogService DialogService
@inject INotificationService NotificationService

<h2>Special items</h2>

<MudPaper Class="mt-4" Style="width:50%;">
    <MudTable Class="mt-2" Items="@_allEntries" Dense="@Dense" Hover="@Hover" Bordered="@Bordered" Striped="@Striped" FixedHeader="true"
              @bind-SelectedItem="_selectedItemModel"
              Filter="new Func<SpecialItemModel,bool>(FilterFunc)"
              SortLabel="Sort By">
        <ToolBarContent>
            <MudButton Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.Add"
                       Color="Color.Primary"
                       @onclick="ShowAddSpecialItemDialog">
                Add Special Item
            </MudButton>
            <MudSpacer />
            <MudTextField @bind-Value="_searchString1"
                          Placeholder="Search"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium"
                          Class="mt-0">
            </MudTextField>
        </ToolBarContent>
        <ColGroup>
            <col style="width: 20px;" />
            <col style="width: 110px;" />
            <col style="width: 110px;" />
            <col style="width: 110px;" />
        </ColGroup>
        <HeaderContent>
            <MudTh>Id<MudTableSortLabel SortBy="new Func<SpecialItemModel, object>(x => x.Id)"></MudTableSortLabel></MudTh>
            <MudTh>Name<MudTableSortLabel SortBy="new Func<SpecialItemModel, object>(x => x.Name)"></MudTableSortLabel></MudTh>
            <MudTh>Amount</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Id">@context.Id</MudTd>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="">@context.Sum.ToString("C", CultureInfo.CurrentCulture)</MudTd>
            <MudTd DataLabel="Actions">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Info" aria-label="edit" @onclick="() => ShowEditSpecialItemDialog(context.Id)"></MudIconButton>
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" aria-label="delete" @onclick="() => ShowDeleteSpecialItemDialog(context.Id)">Delete</MudIconButton>
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
</MudPaper>

@code {
    private IEnumerable<SpecialItemModel>? _allEntries;
    private const bool Dense = true;
    private const bool Hover = true;
    private const bool Striped = true;
    private const bool Bordered = false;
    private string _searchString1 = string.Empty;
    private SpecialItemModel _selectedItemModel = new();

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        _allEntries = await SpecialItemService.GetAllSpecialItems();
    }

    private bool FilterFunc(SpecialItemModel? element) => FilterFunc1(element, _searchString1);

    private bool FilterFunc1(SpecialItemModel? element, string searchstring)
    {
        if (string.IsNullOrWhiteSpace(searchstring))
            return true;
        if (element is not null && !string.IsNullOrWhiteSpace(searchstring))
        {
            if (element.Name.ToLower().Contains(searchstring.ToLowerInvariant()))
                return true;
        }
        return false;
    }

    private async Task ShowAddSpecialItemDialog()
    {
        var dialog = await DialogService.ShowAsync<AddSpecialItemDialog>("Add Special Item", new DialogParameters());
        await NotificationService.ShowDialogResultAsync(await dialog.Result);
        await UpdateView();
    }

    private async Task UpdateView()
    {
        _allEntries = await SpecialItemService.GetAllSpecialItems();
        await InvokeAsync(StateHasChanged);
    }

    private async Task ShowEditSpecialItemDialog(int specialItemId)
    {
        var dialog = await DialogService.ShowAsync<EditSpecialItemDialog>("Edit Special Item", 
            new DialogParameters { ["SpecialItemId"] = specialItemId });
        await NotificationService.ShowDialogResultAsync(await dialog.Result);
        await UpdateView();
    }

    private async Task ShowDeleteSpecialItemDialog(int specialItemId)
    {
        var dialog = await DialogService.ShowAsync<DeleteSpecialItemDialog>("Delete Special Item", 
            new DialogParameters { ["SpecialItemId"] = specialItemId });
        await NotificationService.ShowDialogResultAsync(await dialog.Result);
        await UpdateView();
    }
}
