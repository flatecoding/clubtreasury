@page "/specialitemdialog"
@using Microsoft.Extensions.Localization
@using TTCCashRegister.Data.Notification
@using TTCCashRegister.Data.OperationResult

@inject ISpecialItemService SpecialItemService
@inject IStringLocalizer<Translation> Localizer
@inject INotificationService NotificationService
@inject IOperationResultFactory OperationResultFactory
@inject SpecialItemValidator SpecialItemValidator

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form"
                 Model="_specialItemModel"
                 Validation="SpecialItemValidator.ValidateValue"
                 ValidationDelay="0">

            <MudTextField @bind-Value="_specialItemModel.Name"
                          Label="@Localizer["Name"]"
                          For="@(() => _specialItemModel.Name)"
                          Immediate="true" />
        </MudForm>
    </DialogContent>

    <DialogActions>
        <MudButton Color="Color.Primary" OnClick="@(async () => await Save())">
            @(_isEditMode ? Localizer["Save"] : Localizer["AddEntry"])
        </MudButton>
        <MudButton Color="Color.Secondary" OnClick="@Cancel">@Localizer["Cancel"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int? SpecialItemId { get; set; }

    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = null!;

    private MudForm _form = new();
    private SpecialItemModel _specialItemModel = new();
    private bool _isEditMode;

    protected override async Task OnInitializedAsync()
    {
        _isEditMode = SpecialItemId.HasValue;
        await MudDialog.SetTitleAsync(_isEditMode ? Localizer["Edit"] : Localizer["AddEntry"]);
        await LoadSpecialItemAsync();
    }

    private async Task LoadSpecialItemAsync()
    {
        if (!_isEditMode)
        {
            _specialItemModel = new SpecialItemModel();
            return;
        }

        _specialItemModel = await SpecialItemService.GetSpecialPositionById(SpecialItemId!.Value)
                            ?? new SpecialItemModel();
    }

    private async Task Save()
    {
        await _form.Validate();
        if (!_form.IsValid)
            return;

        var result = _isEditMode
            ? await SpecialItemService.UpdateSpecialPositionAsync(_specialItemModel)
            : await SpecialItemService.AddSpecialPositionAsync(_specialItemModel);

        if (result.Status is OperationResultStatus.Success)
            MudDialog.Close(DialogResult.Ok(result));
        else
            await NotificationService.ShowOperationResultAsync(result);
    }

    private void Cancel() => MudDialog.Close(DialogResult.Ok(OperationResultFactory.Canceled()));
}
