@using ClubTreasury.Components.Dialog
@using ClubTreasury.Data.OperationResult

@inherits SimpleEntityDialogBase<SpecialItemModel>

@inject ISpecialItemService SpecialItemService
@inject SpecialItemValidator SpecialItemValidator

<MudDialog>
    <DialogContent>
        <MudForm @ref="Form"
                 Model="Model"
                 Validation="ValidateValue"
                 ValidationDelay="0"
                 OnEnterPressed="@Save">

            <MudTextField @bind-Value="Model.Name"
                          Label="@Localizer["Name"]"
                          For="@(() => Model.Name)"
                          Immediate="true" />
        </MudForm>
    </DialogContent>

    <DialogActions>
        <MudButton Color="Color.Primary"
                   OnClick="@(async () => await Save())">
            @(IsEditMode ? Localizer["Save"] : Localizer["AddEntry"])
        </MudButton>

        <MudButton Color="Color.Secondary"
                   OnClick="@Cancel">
            @Localizer["Cancel"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int? SpecialItemId { get; set; }

    protected override int? EntityId => SpecialItemId;
    protected override Func<object, string, Task<IEnumerable<string>>> ValidateValue => SpecialItemValidator.ValidateValue;
    protected override Task<SpecialItemModel?> LoadEntityAsync(int id) => SpecialItemService.GetSpecialPositionByIdAsync(id);
    protected override Task<Result> AddEntityAsync(SpecialItemModel model) => SpecialItemService.AddSpecialPositionAsync(model);
    protected override Task<Result> UpdateEntityAsync(SpecialItemModel model) => SpecialItemService.UpdateSpecialPositionAsync(model);
}
