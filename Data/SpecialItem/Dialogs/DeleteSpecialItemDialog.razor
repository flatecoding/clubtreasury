@page "/deletespecialitem"
@inject SpecialItemService SpecialItemService

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h6">Are you sure you want to delete this special item?</MudText>
        <MudText Typo="Typo.subtitle1">@_specialItemName</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="DeleteSpecialItem">Delete</MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int SpecialItemId { get; set; }
    private string _specialItemName = string.Empty;

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        var specialItem = await SpecialItemService.GetSpecialPositionById(SpecialItemId);
        if (specialItem != null)
        {
            _specialItemName = specialItem.Name;
        }
    }

    private async Task DeleteSpecialItem()
    {
        var success = await SpecialItemService.DeleteSpecialPosition(SpecialItemId);
        if (success)
        {
            MudDialog.Close(DialogResult.Ok(true));
        }
        else
        {
            MudDialog.Close(DialogResult.Ok(false));
        }
    }

    private void Cancel()
    {
        MudDialog.Close(DialogResult.Cancel());
    }
}
