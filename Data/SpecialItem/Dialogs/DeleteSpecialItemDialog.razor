@page "/deletespecialitem"
@using Microsoft.Extensions.Localization
@inject ISpecialItemService SpecialItemService
@inject IStringLocalizer<Translation> Localizer

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h6">@Localizer["DeleteQuestion"]</MudText>
        <MudText Typo="Typo.subtitle1">@_specialItemName</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="@(async () => await DeleteSpecialItemAsync())">
            @Localizer["Delete"]
        </MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="@(() => Cancel())">
            @Localizer["Delete"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int SpecialItemId { get; set; }
    private string _specialItemName = string.Empty;

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        var specialItem = await SpecialItemService.GetSpecialPositionById(SpecialItemId);
        if (specialItem != null)
        {
            _specialItemName = specialItem.Name;
        }
    }

    private async Task DeleteSpecialItemAsync()
    {
        var success = await SpecialItemService.DeleteSpecialPosition(SpecialItemId);
        MudDialog.Close(success ? DialogResult.Ok(true) : DialogResult.Ok(false));
    }

    private void Cancel()
    {
        MudDialog.Close(DialogResult.Cancel());
    }
}
