@page "/addspecialitem"
@using Microsoft.Extensions.Localization
@inject ISpecialItemService SpecialItemService
@inject IStringLocalizer<Translation> Localizer

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" Model="_newSpecialItem" Validation="_specialItemValidator.ValidateValue" ValidationDelay="0">
            <MudTextField @bind-Value="_newSpecialItem.Name" Label="@Localizer["Name"]"  
                          For="@(() => _newSpecialItem.Name)" Immediate="true"/>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" OnClick="@(async () => await AddSpecialItemAsync())">
            @Localizer["AddEntry"]
        </MudButton>
        <MudButton Color="Color.Error" OnClick="@(() => Cancel())">
            @Localizer["Cancel"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private MudForm _form = new();
    private readonly SpecialItemModel _newSpecialItem = new();
    private readonly SpecialItemValidator _specialItemValidator = new();

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    private async Task AddSpecialItemAsync()
    {
        await _form.Validate();
        if (_form.IsValid)
        {
            await SpecialItemService.AddSpecialPosition(_newSpecialItem);
            MudDialog.Close(DialogResult.Ok(true));
        }
    }

    private void Cancel()
    {
        MudDialog.Close(DialogResult.Cancel());
    }
}
