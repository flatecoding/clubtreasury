@page "/editspecialitem"
@using Microsoft.Extensions.Localization
@inject ISpecialItemService SpecialItemService
@inject IStringLocalizer<Translation> Localizer

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" Model="_editSpecialItem" Validation="_specialItemValidator.ValidateValue" ValidationDelay="0">
            <MudTextField @bind-Value="_editSpecialItem.Name" Label=@Localizer["Name"] For="@(() => _editSpecialItem.Name)" Immediate="true"/>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary"
                   OnClick="@(async () => await SaveSpecialItem())">
            @Localizer["Save"]
        </MudButton>
        <MudButton Color="Color.Error" OnClick="@(() => Cancel())">
            @Localizer["Cancel"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int SpecialItemId { get; set; }
    private MudForm _form = new();
    private SpecialItemModel _editSpecialItem = new();
    private readonly SpecialItemValidator _specialItemValidator = new();

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        _editSpecialItem = await SpecialItemService.GetSpecialPositionById(SpecialItemId) ?? new SpecialItemModel();
    }

    private async Task SaveSpecialItem()
    {
        await _form.Validate();
        if (_form.IsValid)
        {
            await SpecialItemService.UpdateSpecialPosition(_editSpecialItem);
            MudDialog.Close(DialogResult.Ok(true));
        }
    }

    private void Cancel()
    {
        MudDialog.Close(DialogResult.Cancel());
    }
}
