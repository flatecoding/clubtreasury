@page "/transactions"
@using System.Globalization
@using Microsoft.Extensions.Localization
@using ClubTreasury.Data.DialogService
@using ClubTreasury.Data.Notification
@using ClubTreasury.Data.Transaction.Dialogs
@using ClubTreasury.Data.TransactionDetails
@inject ITransactionService TransactionService
@inject IDialogService DialogService
@inject INotificationService NotificationService
@inject IStringLocalizer<Translation> Localizer

<MudGrid Spacing="0">
    <MudItem xs="12">
        <MudText Typo="Typo.h6">
            @Localizer["TransactionPlural"]
        </MudText>
    </MudItem>
    <MudItem xs="12" md="12" >
        <MudPaper Elevation="0">
            <MudTable @ref="_table"
                      ServerData="LoadServerData"
                      RowsPerPage="25"
                      Dense="@Dense"
                      Hover="@Hover"
                      Bordered="@Bordered"
                      Striped="@Striped"
                      FixedHeader="@FixedHeader"
                      FixedFooter="@FixedFooter"
                      Height="700px"
                      @bind-SelectedItem="_selectedItem"
                      SortLabel="Sort By">
                <ToolBarContent>
                    <MudIconButton Variant="Variant.Filled"
                                   Icon="@Icons.Material.Filled.Add"
                                   Color="Color.Primary"
                                   OnClick="@ShowAddTransactionDialog" />

                    <MudSpacer />
                    <MudHidden Breakpoint="Breakpoint.SmAndDown">
                        <MudBadge Content="@ActiveFilterCount"
                                  Color="Color.Primary"
                                  Overlap="true">
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.FilterAlt"
                                       OnClick="@ShowFilterDialog">
                                    @Localizer["Filter"]
                            </MudButton>
                        </MudBadge>
                    </MudHidden>
                    <MudHidden Breakpoint="Breakpoint.MdAndUp">
                        <MudBadge Content="@ActiveFilterCount"
                                  Color="Color.Default"
                                  Overlap="true">
                            <MudIconButton Icon="@Icons.Material.Filled.FilterAlt"
                                           Color="Color.Primary"
                                           OnClick="@ShowFilterDialog" />
                        </MudBadge>
                    </MudHidden>
                    @if (HasActiveFilters)
                    {
                        <MudTooltip Text="@Localizer["ResetFilter"]">
                            <MudIconButton Icon="@Icons.Material.Filled.FilterAltOff"
                                           Color="Color.Default"
                                           OnClick="@ResetFilter" />
                        </MudTooltip>
                    }
                </ToolBarContent>

                <HeaderContent>
                    <MudTh>
                        <MudTableSortLabel
                            SortLabel="Date"
                            SortBy="new Func<TransactionModel, object?>(x => x.Date)">
                            @Localizer["Date"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel
                            SortLabel="DocumentNumber"
                            SortBy="new Func<TransactionModel, object>(x => x.Documentnumber)">
                            @Localizer["DocumentNumberShort"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>@Localizer["Description"]</MudTh>
                    <MudTh>
                        <MudTableSortLabel
                            SortLabel="Sum"
                            SortBy="new Func<TransactionModel, object>(x => x.Sum)">
                            @Localizer["Sum"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>@Localizer["Account"]</MudTh>
                    <MudTh>
                        <MudTableSortLabel SortLabel="CostCenter"
                                           SortBy="new Func<TransactionModel, object>(x => x.Allocation.CostCenter.CostUnitName)">
                            @Localizer["CostCenter"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel SortLabel="Category"
                                           SortBy="new Func<TransactionModel, object?>(x => x.Allocation.Category.Name)">
                            @Localizer["Category"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel SortLabel="ItemDetail"
                                           SortBy="new Func<TransactionModel, object?>(x => x.Allocation.ItemDetail?.CostDetails)">
                            @Localizer["ItemDetail"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>@Localizer["Actions"]</MudTh>
                </HeaderContent>
                <RowTemplate Context="context">
                    @if (context is not null)
                    {
                        <MudTd DataLabel="@Localizer["Date"].Value">
                            @context.Date?.ToString("dd.MM.yyyy")
                        </MudTd>
                        <MudTd DataLabel="@Localizer["DocumentNumberShort"].Value">
                            @context.Documentnumber
                        </MudTd>
                        <MudTd DataLabel="@Localizer["Description"].Value">
                            @context.Description
                        </MudTd>
                        <MudTd DataLabel="@Localizer["Sum"].Value">
                            @context.Sum.ToString("C", CultureInfo.CurrentCulture)
                        </MudTd>
                        <MudTd DataLabel="@Localizer["Account"].Value">
                            @context.AccountMovement.ToString("C", CultureInfo.CurrentCulture)
                        </MudTd>
                        <MudTd DataLabel="@Localizer["CostCenter"].Value">
                            @context.Allocation.CostCenter.CostUnitName
                        </MudTd>
                        <MudTd DataLabel="@Localizer["Category"].Value">
                            @context.Allocation.Category.Name
                        </MudTd>
                        <MudTd DataLabel="@Localizer["ItemDetail"].Value">
                            @context.Allocation.ItemDetail?.CostDetails
                        </MudTd>
                        <MudTd DataLabel="@Localizer["Actions"].Value">
                            <MudIconButton Icon="@Icons.Material.Filled.List"
                                           Color="Color.Secondary"
                                           aria-label="show-transactionDetails"
                                           OnClick="@(() => ShowTransactionDetailsOverviewDialog(
                                                context.Id,
                                                context.Documentnumber))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                           Color="Color.Info"
                                           aria-label="edit"
                                           OnClick="@(() => ShowEditTransactionDialog(context.Id))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Color="Color.Error"
                                           aria-label="delete"
                                           OnClick="@(() => ShowDeleteTransactionDialog(context))" />
                        </MudTd>
                    }
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private MudTable<TransactionModel>? _table;
    private const bool Dense = true;
    private const bool Hover = true;
    private const bool Striped = true;
    private const bool Bordered = false;
    private string _searchTerm = string.Empty;
    private TransactionModel? _selectedItem;
    private DateRange _dateRange = new(null, null);

    private int? _personId;
    private const bool FixedHeader = true;
    private const bool FixedFooter = true;
    private bool HasActiveFilters =>
        (_dateRange.Start.HasValue || _dateRange.End.HasValue) ||
        !string.IsNullOrWhiteSpace(_searchTerm) ||
        _personId.HasValue;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
    }

    private async Task ShowFilterDialog()
    {
        var parameters = new DialogParameters
        {
            ["DateRange"] = _dateRange,
            ["SearchText"] = _searchTerm,
            ["SelectedPersonId"] = _personId,
        };

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, BackdropClick = false };

        var dialog = await DialogService.ShowAsync<TransactionFilterDialog>(Localizer["Filter"].Value, parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            var values = (TransactionFilterValues)result.Data!;
            _dateRange = values.DateRange;
            _searchTerm = values.SearchText;
            _personId = values.PersonId;

            await UpdateView();
        }
    }

    private async Task ShowTransactionDetailsOverviewDialog(int transactionId, int documentNumber)
    {
        var result = await DialogService.ShowDialogWithNotificationAsync<TransactionDetailsOverviewDialog>(
            NotificationService,
            Localizer["AddEntry"],
            new DialogParameters
            {
                ["TransactionId"] = transactionId,
                ["ParentDocumentNumber"] = documentNumber
            },
            new DialogOptions(){MaxWidth = MaxWidth.Large});
        
        if(result is { IsSuccess: true })
            await UpdateView();
        
    }
    
    private async Task ShowAddTransactionDialog()
    {
        var result = await DialogService.ShowDialogWithNotificationAsync<TransactionDialog>(NotificationService,
            Localizer["AddEntry"],
            null,
            new DialogOptions(){MaxWidth = MaxWidth.Small});
        
        if(result is { IsSuccess: true })
            await UpdateView();
    }

    private async Task ShowEditTransactionDialog(int transactionId)
    {
        var result = await DialogService.ShowDialogWithNotificationAsync<TransactionDialog>(
            NotificationService,
            $"{Localizer["Edit"]}",
            new DialogParameters { ["TransactionId"] = transactionId },
            new DialogOptions(){MaxWidth = MaxWidth.Small});
        
        if(result is { IsSuccess: true })
            await UpdateView();
    }
    
    private async Task ShowDeleteTransactionDialog(TransactionModel transaction)
    {
        await DialogService.ShowConfirmDeleteDialogAsync(
            NotificationService,
            entityName: Localizer["Transaction"].Value,
            itemName: $"{transaction.Documentnumber}",
            onConfirm: () => TransactionService.DeleteTransactionAsync(transaction.Id),
            onSuccess: UpdateView,
            deleteTitle: Localizer["Delete"]);
    }

    private async Task ResetFilter()
    {
        _dateRange = new DateRange(null, null);
        _searchTerm = "";
        _personId = null;
        await UpdateView();
    }
    
    private int ActiveFilterCount
    {
        get
        {
            var count = 0;
            if (_dateRange.Start.HasValue|| _dateRange.End.HasValue) count++;
            if (!string.IsNullOrWhiteSpace(_searchTerm)) count++;
            if (_personId.HasValue) count++;
            return count;
        }
    }

    private async Task UpdateView()
    {
        if (_table is not null)
            await _table.ReloadServerData();
    }
    
    private async Task<TableData<TransactionModel?>> LoadServerData(TableState state, CancellationToken cancellationToken)
    {
        var requestOptions = new PagedRequestOptions
        {
            Page = state.Page,
            PageSize = state.PageSize,
            SortLabel = state.SortLabel,
            SortDirection = state.SortDirection switch
            {
                MudBlazor.SortDirection.Ascending => SortDirection.Ascending,
                MudBlazor.SortDirection.Descending => SortDirection.Descending,
                _ => SortDirection.None
            },
            DateStart = _dateRange.Start,
            DateEnd = _dateRange.End,
            SearchText = _searchTerm,
            PersonId = _personId
        };

        var result = await TransactionService.GetTransactionsPagedAsync(requestOptions, cancellationToken);
        return new TableData<TransactionModel?> { Items = result.Items, TotalItems = result.TotalItems };
    }
}
