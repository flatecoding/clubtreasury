@page "/transactions"
@using System.Globalization
@using Microsoft.Extensions.Localization
@using TTCCashRegister.Data.Dialog
@using TTCCashRegister.Data.Source
@using TTCCashRegister.Data.Transaction.Dialogs
@using TTCCashRegister.Data.TransactionDetails
@inject ITransactionService TransactionService
@inject IDialogService DialogService
@inject INotificationService NotificationService
@inject IStringLocalizer<Translation> Localizer

<MudGrid Spacing="0">
    <MudItem xs="12">
        <MudText Typo="Typo.h6">
            @Localizer["TransactionPlural"]
        </MudText>
    </MudItem>
    <MudItem xs="12">
        <MudPaper Elevation="0">
            <MudTable @ref="_table"
                      ServerData="LoadServerData"
                      RowsPerPage="25"
                      Dense="@Dense"
                      Hover="@Hover"
                      Bordered="@Bordered"
                      Striped="@Striped"
                      FixedHeader="@_fixedHeader"
                      FixedFooter="@_fixedFooter"
                      Height="@(_fixedHeader || _fixedFooter ? "700px" : null)"
                      @bind-SelectedItem="_selectedItem"
                      SortLabel="Sort By">
                <ToolBarContent>
                    <MudIconButton Variant="Variant.Filled"
                               Icon="@Icons.Material.Filled.Add"
                               Color="Color.Primary"
                               OnClick="@ShowAddTransactionDialog">
                    </MudIconButton>
                    <MudSpacer />
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.FilterAlt"
                               OnClick="@ShowFilterDialog">
                        @Localizer["Filter"]
                    </MudButton>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>
                        <MudTableSortLabel
                            SortLabel="Date"
                            SortBy="new Func<TransactionModel, object?>(x => x.Date)">
                            @Localizer["Date"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel
                            SortLabel="DocumentNumber"
                            SortBy="new Func<TransactionModel, object>(x => x.Documentnumber)">
                            @Localizer["DocumentNumberShort"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>@Localizer["Description"]</MudTh>
                    <MudTh>
                        <MudTableSortLabel
                            SortLabel="Sum"
                            SortBy="new Func<TransactionModel, object>(x => x.Sum)">
                            @Localizer["Sum"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>@Localizer["Account"]</MudTh>
                    <MudTh>
                        <MudTableSortLabel SortLabel="CostCenter"
                                           SortBy="new Func<TransactionModel, object>(x => x.Allocation.CostCenter.CostUnitName)">
                            @Localizer["CostCenter"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel SortLabel="Category"
                                           SortBy="new Func<TransactionModel, object?>(x => x.Allocation.Category != null ? x.Allocation.Category.Name : null)">
                            @Localizer["Category"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel SortLabel="ItemDetail"
                                           SortBy="new Func<TransactionModel, object?>(x => x.Allocation.ItemDetail != null ? x.Allocation.ItemDetail.CostDetails : null)">
                            @Localizer["ItemDetail"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>@Localizer["Actions"]</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="@Localizer["Date"].Value">
                        @context?.Date?.ToString("dd.MM.yyyy")
                    </MudTd>
                    <MudTd DataLabel="@Localizer["DocumentNumberShort"].Value">
                        @context.Documentnumber
                    </MudTd>
                    <MudTd DataLabel="@Localizer["Description"].Value">
                        @context.Description
                    </MudTd>
                    <MudTd DataLabel="@Localizer["Sum"].Value">
                        @context.Sum.ToString("C", CultureInfo.CurrentCulture)
                    </MudTd>
                    <MudTd DataLabel="@Localizer["Account"].Value">
                        @context.AccountMovement.ToString("C", CultureInfo.CurrentCulture)
                    </MudTd>
                    <MudTd DataLabel="@Localizer["CostCenter"].Value">
                        @context.Allocation.CostCenter.CostUnitName
                    </MudTd>
                    <MudTd DataLabel="@Localizer["Category"].Value">
                        @context.Allocation.Category?.Name
                    </MudTd>
                    <MudTd DataLabel="@Localizer["ItemDetail"].Value">
                        @context.Allocation.ItemDetail?.CostDetails
                    </MudTd>
                    <MudTd DataLabel="@Localizer["Actions"].Value">
                        <MudIconButton Icon="@Icons.Material.Filled.List"
                                       Color="Color.Secondary"
                                       aria-label="show-transactionDetails"
                                       OnClick="@(() => ShowTransactionDetailsOverviewDialog(
                                            context.Id,
                                            context.Documentnumber))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Info"
                                       aria-label="edit"
                                       OnClick="@(() => ShowEditTransactionDialog(context.Id))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       aria-label="delete"
                                       OnClick="@(() => ShowDeleteTransactionDialog(context.Id))" />
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private MudTable<TransactionModel>? _table;
    private const bool Dense = true;
    private const bool Hover = true;
    private const bool Striped = true;
    private const bool Bordered = false;
    private string _searchString1 = string.Empty;
    private TransactionModel? _selectedItem;
    private DateRange _dateRange = new(null, null);

    private readonly DialogOptions _transactionDetailsOverviewOptions = new()
    {
        MaxWidth = MaxWidth.Large,
        FullWidth = true,
        BackdropClick = false,
        BackgroundClass= "custom-dialog-background"
    };

    private int? _personId;
    private readonly bool _fixedHeader = true;
    private readonly bool _fixedFooter = true;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
    }

    private async Task ShowFilterDialog()
    {
        var parameters = new DialogParameters
        {
            ["DateRange"] = _dateRange,
            ["SearchText"] = _searchString1,
            ["SelectedPersonId"] = _personId,
        };

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, BackdropClick = false };

        var dialog = await DialogService.ShowAsync<TransactionFilterDialog>(Localizer["Filter"].Value, parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            var values = (TransactionFilterValues)result.Data!;
            _dateRange = values.DateRange;
            _searchString1 = values.SearchText;
            _personId = values.PersonId;

            await UpdateView();
        }
    }

    private async Task ShowTransactionDetailsOverviewDialog(int transactionId, int documentNumber)
    {
        var dialog = await DialogService.ShowAsync<TransactionDetailsOverviewDialog>(null,
            new DialogParameters
            {
                ["TransactionId"] = transactionId,
                ["ParentDocumentNumber"] = documentNumber
            },
            _transactionDetailsOverviewOptions);
        await dialog.Result;
        
        await UpdateView();
    }
    
    private async Task ShowAddTransactionDialog()
    {
        var dialog = await DialogService.ShowAsync<TransactionDialog>(string.Empty);
        await NotificationService.ShowDialogResultAsync(await dialog.Result);
        await UpdateView();
    }

    private async Task ShowEditTransactionDialog(int transactionId)
    {
        var dialog = await DialogService.ShowAsync<TransactionDialog>("Edit Transaction",
            new DialogParameters { ["TransactionId"] = transactionId });
        await NotificationService.ShowDialogResultAsync(await dialog.Result);
        await UpdateView();
    }
    
    private async Task ShowDeleteTransactionDialog(int transactionId)
    {
        var transaction = await TransactionService.GetTransactionByIdAsync(transactionId);
        if (transaction == null) return;

        var dialog = await DialogService.ShowAsync<ConfirmDeleteDialog>(
            string.Empty,
            new DialogParameters
            {
                ["EntityName"] = Localizer["Transaction"].Value,
                ["ItemName"] = $"B{transaction.Documentnumber.ToString()}: {transaction.Description}",
                ["OnConfirm"] = EventCallback.Factory.Create(this, async () =>
                {
                    await TransactionService.DeleteTransactionAsync(transactionId);
                })
            });

        await NotificationService.ShowDialogResultAsync(await dialog.Result);
        await UpdateView();
    }

    private async Task UpdateView()
    {
        if (_table is not null)
            await _table.ReloadServerData();
    }
    
    private async Task<TableData<TransactionModel>> LoadServerData(TableState state, CancellationToken cancellationToken)
    {
        return await TransactionService.GetTransactionsPagedOptimized(
            state,
            cancellationToken,
            _dateRange,
            _searchString1,
            _personId);
    }
}
