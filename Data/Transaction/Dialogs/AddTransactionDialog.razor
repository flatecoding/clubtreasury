@page "/addtransactions"
@using System.Globalization
@using TTCCashRegister.Data.BasicUnit
@using TTCCashRegister.Data.CashRegister
@using TTCCashRegister.Data.CostUnit
@using TTCCashRegister.Data.SpecialItem
@using TTCCashRegister.Data.Transaction
@using TTCCashRegister.Data.UnitDetail
@inject TransactionService TransactionService
@inject CostUnitService CostUnitService
@inject BasicUnitService BasicUnitService
@inject SpecialItemService SpecialItemService
@inject CashRegisterService CashRegisterService


<MudDialog>
    <DialogContent>
        <MudForm Model="_newTransactionModel" @ref="@_form" Validation="_transactionValidator.ValidateValue" ValidationDelay="0">
            <MudSelect T="CashRegisterModel"
                       Label="Cash register"
                       Required="true"
                       ToStringFunc="@_cashRegisterConverter"
                       Immediate="true"
                       @bind-Value="@_selectedCashRegisterModel"
                       @bind-Value:after="OnCashRegisterChangedAsync">
                @if (_cashRegisters is not null)
                {
                    @foreach (var cash in _cashRegisters)
                    {
                        <MudSelectItem T="CashRegisterModel" Value="@cash">@cash.Name</MudSelectItem>
                    }
                }
            </MudSelect>
            <MudDatePicker @bind-Date="@TransactionDateTime" Label="Date" Required="true" RequiredError="Date is required." />
            <MudTextField @bind-Value="_newTransactionModel.Documentnumber" Label="Document Number" For="@(() => _newTransactionModel.Documentnumber)" Immediate="true" />
            <MudTextField @bind-Value="_newTransactionModel.Description" Label="Description" For="@(() => _newTransactionModel.Description)" Immediate="true"/>
            <MudTextField @bind-Value="_newTransactionModel.Sum" Label="Sum" For="@(() => _newTransactionModel.Sum)" Immediate="true"/>
            <MudTextField @bind-Value="_newTransactionModel.AccountMovement" Label="Account Movement" For="@(() => _newTransactionModel.AccountMovement)" Immediate="true"/>
            
            <MudSelect T="CostUnitModel" 
                Label="Cost Unit" 
                Required="true" 
                ToStringFunc="@_unitConverter"
                Immediate="true"
                @bind-Value="@_selectedCostUnit"
                @bind-Value:after="OnCostUnitChangedAsync"       
            >
                @if (_costUnits is not null)
                {
                    @foreach (var unit in _costUnits)
                    {
                        <MudSelectItem T="CostUnitModel" Value="@unit">@unit.CostUnitName</MudSelectItem>
                    }
                }
            </MudSelect>
            <MudSelect T="BasicUnitModel" 
                Label="Basic Unit"  
                Disabled="@(string.IsNullOrEmpty(_selectedCostUnit.CostUnitName))" 
                Required="true" 
                ToStringFunc="@_basicUnitConverter"
                @bind-Value="_selectedBasicUnit"
                @bind-Value:after="OnBasicUnitChangedAsync"
            >
                @if (_basicUnits is not null)
                {
                    @foreach (var basicUnit in _basicUnits)
                    {
                        <MudSelectItem T="BasicUnitModel" Value="@basicUnit">@basicUnit.Name</MudSelectItem>
                    }
                }
            </MudSelect>
            <MudSelect T="UnitDetailsModel" 
                Label="Unit Details"
                Disabled="@(string.IsNullOrEmpty(_selectedBasicUnit.Name))" 
                ToStringFunc="@_detailsConverter"
                @bind-Value="_selectedUnitDetail"
            >
                <MudSelectItem T="UnitDetailsModel" Value="null">None</MudSelectItem>
                @if (_unitDetails is not null)
                {
                    @foreach (var unitDetail in _unitDetails)
                    {
                        <MudSelectItem T="UnitDetailsModel" Value="@unitDetail">@unitDetail.CostDetails</MudSelectItem>
                    }
                }
            </MudSelect>
            <MudSelect T="SpecialItemModel" 
                Label="SpecialItem"
                ToStringFunc="@_specialItemConverter"
                Placeholder="Select special position if required"
                @bind-Value="_selectedSpecialItem"  
            >
                <MudSelectItem T="SpecialItemModel" Value="null">None</MudSelectItem>
                @foreach (var specialItem in _specialItemList)
                {
                    <MudSelectItem T="SpecialItemModel" Value="@specialItem">@specialItem.Name</MudSelectItem>
                }
            </MudSelect>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(async () => await AddTransaction())">Add</MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private MudForm _form = new();
    private readonly TransactionModel _newTransactionModel = new();
    readonly TransactionValidator _transactionValidator = new();
    private DateTime? TransactionDateTime { get; set; } = DateTime.Now;
    private IEnumerable<CostUnitModel> _costUnits = new List<CostUnitModel>();
    private IEnumerable<BasicUnitModel> _basicUnits = new List<BasicUnitModel>();
    private IEnumerable<UnitDetailsModel> _unitDetails = new List<UnitDetailsModel>();
    private IEnumerable<CashRegisterModel>? _cashRegisters = new List<CashRegisterModel>();
    private CostUnitModel _selectedCostUnit = new();
    private BasicUnitModel _selectedBasicUnit = new();
    private UnitDetailsModel _selectedUnitDetail = new();
    private IEnumerable<SpecialItemModel> _specialItemList = new List<SpecialItemModel>();
    private SpecialItemModel? _selectedSpecialItem = new();
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;
    private CashRegisterModel _selectedCashRegisterModel = new();


    readonly Func<CashRegisterModel, string> _cashRegisterConverter = p => p?.Name ?? string.Empty;
    Func<DateTime, string> _dateOnlyConverter = d => d.ToString(CultureInfo.CurrentCulture);
    readonly Func<CostUnitModel, string> _unitConverter = p => p?.CostUnitName ?? string.Empty;
    readonly Func<UnitDetailsModel, string> _detailsConverter = d => d?.CostDetails ??string.Empty;
    readonly Func<SpecialItemModel, string> _specialItemConverter = s => s?.Name ?? string.Empty;
    readonly Func<BasicUnitModel, string> _basicUnitConverter = b => b?.Name ?? string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _costUnits = await CostUnitService.GetAllUnitsAsync();
            _basicUnits = await BasicUnitService.GetAllBasicUnitsAsync();
            _specialItemList = await SpecialItemService.GetAllSonderposten();
            _cashRegisters = await CashRegisterService.GetAllCashRegisters();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error during init: {ex.Message}");
        }
    }

    private async Task OnCostUnitChangedAsync()
    {
        _basicUnits = _selectedCostUnit.BasicUnitDetails;
        _selectedBasicUnit = new BasicUnitModel();
        _unitDetails = new List<UnitDetailsModel>();
        _selectedUnitDetail = new UnitDetailsModel();
        await InvokeAsync(StateHasChanged); 
    }

    private async Task OnBasicUnitChangedAsync()
    {
        _unitDetails = _selectedBasicUnit.CostUnitDetails;
        _selectedUnitDetail = new();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnCashRegisterChangedAsync()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async Task AddTransaction()
    {
        await _form.Validate();
        if (_form.IsValid)
        {
            //Connect data
            _newTransactionModel.CashRegister = _selectedCashRegisterModel;
            _newTransactionModel.CashRegisterId = _selectedCashRegisterModel.ID;
            if (TransactionDateTime.HasValue)
            {
                _newTransactionModel.Date = DateOnly.FromDateTime(TransactionDateTime.Value);
            }
            _newTransactionModel.CostUnit = _selectedCostUnit;
            _newTransactionModel.CostUnitId = _selectedCostUnit.Id;
            _newTransactionModel.BasicUnit = _selectedBasicUnit;
            _newTransactionModel.BasicUnitId = _selectedBasicUnit.Id;
            if (_selectedUnitDetail is not null)
            {
                _newTransactionModel.UnitDetailsId = _selectedUnitDetail.Id;
                _newTransactionModel.UnitDetails = _selectedUnitDetail;
            }
            if (_selectedSpecialItem is not null)
            {
                _newTransactionModel.SpecialItemId = _selectedSpecialItem.Id;
                _newTransactionModel.SpecialItem = _selectedSpecialItem;
            }

            if (await TransactionService.AddTransaction(_newTransactionModel))
            {
                MudDialog.Close(DialogResult.Ok(true));

            }
            else
                MudDialog.Close(DialogResult.Ok(false));
        }
    }

    private void Cancel()
    {
        MudDialog.Close(DialogResult.Cancel());
    }
}
