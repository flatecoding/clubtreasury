@page "/transactiondialog"
@using Microsoft.Extensions.Localization
@using TTCCashRegister.Data.Allocation
@using TTCCashRegister.Data.CashRegister
@using TTCCashRegister.Data.Category
@using TTCCashRegister.Data.CostCenter
@using TTCCashRegister.Data.ItemDetail
@using TTCCashRegister.Data.SpecialItem
@using TTCCashRegister.Data.Transaction
@inject ITransactionService TransactionService
@inject ICostCenterService CostCenterService
@inject ICategoryService CategoryService
@inject IItemDetailService ItemDetailService
@inject ICashRegisterService CashRegisterService
@inject ISpecialItemService SpecialItemService
@inject IStringLocalizer<Translation> Localizer

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" Model="_transactionModel" Validation="_transactionValidator.ValidateValue" ValidationDelay="0">
            
            <MudSelect T="CashRegisterModel"
                       Label="@Localizer["CashRegister"]"
                       Required="true"
                       ToStringFunc="@_cashRegisterConverter"
                       Immediate="true"
                       @bind-Value="_selectedCashRegisterModel"
                       @bind-Value:after="OnCashRegisterChangedAsync">
                @foreach (var cash in _cashRegisters)
                {
                    <MudSelectItem T="CashRegisterModel" Value="@cash">@cash.Name</MudSelectItem>
                }
            </MudSelect>

            <MudDatePicker 
                @bind-Date="@TransactionDateTime"
                Editable="true" 
                Label="@Localizer["Date"]" 
                Required="true" 
                RequiredError="Date is required." />

            <MudTextField @bind-Value="_transactionModel.Documentnumber" 
                          Label="@Localizer["DocumentNumber"]" 
                          For="@(() => _transactionModel.Documentnumber)" 
                          Immediate="true" />

            <MudTextField @bind-Value="_transactionModel.Description" 
                          Label="@Localizer["Description"]" 
                          For="@(() => _transactionModel.Description)" 
                          Immediate="true" />

            <MudTextField @bind-Value="_transactionModel.Sum"
                          Label="@Localizer["Sum"]" 
                          For="@(() => _transactionModel.Sum)" 
                          Immediate="true" />

            <MudTextField @bind-Value="_transactionModel.AccountMovement"
                          Label="@Localizer["Account"]" 
                          For="@(() => _transactionModel.AccountMovement)" 
                          Immediate="true" />

            <MudSelect T="CostCenterModel" 
                       Label="@Localizer["CostCenter"]" 
                       Required="true" 
                       ToStringFunc="@_unitConverter"
                       Immediate="true"
                       @bind-Value="_selectedCostUnit"
                       @bind-Value:after="OnCostUnitChangedAsync">
                @foreach (var unit in _costCenters)
                {
                    <MudSelectItem T="CostCenterModel" Value="@unit">@unit.CostUnitName</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="CategoryModel" 
                       Label="@Localizer["Category"]"  
                       Disabled="@(_selectedCostUnit == null)" 
                       Required="true" 
                       ToStringFunc="@_basicUnitConverter"
                       @bind-Value="_selectedBasicUnit"
                       @bind-Value:after="OnBasicUnitChangedAsync">
                @if (_categories is not null)
                {
                    @foreach (var basicUnit in _categories)
                    {
                        <MudSelectItem T="CategoryModel" Value="@basicUnit">@basicUnit.Name</MudSelectItem>
                    }
                }
            </MudSelect>

            <MudSelect T="ItemDetailModel" 
                       Label="@Localizer["ItemDetail"]"
                       Disabled="@(_selectedBasicUnit == null)" 
                       ToStringFunc="@_detailsConverter"
                       @bind-Value="_selectedUnitDetail">
                <MudSelectItem T="ItemDetailModel" Value="@null">None</MudSelectItem>
                @if (_unitDetails is not null)
                {
                    foreach (var unitDetail in _unitDetails)
                    {
                        <MudSelectItem T="ItemDetailModel" Value="@unitDetail">@unitDetail.CostDetails</MudSelectItem>
                    }
                }
            </MudSelect>
            <MudSelect T="SpecialItemModel" 
                       Label="@Localizer["SpecialPositions"]"
                       ToStringFunc="@_specialItemConverter"
                       Placeholder="@Localizer["SpecialPositionIfRequired"]"
                       @bind-Value="_selectedSpecialItem">
                <MudSelectItem T="SpecialItemModel" Value="@null">None</MudSelectItem>
                @foreach (var specialItem in _specialItemList)
                {
                    <MudSelectItem T="SpecialItemModel" Value="@specialItem">@specialItem.Name</MudSelectItem>
                }
            </MudSelect>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" OnClick="@(async () => await Save())">
            @(_isEditMode ? $"{Localizer["Save"]}" : $"{Localizer["AddEntry"]}")
        </MudButton>
        <MudButton Color="Color.Error" OnClick="@Cancel">@Localizer["Cancel"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int? TransactionId { get; set; }

    private MudForm _form = new();
    private TransactionModel _transactionModel = new();
    private readonly TransactionValidator _transactionValidator = new();

    private bool _isEditMode;

    private DateTime? TransactionDateTime { get; set; } = DateTime.Now;

    private IEnumerable<CostCenterModel> _costCenters = [];
    private IEnumerable<CategoryModel>? _categories = [];
    private IEnumerable<ItemDetailModel>? _unitDetails = [];
    private IEnumerable<CashRegisterModel> _cashRegisters = [];
    private IEnumerable<SpecialItemModel> _specialItemList = [];

    private CostCenterModel? _selectedCostUnit;
    private CategoryModel? _selectedBasicUnit;
    private ItemDetailModel? _selectedUnitDetail;
    private CashRegisterModel? _selectedCashRegisterModel;
    private SpecialItemModel? _selectedSpecialItem;

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    
    private readonly Func<CashRegisterModel, string> _cashRegisterConverter = p => p?.Name ?? string.Empty;
    private readonly Func<CostCenterModel, string> _unitConverter = p => p?.CostUnitName ?? string.Empty;
    private readonly Func<ItemDetailModel, string> _detailsConverter = d => d?.CostDetails ?? string.Empty;
    private readonly Func<SpecialItemModel, string> _specialItemConverter = s => s?.Name ?? string.Empty;
    private readonly Func<CategoryModel, string> _basicUnitConverter = b => b?.Name ?? string.Empty;

   protected override async Task OnInitializedAsync()
{
    _isEditMode = TransactionId.HasValue;
    
    _costCenters = await CostCenterService.GetAllCostCentersAsync();
    _specialItemList = await SpecialItemService.GetAllSpecialItems();
    _cashRegisters = await CashRegisterService.GetAllCashRegisters();

    if (_isEditMode && TransactionId is not null)
    {
        _transactionModel = await TransactionService.GetTransactionByIdAsync(TransactionId.Value) ?? new TransactionModel();

        // Vorbelegung aus gespeicherter Transaktion
        _selectedCashRegisterModel = _transactionModel.CashRegister;
        _selectedCostUnit = _transactionModel.Allocation?.CostCenter;
        _selectedBasicUnit = _transactionModel.Allocation?.Category;
        _selectedUnitDetail = _transactionModel.Allocation?.ItemDetail;
        _selectedSpecialItem = _transactionModel.SpecialItem;
        TransactionDateTime = _transactionModel.Date?.ToDateTime(TimeOnly.MinValue);

        // Nachladen der abhängigen Dropdowns
        if (_selectedCostUnit is not null)
        {
            _categories = await CategoryService.GetCategoriesByCostCenterIdAsync(_selectedCostUnit.Id);

            var categoryModels = _categories.ToList();
            if (_selectedBasicUnit is not null && categoryModels.All(b => b.Id != _selectedBasicUnit.Id))
                _selectedBasicUnit = categoryModels.FirstOrDefault();

            if (_selectedBasicUnit is not null)
            {
                _unitDetails = await ItemDetailService.GetItemDetailByCategoryIdAsync(_selectedBasicUnit.Id);

                if (_selectedUnitDetail is not null && _unitDetails.All(u => u.Id != _selectedUnitDetail.Id))
                    _selectedUnitDetail = _unitDetails.FirstOrDefault();
            }
        }
    }
    else
    {
        _transactionModel = new TransactionModel();
    }

    await MudDialog.SetTitleAsync(_isEditMode ? $"{Localizer["Edit"]}" : $"{Localizer["AddEntry"]}");
    StateHasChanged();
}

    private async Task OnCostUnitChangedAsync()
    {
        _categories = [];
        _selectedBasicUnit = null;
        _unitDetails = [];
        _selectedUnitDetail = null;

        if (_selectedCostUnit is not null)
        {
            _categories = await CategoryService.GetCategoriesByCostCenterIdAsync(_selectedCostUnit.Id);
            if (_categories != null) _selectedBasicUnit = _categories.FirstOrDefault();
            await OnBasicUnitChangedAsync();
        }

       StateHasChanged();
    }

    private async Task OnBasicUnitChangedAsync()
    {
        _unitDetails = [];
        _selectedUnitDetail = null;

        if (_selectedBasicUnit is not null)
        {                                          
            _unitDetails = await ItemDetailService.GetItemDetailByCategoryIdAsync(_selectedBasicUnit.Id);
            if (_unitDetails != null) _selectedUnitDetail = _unitDetails.FirstOrDefault();
        }

        StateHasChanged();
    }

    private Task OnCashRegisterChangedAsync() => InvokeAsync(StateHasChanged);

    private async Task Save()
    {
        await _form.Validate();
        if (_form.IsValid && IsProcessable())
        {
            MapFormToModel();

            bool success;
            if (_isEditMode)
                success = await TransactionService.UpdateTransactionAsync(_transactionModel);
            else
                success = await TransactionService.AddTransactionAsync(_transactionModel);

            MudDialog.Close(DialogResult.Ok(success));
        }
    }


    private void MapFormToModel()
    {
        (_transactionModel.CashRegister, _transactionModel.CashRegisterId) =
            SetRequired<CashRegisterModel, CashRegisterModel>(_selectedCashRegisterModel, c => c.Id);
        
        _transactionModel.Allocation = new AllocationModel
        {
            CostCenterId = _selectedCostUnit?.Id ?? 0,
            CostCenter = _selectedCostUnit,
            CategoryId = _selectedBasicUnit?.Id ?? 0,
            Category = _selectedBasicUnit,
            ItemDetailId = _selectedUnitDetail?.Id,
            ItemDetail = _selectedUnitDetail
        };
        
        (_transactionModel.SpecialItem, _transactionModel.SpecialItemId) =
            SetOrClear<SpecialItemModel, SpecialItemModel>(_selectedSpecialItem, s => s.Id);
        
        if (TransactionDateTime.HasValue)
            _transactionModel.Date = DateOnly.FromDateTime(TransactionDateTime.Value);
        else
            throw new InvalidOperationException("Das Transaktionsdatum ist erforderlich.");
    }

    private static (TModel?, int?) SetOrClear<TModel, TSelected>(TSelected? selected, Func<TSelected, int> getId)
        where TModel : class
        where TSelected : class
        => selected is not null ? (selected as TModel, getId(selected)) : (null, null);

    private (TModel, int) SetRequired<TModel, TSelected>(TSelected? selected, Func<TSelected, int> getId)
        where TModel : class
        where TSelected : class
        => selected is null ? throw new InvalidOperationException($"{typeof(TModel).Name} is required.") : 
            (selected as TModel ?? throw new InvalidCastException(), getId(selected));

    private bool IsProcessable()
        => _selectedCostUnit?.Id >= 1
           && _selectedBasicUnit?.Id >= 1
           && _selectedCashRegisterModel?.Id >= 1
           && TransactionDateTime.HasValue;

    private void Cancel() => MudDialog.Close(DialogResult.Cancel());
}
