@using Microsoft.Extensions.Localization
@using ClubTreasury.Data.CashRegister
@using ClubTreasury.Data.Category
@using ClubTreasury.Data.CostCenter
@using ClubTreasury.Data.ItemDetail
@using ClubTreasury.Data.Notification
@using ClubTreasury.Data.OperationResult
@using ClubTreasury.Data.SpecialItem
@using ClubTreasury.Data.Transaction
@using System.Globalization
@inject ITransactionFormService FormService
@inject IStringLocalizer<Translation> Localizer
@inject INotificationService NotificationService
@inject IResultFactory ResultFactory
@inject TransactionValidator TransactionValidator

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" Model="_transactionModel" Validation="TransactionValidator.ValidateValue" ValidationDelay="0" OnEnterPressed="@Save">

            <MudSelect T="CashRegisterModel"
                       Label="@Localizer["CashRegister"]"
                       Required="true"
                       RequiredError="@Localizer["CashRegisterRequired"]"
                       ToStringFunc="@_cashRegisterConverter"
                       Immediate="true"
                       @bind-Value="_selectedCashRegisterModel"
                       @bind-Value:after="OnCashRegisterChangedAsync">
                @foreach (var cash in _cashRegisters)
                {
                    <MudSelectItem T="CashRegisterModel" Value="@cash">@cash.Name</MudSelectItem>
                }
            </MudSelect>

            <MudDatePicker
                @bind-Date="@TransactionDateTime"
                Editable="true"
                Label="@Localizer["Date"]"
                Required="true"
                RequiredError="@Localizer["DateRequired"]" />

            <MudTextField @bind-Value="_transactionModel.Documentnumber"
                          Label="@Localizer["DocumentNumber"]"
                          For="@(() => _transactionModel.Documentnumber)"
                          Immediate="true" />

            <MudTextField @bind-Value="_transactionModel.Description"
                          Label="@Localizer["Description"]"
                          For="@(() => _transactionModel.Description)"
                          Immediate="true" />

            <MudTextField @bind-Value="_transactionModel.Sum"
                          Label="@Localizer["Sum"]"
                          Adornment="Adornment.Start"
                          AdornmentText=@CultureInfo.CurrentCulture.NumberFormat.CurrencySymbol
                          For="@(() => _transactionModel.Sum)"
                          Immediate="true" />

            <MudTextField @bind-Value="_transactionModel.AccountMovement"
                          Label="@Localizer["Account"]"
                          Adornment="Adornment.Start"
                          AdornmentText=@CultureInfo.CurrentCulture.NumberFormat.CurrencySymbol
                          For="@(() => _transactionModel.AccountMovement)"
                          Immediate="true" />

            <MudSelect T="CostCenterModel"
                       Label="@Localizer["CostCenter"]"
                       Required="true"
                       RequiredError="@Localizer["CostCenterRequired"]"
                       ToStringFunc="@_unitConverter"
                       Immediate="true"
                       @bind-Value="_selectedCostUnit"
                       @bind-Value:after="OnCostUnitChangedAsync"
                       Clearable="true">
                @foreach (var unit in _costCenters)
                {
                    <MudSelectItem T="CostCenterModel" Value="@unit">@unit.CostUnitName</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="CategoryModel"
                       Label="@Localizer["Category"]"
                       Disabled="@(_selectedCostUnit == null)"
                       Required="true"
                       RequiredError="@Localizer["CategoryRequired"]"
                       ToStringFunc="@_basicUnitConverter"
                       @bind-Value="_selectedCategory"
                       @bind-Value:after="OnCategoryChangedAsync"
                       Clearable="true">
                @foreach (var basicUnit in _categories)
                {
                    <MudSelectItem T="CategoryModel" Value="@basicUnit">@basicUnit.Name</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="ItemDetailModel"
                       Label="@Localizer["ItemDetail"]"
                       Disabled="@(_selectedCategory == null)"
                       ToStringFunc="@_detailsConverter"
                       @bind-Value="_selectedItemDetail"
                       Clearable="true">
                @foreach (var unitDetail in _unitDetails)
                {
                    <MudSelectItem T="ItemDetailModel" Value="@unitDetail">@unitDetail.CostDetails</MudSelectItem>
                }
            </MudSelect>
            <MudSelect T="SpecialItemModel"
                       Label="@Localizer["SpecialPositions"]"
                       ToStringFunc="@_specialItemConverter"
                       Placeholder="@Localizer["SpecialPositionIfRequired"]"
                       @bind-Value="_selectedSpecialItem"
                       Clearable="true">
                @foreach (var specialItem in _specialItemList)
                {
                    <MudSelectItem T="SpecialItemModel" Value="@specialItem">@specialItem.Name</MudSelectItem>
                }
            </MudSelect>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" OnClick="@(async () => await Save())">
            @(_isEditMode ? Localizer["Save"] : Localizer["AddEntry"])
        </MudButton>
        <MudButton Color="Color.Secondary" OnClick="@Cancel">@Localizer["Cancel"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int? TransactionId { get; set; }

    private MudForm _form = new();
    private TransactionModel _transactionModel = new();
    private bool _isEditMode;

    private DateTime? TransactionDateTime { get; set; } = DateTime.Now;

    private IEnumerable<CostCenterModel> _costCenters = [];
    private IEnumerable<CategoryModel> _categories = [];
    private IEnumerable<ItemDetailModel> _unitDetails = [];
    private IEnumerable<CashRegisterModel> _cashRegisters = [];
    private IEnumerable<SpecialItemModel> _specialItemList = [];

    private CostCenterModel? _selectedCostUnit;
    private CategoryModel? _selectedCategory;
    private ItemDetailModel? _selectedItemDetail;
    private CashRegisterModel? _selectedCashRegisterModel;
    private SpecialItemModel? _selectedSpecialItem;

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    private readonly Func<CashRegisterModel?, string?> _cashRegisterConverter = p => p?.Name;
    private readonly Func<CostCenterModel?, string?> _unitConverter = p => p?.CostUnitName;
    private readonly Func<ItemDetailModel?, string?> _detailsConverter = d => d?.CostDetails;
    private readonly Func<SpecialItemModel?, string?> _specialItemConverter = s => s?.Name;
    private readonly Func<CategoryModel?, string?> _basicUnitConverter = b => b?.Name;

    protected override async Task OnInitializedAsync()
    {
        _isEditMode = TransactionId.HasValue;
        await MudDialog.SetTitleAsync(_isEditMode ? Localizer["Edit"] : Localizer["AddEntry"]);

        var referenceData = await FormService.LoadReferenceDataAsync();
        _cashRegisters = referenceData.CashRegisters;
        _costCenters = referenceData.CostCenters;
        _specialItemList = referenceData.SpecialItems;

        await LoadTransactionAsync();
    }

    private async Task LoadTransactionAsync()
    {
        if (!_isEditMode)
        {
            _transactionModel = new TransactionModel();
            return;
        }

        _transactionModel = await FormService.LoadTransactionAsync(TransactionId!.Value) ?? new TransactionModel();
        RestoreSelections();
        await ReloadDependentDropdownsAsync();
    }

    private void RestoreSelections()
    {
        _selectedCashRegisterModel = _transactionModel.CashRegister;
        _selectedCostUnit = _transactionModel.Allocation.CostCenter;
        _selectedCategory = _transactionModel.Allocation.Category;
        _selectedItemDetail = _transactionModel.Allocation.ItemDetail;
        _selectedSpecialItem = _transactionModel.SpecialItem;
        TransactionDateTime = _transactionModel.Date?.ToDateTime(TimeOnly.MinValue);
    }

    private async Task ReloadDependentDropdownsAsync()
    {
        if (_selectedCostUnit is null)
            return;

        _categories = await FormService.GetCategoriesForCostCenterAsync(_selectedCostUnit.Id);

        if (_selectedCategory is not null && _categories.All(b => b.Id != _selectedCategory.Id))
            _selectedCategory = _categories.FirstOrDefault();

        if (_selectedCategory is null)
            return;

        _unitDetails = await FormService.GetItemDetailsForCategoryAsync(_selectedCategory.Id);

        if (_selectedItemDetail is not null && _unitDetails.All(u => u.Id != _selectedItemDetail.Id))
            _selectedItemDetail = _unitDetails.FirstOrDefault();
    }

    private async Task OnCostUnitChangedAsync()
    {
        _categories = [];
        _selectedCategory = null;
        _unitDetails = [];
        _selectedItemDetail = null;

        if (_selectedCostUnit is not null)
        {
            _categories = await FormService.GetCategoriesForCostCenterAsync(_selectedCostUnit.Id);
            _selectedCategory = _categories.FirstOrDefault();
            await OnCategoryChangedAsync();
        }

       StateHasChanged();
    }

    private async Task OnCategoryChangedAsync()
    {
        _unitDetails = [];
        _selectedItemDetail = null;

        if (_selectedCategory is not null)
        {
            _unitDetails = await FormService.GetItemDetailsForCategoryAsync(_selectedCategory.Id);
            _selectedItemDetail = _unitDetails.FirstOrDefault();
        }

        StateHasChanged();
    }

    private async Task OnCashRegisterChangedAsync()
    {
        _transactionModel.Documentnumber = _selectedCashRegisterModel != null
            ? await FormService.GetNextDocumentNumberAsync(_selectedCashRegisterModel.Id)
            : 0;
        StateHasChanged();
    }

    private async Task Save()
    {
        await _form.Validate();
        if (!_form.IsValid || !IsProcessable())
            return;

        var selections = new TransactionFormSelections(
            _selectedCashRegisterModel!,
            _selectedCostUnit!,
            _selectedCategory!,
            _selectedItemDetail,
            _selectedSpecialItem,
            TransactionDateTime!.Value);

        var result = await FormService.SaveTransactionAsync(_transactionModel, selections, _isEditMode);

        if (result.IsSuccess)
            MudDialog.Close(DialogResult.Ok(result));
        else
            await NotificationService.ShowResultAsync(result);
    }

    private bool IsProcessable()
        => _selectedCostUnit?.Id >= 1
           && _selectedCategory?.Id >= 1
           && _selectedCashRegisterModel?.Id >= 1
           && TransactionDateTime.HasValue;

    private void Cancel() => MudDialog.Close(DialogResult.Ok(ResultFactory.Canceled()));

}
