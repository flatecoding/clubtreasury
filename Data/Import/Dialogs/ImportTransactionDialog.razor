@page "/import-transaction-dialog"
@using MudExtensions
@inject ImportBookingJournalService ImportBookingJournalService

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.subtitle1">Select a file to import data from booking journal. Table name must be "Buchungen"</MudText>
        <MudForm>
            <MudFileUpload T="IBrowserFile" 
                           FilesChanged="UploadFiles"
                           Accept="*.xlsx/*.ods">
                <ActivatorContent>
                    <MudButton Class="mb-2"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               >
                        Select file
                    </MudButton>
                </ActivatorContent>
            </MudFileUpload>
            <MudTextField Disabled="true" @bind-Value="_fileName" Label="Filename" Placeholder="Filename" Required="true"/>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudLoadingButton 
            @bind-Loading="_isImporting" 
            Size="Size.Small" 
            LoadingAdornment="Adornment" 
            OnClick="ImportData" 
            Variant="Variant.Filled" 
            Color="Color.Primary"
            >Import
        </MudLoadingButton>
        <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="Cancel">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    private string? _fileName;
    private const Adornment Adornment = MudBlazor.Adornment.Start;

    private IBrowserFile? _file;
    private Task UploadFiles(IBrowserFile file)
    {
        _file = file;
        _fileName = file.Name;
        return Task.CompletedTask;
    }

    private bool _isImporting;

    private async Task ImportData()
    {
        if (_file is null)
            return;
        
            _isImporting = true;
            try
            {
                await using var stream = _file.OpenReadStream();
                var result = await ImportBookingJournalService.ImportTransactions(stream);
                MudDialog.Close(DialogResult.Ok(result));
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Fehler beim Importieren der Datei '{_fileName}': {ex.Message}");
                MudDialog.Close(DialogResult.Ok(false));
            }
            finally
            {
                _isImporting = false;
            }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}