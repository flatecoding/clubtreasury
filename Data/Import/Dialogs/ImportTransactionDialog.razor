@page "/import-transaction-dialog"
@using MudExtensions
@inject IImportBookingJournalService ImportBookingJournalService

<MudDialog>
    <DialogContent>
        <MudTextM3 Class="mb-2" Typo="TypoM3.Title" Size="Size.Large">Select a file to import data from booking journal. </MudTextM3>
        <MudTextM3 Class="mb-2" Typo="TypoM3.Title" Size="Size.Medium"><strong>Required format</strong></MudTextM3> 
        <MudTextM3 Class="mb-2" Typo="TypoM3.Body" Size="Size.Medium"><strong>Name of sheet:</strong> "Buchungen"</MudTextM3>
        <MudTextM3 Class="mb-2" Typo="TypoM3.Body" Size="Size.Medium"><strong>Row definition:</strong></MudTextM3>
        <MudTextM3 Class="mb-2" Typo="TypoM3.Body" Size="Size.Medium">
            Date; Document number; Description; Income; Outcome; Account movement; Costunit/Basicposition
        </MudTextM3>
        <MudTextM3 Class="mb-2" Typo="TypoM3.Body" Size="Size.Medium"><strong>File format:</strong> *.xlsx</MudTextM3>
       <MudTextM3 Class="mb-2" Typo="TypoM3.Title" Size="Size.Medium"><strong>Example</strong></MudTextM3>
        <MudImage Class="mb-2"
            Src="images/ExampleBookingJournalImport.png"
                          Alt="Example">
                </MudImage>
        <MudForm>
            <MudFileUpload T="IBrowserFile" 
                           FilesChanged="UploadFiles"
                           Accept="*.xlsx/*.ods">
                <ActivatorContent>
                    <MudButton Class="mb-2"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               >
                        Select file
                    </MudButton>
                </ActivatorContent>
            </MudFileUpload>
            <MudTextField Disabled="true" @bind-Value="_fileName" Label="Filename" Placeholder="Filename" Required="true"/>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudLoadingButton 
            @bind-Loading="_isImporting" 
            Size="Size.Small" 
            LoadingAdornment="Adornment" 
            OnClick="@(() => ImportData())" 
            Variant="Variant.Filled" 
            Color="Color.Primary"
            >Import
        </MudLoadingButton>
        <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="@(() => Cancel())">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    private string? _fileName;
    private const Adornment Adornment = MudBlazor.Adornment.Start;
    private bool _isImporting;
    private IBrowserFile? _file;
    private Task UploadFiles(IBrowserFile? file)
    {
        _file = file;
        _fileName = file?.Name;
        return Task.CompletedTask;
    }

    private async Task ImportData()
    {
        if (_file is null)
            return;
        
            _isImporting = true;
            try
            {
                await using var stream = _file.OpenReadStream();
                var result = await ImportBookingJournalService.ImportTransactions(stream);
                MudDialog.Close(DialogResult.Ok(result));
            }
            catch (Exception ex)
            {
                Console.WriteLine($"An error occured during import of file: '{_fileName}': {ex.Message}");
                MudDialog.Close(DialogResult.Ok(false));
            }
            finally
            {
                _isImporting = false;
            }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}