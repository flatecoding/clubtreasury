@page "/import-cost-center-dialog"
@using Microsoft.Extensions.Localization
@using MudExtensions
@using ClubTreasury.Data.OperationResult
@inject IImportCostCenterService ImportCostCenterService
@inject IStringLocalizer<Translation> Localizer
@inject ILogger<ImportCostCenterDialog> Logger
@inject IResultFactory ResultFactory

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.subtitle1">@Localizer["ImportQuestion"]</MudText>
        <MudForm>
            <MudFileUpload T="IBrowserFile"
                           FilesChanged="UploadFiles"
                           Accept=".txt"
                           DragAndDrop="true" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudLoadingButton
            LoadingAdornment="Adornment"
            OnClick="@ImportData"
            Color="Color.Primary">
            @Localizer["Import"]
        </MudLoadingButton>
        <MudButton Variant="Variant.Text" Color="Color.Secondary" OnClick="@Cancel">@Localizer["Close"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    private bool _isImporting;
    private const Adornment Adornment = MudBlazor.Adornment.Start;
    private IBrowserFile? _file;

    private void UploadFiles(IBrowserFile? file)
    {
        _file = file;
    }

    private async Task ImportData()
    {
        if (_isImporting)
            return;

        try
        {
            _isImporting = true;
            if (_file is null)
                return;

            if (!string.Equals(_file.ContentType, "text/plain", StringComparison.OrdinalIgnoreCase)
                && !_file.Name.EndsWith(".txt", StringComparison.OrdinalIgnoreCase))
            {
                MudDialog.Close(DialogResult.Ok(ResultFactory.ImportFailed(Localizer["InvalidFileFormat"])));
                return;
            }

            await using var stream = _file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            var result = await ImportCostCenterService.ImportCostCentersAndPositionsAsync(stream, _file.Name);
            MudDialog.Close(DialogResult.Ok(result));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "An error occured during import of file: '{FileName}':", _file?.Name);
            MudDialog.Close(DialogResult.Ok(ResultFactory.ImportFailed(Localizer["Exception"])));
        }
        finally
        {
            _isImporting = false;
        }
    }

    private void Cancel() => MudDialog.Close(DialogResult.Ok(ResultFactory.Canceled()));
}
