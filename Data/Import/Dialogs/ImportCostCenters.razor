@page "/import-cost-center-dialog"
@using Microsoft.Extensions.Localization
@using MudExtensions
@using Serilog
@inject IImportCostCenterService ImportCostCenterService
@inject IStringLocalizer<Translation> Localizer
@inject ILogger<ImportCostCenters> Logger

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.subtitle1">@Localizer["ImportQuestion"]</MudText>
        <MudForm>
            <MudFileUpload T="IBrowserFile" 
                           FilesChanged="UploadFiles"
                           Accept=".txt">
                <ActivatorContent>
                    <MudButton Class="mb-2"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               >
                        @Localizer["SelectFile"]
                    </MudButton>
                </ActivatorContent>
            </MudFileUpload>
            <MudTextField Disabled="true" @bind-Value="_fileName" Label=@Localizer["FileName"] Placeholder="@Localizer["FileName"]" Required="true"/>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudLoadingButton
            @bind-Loading="_isImporting"
            Size="Size.Small"
            LoadingAdornment="Adornment"
            OnClick="@(() => ImportData())"
            Variant="Variant.Filled"
            Color="Color.Primary">
            @Localizer["Import"]
        </MudLoadingButton>
        <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="@(() => Cancel())">@Localizer["Close"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    private string? _fileName = string.Empty;
    private bool _isImporting;
    private const Adornment Adornment = MudBlazor.Adornment.Start;

    private IBrowserFile? _file;
    private Task UploadFiles(IBrowserFile? file)
    {
        _file = file;
        _fileName = file?.Name;
        return Task.CompletedTask;
    }

    private async Task ImportData()
    {
        if (!_isImporting)
        {
            try
            {
                await using var stream = _file?.OpenReadStream();
                var result = stream != null && await ImportCostCenterService.ImportCostCentersAndPositions(stream);
                MudDialog.Close(DialogResult.Ok(result));
            }
            catch (Exception ex)
            {
                Logger.LogCritical(ex, "An error occured during import of file: '{_fileName}':", _fileName);
                MudDialog.Close(DialogResult.Ok(false));
            }
            finally
            {
                _isImporting = false;
            }
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}