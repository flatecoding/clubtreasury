@page "/addcashregister"
@using TTCCashRegister.Data.CashRegister
@inject CashRegisterService CashRegisterService

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" Model="_newCashRegisterModel" Validation="_cashRegisterValidator.ValidateValue" ValidationDelay="0">
            <MudTextField @bind-Value="_newCashRegisterModel.Name" Label="Name"
                          For="@(() => _newCashRegisterModel.Name)" Immediate="true"/>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(async () => await AddEntry())">Add</MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private MudForm _form = new();
    private readonly CashRegisterModel _newCashRegisterModel = new();
    private readonly CashRegisterValidator _cashRegisterValidator = new();

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    private async Task AddEntry()
    {
        await _form.Validate();
        if (_form.IsValid)
        {
            await CashRegisterService.AddCashRegister(_newCashRegisterModel);
            MudDialog.Close(DialogResult.Ok(true));
        }
    }

    private void Cancel()
    {
        MudDialog.Close(DialogResult.Cancel());
    }
}
