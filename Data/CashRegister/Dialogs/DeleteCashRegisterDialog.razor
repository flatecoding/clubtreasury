@page "/deletecashregister"
@using Microsoft.Extensions.Localization
@inject ICashRegisterService CashRegisterService
@inject IStringLocalizer<Translation> Localizer

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h6">@Localizer["DeleteQuestion"]</MudText>
        <MudText Typo="Typo.subtitle1">@_cashRegisterName</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" OnClick="@(() => DeleteEntry())">@Localizer["Delete"]</MudButton>
        <MudButton Color="Color.Error" OnClick="@(() => Cancel())">@Localizer["Cancel"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int CashRegisterId { get; set; }
    private string _cashRegisterName = string.Empty;

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        var cashRegister = await CashRegisterService.GetCashRegisterById(CashRegisterId);
        if (cashRegister != null)
        {
            _cashRegisterName = cashRegister.Name;
        }
    }

    private async Task DeleteEntry()
    {
        var success = await CashRegisterService.DeleteCashRegister(CashRegisterId);
        MudDialog.Close(success ? DialogResult.Ok(true) : DialogResult.Ok(false));
    }

    private void Cancel()
    {
        MudDialog.Close(DialogResult.Cancel());
    }
}
