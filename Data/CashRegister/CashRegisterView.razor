@page "/cashregisters"
@using System.Globalization
@using Microsoft.Extensions.Localization
@using TTCCashRegister.Data.DialogService
@using TTCCashRegister.Data.Notification
@using TTCCashRegister.Data.OperationResult
@inject ICashRegisterService CashRegisterService
@inject IDialogService DialogService
@inject INotificationService NotificationService
@inject IStringLocalizer<Translation> Localizer

<MudGrid Spacing="0">
    <MudItem xs="12">
        <MudText Typo="Typo.h6">
            Cash registers
        </MudText>
    </MudItem>

    <MudItem xs="12" md="10" lg="4">
        <MudPaper Elevation="0">
            <MudTable Items="@_allEntries"
                      Dense="@Dense"
                      Hover="@Hover"
                      Bordered="@Bordered"
                      Striped="@Striped"
                      FixedHeader="true"
                      @bind-SelectedItem="_selectedItem"
                      Filter="new Func<CashRegisterModel,bool>(FilterFunc)"
                      SortLabel="Sort By">
                <ToolBarContent>
                    <MudIconButton Variant="Variant.Filled"
                               Icon="@Icons.Material.Filled.Add"
                               Color="Color.Primary"
                               OnClick="@ShowAddCashRegisterDialog">
                    </MudIconButton>
                    <MudSpacer />
                    <MudTextField @bind-Value="_searchString1"
                                  Placeholder="Search"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  IconSize="Size.Medium"
                                  Class="mt-0" />
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>
                        <MudTableSortLabel
                            SortBy="new Func<CashRegisterModel, object>(x => x.Id)">
                            @Localizer["Id"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel
                            SortBy="new Func<CashRegisterModel, object>(x => x.Name)">
                            @Localizer["Name"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>@Localizer["CurrentBalance"]</MudTh>
                    <MudTh>@Localizer["Actions"]</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="@Localizer["Id"].Value">
                        @context.Id
                    </MudTd>
                    <MudTd DataLabel="@Localizer["Name"].Value">
                        @context.Name
                    </MudTd>
                    <MudTd DataLabel="@Localizer["CurrentBalance"].Value">
                        @context.CurrentBalance.ToString("C", CultureInfo.CurrentCulture)
                    </MudTd>
                    <MudTd DataLabel="Actions">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Info"
                                       aria-label="@Localizer["Edit"].Value"
                                       OnClick="@(() => ShowEditCashRegisterDialog(context.Id))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       aria-label="@Localizer["Delete"].Value"
                                       OnClick="@(() => ShowDeleteCashRegisterDialog(context))" />
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private IEnumerable<CashRegisterModel>? _allEntries;
    private const bool Dense = true;
    private const bool Hover = true;
    private const bool Striped = true;
    private const bool Bordered = false;
    private string _searchString1 = string.Empty;
    private CashRegisterModel _selectedItem = new();
    
    private readonly DialogOptions _dialogOptions = new()
    {
        MaxWidth = MaxWidth.Medium,
        FullWidth = true,
        BackdropClick = false,
        CloseButton = true
    };

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        _allEntries = await CashRegisterService.GetAllCashRegisters();
    }

    private bool FilterFunc(CashRegisterModel? element) => FilterFunc1(element, _searchString1);

    private bool FilterFunc1(CashRegisterModel? element, string searchstring)
    {
        if (string.IsNullOrWhiteSpace(searchstring))
            return true;
        if (element is null)
            return false;
        if (!string.IsNullOrWhiteSpace(searchstring))
        {
            if (element.Name.ToLower().Contains(searchstring.ToLowerInvariant()))
                return true;
        }
        return false;
    }

    private async Task ShowAddCashRegisterDialog()
    {
       var result = await DialogService.ShowDialogWithNotificationAsync<CashRegisterDialog>(
            NotificationService);
    
        if (result?.Status == OperationResultStatus.Success)
        {
            await UpdateView();
        }
    }
    
    private async Task ShowEditCashRegisterDialog(int cashRegisterId)
    {
        var parameters = new DialogParameters { ["CashRegisterId"] = cashRegisterId };
    
        var result = await DialogService.ShowDialogWithNotificationAsync<CashRegisterDialog>(
            NotificationService,
            $"{Localizer["Edit"]} ",
            parameters);
    
        if (result?.Status == OperationResultStatus.Success)
        {
            await UpdateView();
        }
    }
    
    private async Task UpdateView()
    {
        _allEntries = await CashRegisterService.GetAllCashRegisters();
        await InvokeAsync(StateHasChanged);
    }
    
    private async Task ShowDeleteCashRegisterDialog(CashRegisterModel cashRegister)
    {
        await DialogService.ShowConfirmDeleteDialogAsync(
            NotificationService,
            entityName: Localizer["CashRegister"].Value,
            itemName: $"{cashRegister.Name}",
            onConfirm: () => CashRegisterService.DeleteCashRegisterAsync(cashRegister.Id),
            onSuccess: UpdateView,
            deleteTitle: Localizer["Delete"]);
    }
}
