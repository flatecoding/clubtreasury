@page "/cashregisters"
@using System.Globalization
@using ClubTreasury.Components.View
@using ClubTreasury.Data.OperationResult

@inherits CrudViewBase<CashRegisterModel, CashRegisterDialog>

@inject ICashRegisterService CashRegisterService

<MudGrid Spacing="0">
    <MudItem xs="12">
        <MudText Typo="Typo.h6">
            @Localizer["CashRegister"]
        </MudText>
    </MudItem>
    <MudItem xs="12" md="10" lg="4">
        <MudPaper Elevation="0">
            <MudTable Items="@AllEntries"
                      Dense="true"
                      Hover="true"
                      Bordered="false"
                      Striped="true"
                      FixedHeader="true"
                      @bind-SelectedItem="SelectedItem"
                      Filter="new Func<CashRegisterModel,bool>(FilterFunc)"
                      SortLabel="Sort By">
                <ToolBarContent>
                    <MudIconButton Variant="Variant.Filled"
                               Icon="@Icons.Material.Filled.Add"
                               Color="Color.Primary"
                               OnClick="@ShowAddDialog">
                    </MudIconButton>
                    <MudSpacer />
                    <MudTextField @bind-Value="SearchTerm"
                                  Placeholder="Search"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  IconSize="Size.Medium"
                                  Class="mt-0" />
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>
                        <MudTableSortLabel
                            SortBy="new Func<CashRegisterModel, object>(x => x.Id)">
                            @Localizer["Id"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel
                            SortBy="new Func<CashRegisterModel, object>(x => x.Name)">
                            @Localizer["Name"]
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>@Localizer["CurrentBalance"]</MudTh>
                    <MudTh>@Localizer["Actions"]</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="@Localizer["Id"].Value">
                        @context.Id
                    </MudTd>
                    <MudTd DataLabel="@Localizer["Name"].Value">
                        @context.Name
                    </MudTd>
                    <MudTd DataLabel="@Localizer["CurrentBalance"].Value">
                        @context.CurrentBalance.ToString("C", CultureInfo.CurrentCulture)
                    </MudTd>
                    <MudTd DataLabel="Actions">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Info"
                                       aria-label="@Localizer["Edit"].Value"
                                       OnClick="@(() => ShowEditDialog(context.Id))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       aria-label="@Localizer["Delete"].Value"
                                       OnClick="@(() => ShowDeleteDialog(context))" />
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    protected override string EntityIdParameterName => "CashRegisterId";
    protected override string EntityLocalizedName => Localizer["CashRegister"];
    protected override int GetEntityId(CashRegisterModel entity) => entity.Id;
    protected override string GetEntityDisplayName(CashRegisterModel entity) => entity.Name;
    protected override Task<List<CashRegisterModel>> LoadAllAsync() => CashRegisterService.GetAllCashRegisters();
    protected override Task<Result> DeleteEntityAsync(int id) => CashRegisterService.DeleteCashRegisterAsync(id);
    protected override DialogOptions? CustomDialogOptions => new() { MaxWidth = MaxWidth.Small };

    protected override bool MatchesFilter(CashRegisterModel? element, string searchTerm)
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
            return true;
        if (element is null)
            return false;
        return element.Name.ToLower().Contains(searchTerm.ToLowerInvariant());
    }
}
