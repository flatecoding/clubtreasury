@page "/cashregisterdialog"
@using System.Globalization
@using Microsoft.Extensions.Localization
@using ClubTreasury.Data.Notification
@using ClubTreasury.Data.OperationResult
@inject ICashRegisterService CashRegisterService
@inject IStringLocalizer<Translation> Localizer
@inject INotificationService NotificationService
@inject IOperationResultFactory OperationResultFactory
@inject CashRegisterValidator CashRegisterValidator

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" Model="_cashRegisterModel" Validation="CashRegisterValidator.ValidateValue" ValidationDelay="0">
            <MudTextField @bind-Value="_cashRegisterModel.Name" Label="@Localizer["Name"]"
                          For="@(() => _cashRegisterModel.Name)" Immediate="true"/>
            <MudSelect T="int" @bind-Value="_cashRegisterModel.FiscalYearStartMonth"
                       Label="@Localizer["FiscalYearStartMonth"]"
                       For="@(() => _cashRegisterModel.FiscalYearStartMonth)">
                @for (var i = 1; i <= 12; i++)
                {
                    var month = i;
                    <MudSelectItem T="int" Value="@month">
                        @DateTimeFormatInfo.CurrentInfo.GetMonthName(month)
                    </MudSelectItem>
                }
            </MudSelect>
        </MudForm>

        <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2">@Localizer["Logo"]</MudText>

        @if (_existingLogoDataUri is not null && _pendingFile is null)
        {
            <div style="position: relative; display: inline-block" class="mb-2">
                <MudImage Src="@_existingLogoDataUri" Alt="Logo" Width="60"/>
                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                               Color="Color.Error"
                               Size="Size.Medium"
                               OnClick="@RemoveLogo"
                               Style="position: absolute; bottom: -8px; right: -24px"/>
            </div>
        }

        <MudFileUpload T="IBrowserFile"
                       FilesChanged="OnFileSelected"
                       Accept=".png,.jpg,.jpeg,.svg">
            <CustomContent Context="fileUpload">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@fileUpload.OpenFilePickerAsync">
                    @Localizer["SelectFile"]
                </MudButton>
            </CustomContent>
        </MudFileUpload>

        @if (_pendingFile is not null)
        {
            <MudText Typo="Typo.body2" Class="mt-1">@_pendingFile.Name</MudText>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" OnClick="@(async () => await Save())">
            @(_isEditMode ? Localizer["Save"] : Localizer["AddEntry"])
        </MudButton>
        <MudButton Color="Color.Secondary" OnClick="@Cancel">@Localizer["Cancel"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int? CashRegisterId { get; set; }
    private MudForm _form = new();
    private CashRegisterModel _cashRegisterModel = new();
    private bool _isEditMode;
    private string? _existingLogoDataUri;
    private IBrowserFile? _pendingFile;
    private bool _logoRemoved;

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        _isEditMode = CashRegisterId.HasValue;
        await MudDialog.SetTitleAsync(_isEditMode ? Localizer["Edit"] : Localizer["AddEntry"]);
        await LoadCashRegisterAsync();
    }

    private async Task LoadCashRegisterAsync()
    {
        if (!_isEditMode)
        {
            _cashRegisterModel = new CashRegisterModel();
            return;
        }

        _cashRegisterModel = await CashRegisterService.GetCashRegisterById(CashRegisterId!.Value) ?? new CashRegisterModel();
        await LoadExistingLogoAsync(CashRegisterId.Value);
    }

    private async Task LoadExistingLogoAsync(int cashRegisterId)
    {
        var logo = await CashRegisterService.GetLogoAsync(cashRegisterId);
        if (logo is not null)
            _existingLogoDataUri = $"data:{logo.Value.ContentType};base64,{Convert.ToBase64String(logo.Value.Data)}";
    }

    private void OnFileSelected(IBrowserFile? file) => _pendingFile = file;

    private void RemoveLogo()
    {
        _existingLogoDataUri = null;
        _logoRemoved = true;
    }

    private async Task Save()
    {
        await _form.Validate();
        if (!_form.IsValid)
            return;

        var result = _isEditMode
            ? await CashRegisterService.UpdateCashRegister(_cashRegisterModel)
            : await CashRegisterService.AddCashRegister(_cashRegisterModel);

        if (result.Status is not OperationResultStatus.Success)
        {
            await NotificationService.ShowOperationResultAsync(result);
            return;
        }

        var cashRegisterId = _isEditMode ? _cashRegisterModel.Id : (int)(result.Data ?? 0);
        await HandleLogoAsync(cashRegisterId);
        MudDialog.Close(DialogResult.Ok(result));
    }

    private async Task HandleLogoAsync(int cashRegisterId)
    {
        if (_pendingFile is not null)
        {
            await using var stream = _pendingFile.OpenReadStream(maxAllowedSize: 512 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            await CashRegisterService.UploadLogoAsync(cashRegisterId, ms.ToArray(), _pendingFile.ContentType);
        }
        else if (_logoRemoved)
        {
            await CashRegisterService.DeleteLogoAsync(cashRegisterId);
        }
    }

    private void Cancel() => MudDialog.Close(DialogResult.Ok(OperationResultFactory.Canceled()));
}
