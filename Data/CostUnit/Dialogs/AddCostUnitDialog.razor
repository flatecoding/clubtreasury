@page "/addcostunit"
@using TTCCashRegister.Data.CostUnit
@inject CostUnitService CostUnitService

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" Model="_newCostUnitModel" Validation="_costunitvalidator.ValidateValue" ValidationDelay="0">
            <MudTextField @bind-Value="_newCostUnitModel.CostUnitName" Label="Unit Name"
                          For="@(() => _newCostUnitModel.CostUnitName)" Immediate="true" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(async () => await AddCostUnit())">Add</MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private MudForm _form = new();
    private readonly CostUnitValidator _costunitvalidator = new(); 
    private readonly CostUnitModel _newCostUnitModel = new();
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    
    private async Task AddCostUnit()
    {
        await _form.Validate();
        if (_form.IsValid)
        {
            await CostUnitService.AddCostUnitAsync(_newCostUnitModel);
            MudDialog.Close(DialogResult.Ok(true));
        }
    }

    private void Cancel()
    {
        MudDialog.Close(DialogResult.Cancel());
    }
}
