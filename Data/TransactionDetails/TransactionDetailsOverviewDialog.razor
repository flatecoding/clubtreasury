@using System.Globalization
@using Microsoft.Extensions.Localization
@using TTCCashRegister.Data.DialogService
@using TTCCashRegister.Data.Notification
@using TTCCashRegister.Data.OperationResult
@inject ITransactionDetailsService TransactionDetailsService
@inject IDialogService DialogService
@inject INotificationService NotificationService
@inject IStringLocalizer<Translation> Localizer

<MudDialog>
    <DialogContent>
        @if (_transactionDetails == null)
        {
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
        }
        else if (!_transactionDetails.Any())
        {
            <em>@Localizer["NoData"]</em>
        }
        else
        {
            <MudTable Items="_transactionDetails" Dense="true" Hover="true" Striped="true" Bordered="true">
                <HeaderContent>
                    <MudTh>@Localizer["DocumentNumberShort"]</MudTh>
                    <MudTh>@Localizer["Description"]</MudTh>
                    <MudTh>@Localizer["Person"]</MudTh>
                    <MudTh>@Localizer["Sum"]</MudTh>
                    <MudTh>@Localizer["Actions"]</MudTh>
                </HeaderContent>
                <RowTemplate Context="row">
                    <MudTd>@row.DocumentNumber</MudTd>
                    <MudTd>@row.Description</MudTd>
                    <MudTd>@row.Person?.Name</MudTd>
                    <MudTd>@row.Sum.ToString("C", CultureInfo.CurrentCulture)</MudTd>
                    <MudTd>
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Info"
                                       OnClick="@(async () => await ShowEditTransactionDetailDialog(row.Id))"/>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       OnClick="@(async () => await ShowDeleteTransactionDetailsDialog(row))"/>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary"
                   OnClick="@(async () => await ShowAddTransactionDetailsDialog())">
            @Localizer["AddEntry"]
        </MudButton>
        <MudButton Color="Color.Secondary" OnClick="@Close">@Localizer["Close"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int TransactionId { get; set; }
    [Parameter] public int ParentDocumentNumber { get; set; }

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    private List<TransactionDetailsModel>? _transactionDetails;

    protected override async Task OnInitializedAsync()
    {
        await MudDialog.SetTitleAsync($"{Localizer["TransactionDetailsFor"]}: {ParentDocumentNumber}");
        await LoadTransactionDetails();
    }

    private async Task LoadTransactionDetails()
    {
        _transactionDetails = await TransactionDetailsService.GetTransactionDetailsByTransactionIdAsync(TransactionId);
        StateHasChanged();
    }

    private async Task ShowAddTransactionDetailsDialog()
    {
        var parameters = new DialogParameters
        {
            ["TransactionId"] = TransactionId,
            ["TransactionDetailsId"] = null
        };

        var result = await DialogService.ShowDialogWithNotificationAsync<TransactionDetailsDialog>(NotificationService,
            Localizer["AddEntry"], parameters);

        if (result?.Status is OperationResultStatus.Success)
            await LoadTransactionDetails();
    }

    private async Task ShowEditTransactionDetailDialog(int transactionDetailsId)
    {
        var parameters = new DialogParameters
        {
            ["TransactionId"] = TransactionId,
            ["TransactionDetailsId"] = transactionDetailsId
        };

        var result = await DialogService.ShowDialogWithNotificationAsync<TransactionDetailsDialog>(NotificationService,
            Localizer["Edit"], parameters);

        if (result?.Status is OperationResultStatus.Success)
            await LoadTransactionDetails();
    }

    private async Task ShowDeleteTransactionDetailsDialog(TransactionDetailsModel details)
    {
        await DialogService.ShowConfirmDeleteDialogAsync(
            NotificationService,
            entityName: Localizer["TransactionDetailsFor"].Value,
            itemName: details.Description ?? string.Empty,
            onConfirm: () => TransactionDetailsService.DeleteTransactionDetailsAsync(details.Id),
            onSuccess: LoadTransactionDetails,
            deleteTitle: Localizer["Delete"]);
    }

    private void Close() => MudDialog.Close();
}
