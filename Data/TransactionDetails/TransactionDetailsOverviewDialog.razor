@using System.Globalization
@using TTCCashRegister.Data.Dialog
@using TTCCashRegister.Data.Source
@inject ITransactionDetailsService TransactionDetailsService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject INotificationService NotificationService

<MudDialog>
    <DialogContent>
        @if (_transactionDetails == null)
        {
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
        }
        else if (!_transactionDetails.Any())
        {
            <em>No transaction details found.</em>
        }
        else
        {
            <MudTable Items="_transactionDetails" Dense="true" Hover="true" Striped="true" Bordered="true">
                <HeaderContent>
                    <MudTh>Doc. Nr.</MudTh>
                    <MudTh>Description</MudTh>
                    <MudTh>Person</MudTh>
                    <MudTh>Sum</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate Context="row">
                    <MudTd>@row.DocumentNumber</MudTd>
                    <MudTd>@row.Description</MudTd>
                    <MudTd>@row.Person?.Name</MudTd>
                    <MudTd>@row.Sum.ToString("C", CultureInfo.CurrentCulture)</MudTd>
                    <MudTd>
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Info"
                                       OnClick="@(() => ShowEditTransactionDetailDialog(row.Id))"/>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       OnClick="@(() => ShowDeleteTransactionDetailsDialog(row.Id))"/>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="@(() => ShowAddTransactionDetailsDialog())">
            Add transaction details
        </MudButton>
        <MudButton Color="Color.Default" OnClick="@(() => Close())">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int TransactionId { get; set; }
    [Parameter] public int ParentDocumentNumber { get; set; }
    private List<TransactionDetailsModel>? _transactionDetails;

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        await LoadTransactionDetails();
        await MudDialog.SetTitleAsync($"Transaction details for document: {ParentDocumentNumber}");
        StateHasChanged();
    }

    private async Task LoadTransactionDetails()
    {
        _transactionDetails = await TransactionDetailsService.GetTransactionDetailsByTransactionIdAsync(TransactionId);
    }

    
    private async Task ShowAddTransactionDetailsDialog()
    {
        var parameters = new DialogParameters
        {
            ["TransactionId"] = TransactionId,
            ["TransactionDetailsId"] = null
        };

        var dialog = await DialogService.ShowAsync<TransactionDetailsDialog>(null, parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            Snackbar.Add("Transaction detail was added successfully", Severity.Success);
            await LoadTransactionDetails();
        }
    }
    
    private async Task ShowEditTransactionDetailDialog(int transactionDetailsId)
    {
        var parameters = new DialogParameters
        {
            ["TransactionId"] = TransactionId,
            ["TransactionDetailsId"] = transactionDetailsId
        };

        var dialog = await DialogService.ShowAsync<TransactionDetailsDialog>(null, parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            Snackbar.Add("Subtransaction was updated successfully", Severity.Success);
            await LoadTransactionDetails();
        }
    }

    private async Task ShowDeleteTransactionDetailsDialog(int transactionDetailsId)
    {
        var transaction = await TransactionDetailsService.GetTransactionDetailsByIdAsync(transactionDetailsId);
        if (transaction == null) return;

        var dialog = await DialogService.ShowAsync<ConfirmDeleteDialog>(
            string.Empty,
            new DialogParameters
            {
                ["EntityName"] = "Transaction details",
                ["ItemName"] = $"{transaction.DocumentNumber} {transaction.Description}",
                ["OnConfirm"] = EventCallback.Factory.Create(this, async () =>
                {
                    await TransactionDetailsService.DeleteAsync(transactionDetailsId);
                })
            });

        await NotificationService.ShowDialogResultAsync(await dialog.Result);
        StateHasChanged();
    }

    private void Close() => MudDialog.Close();
}
