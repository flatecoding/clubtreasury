@page "/transactiondetailsdialog"
@using TTCCashRegister.Data.Person
@inject ITransactionDetailsService TransactionDetailsService
@inject IPersonService PersonService

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" Model="_transactionDetailsModel" 
                 Validation="_transactionDetailsValidator.ValidateValue"
                 ValidationDelay="0">
            
            <MudTextField @bind-Value="_transactionDetailsModel.DocumentNumber"
                          Label="Document Number"
                          For="@(() => _transactionDetailsModel.DocumentNumber)"
                          Immediate="true" />
            
            <MudTextField @bind-Value="_transactionDetailsModel.Description"
                          Label="Description"
                          For="@(() => _transactionDetailsModel.Description)"
                          Immediate="true"
                          Required="true"
                          RequiredError="Description is required" />
            
            <MudTextField @bind-Value="_transactionDetailsModel.Sum"
                             Label="Sum"
                             For="@(() => _transactionDetailsModel.Sum)"
                             Immediate="true"
                             Required="true"
                             RequiredError="Amount is required" />
            
            <MudSelect T="int?" Label="Person"
                       @bind-Value="_transactionDetailsModel.PersonId"
                       Clearable="true">
                <MudSelectItem T="int?" Value="@null">None</MudSelectItem>
                @foreach (var p in _persons)
                {
                    <MudSelectItem T="int?" Value="@p.Id">@p.Name</MudSelectItem>
                }
            </MudSelect>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="@(async () => await Save())">
            @(_isEditMode ? "Save" : "Add")
        </MudButton>
        <MudButton Variant="Variant.Text"
                   Color="Color.Default"
                   OnClick="@Cancel">
            Cancel
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int TransactionId { get; set; }
    [Parameter] public int? TransactionDetailsId { get; set; } // null = Add, Wert = Edit

    private MudForm _form = new();
    private TransactionDetailsModel _transactionDetailsModel = new();
    private bool _isEditMode;
    private readonly TransactionDetailsValidator _transactionDetailsValidator = new();

    private IEnumerable<PersonModel> _persons = [];

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        _isEditMode = TransactionDetailsId.HasValue;
        
        _persons = await PersonService.GetAllPersonsAsync();
        string dialogTitle;
        if (_isEditMode)
        {
            if (TransactionDetailsId is not null) 
                _transactionDetailsModel = await TransactionDetailsService
                                               .GetTransactionDetailsByIdAsync(TransactionDetailsId.Value)
                                           ?? new TransactionDetailsModel { TransactionId = TransactionId };
            dialogTitle = "Edit transaction details";
        }
        else
        {
            _transactionDetailsModel = new TransactionDetailsModel
            {
                TransactionId = TransactionId,
                Sum = 0m
            };
            dialogTitle = "Add new transaction details";
        }

        await MudDialog.SetTitleAsync(dialogTitle);
        StateHasChanged();
    }

    private async Task Save()
    {
        await _form.Validate();
        if (_form.IsValid)
        {
            if (_isEditMode)
                await TransactionDetailsService.UpdateTransactionDetailsAsync(_transactionDetailsModel);
            else
                await TransactionDetailsService.AddTransactionDetailsAsync(_transactionDetailsModel);

            MudDialog.Close(DialogResult.Ok(true));
        }
    }

    private void Cancel() => MudDialog.Close(DialogResult.Cancel());
}
