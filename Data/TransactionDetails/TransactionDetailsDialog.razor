@page "/transactiondetailsdialog"
@using Microsoft.Extensions.Localization
@using ClubTreasury.Data.Notification
@using ClubTreasury.Data.OperationResult
@using ClubTreasury.Data.Person
@inject ITransactionDetailsService TransactionDetailsService
@inject IPersonService PersonService
@inject IStringLocalizer<Translation> Localizer
@inject INotificationService NotificationService
@inject IOperationResultFactory OperationResultFactory
@inject TransactionDetailsValidator TransactionDetailsValidator

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" Model="_transactionDetailsModel"
                 Validation="TransactionDetailsValidator.ValidateValue"
                 ValidationDelay="0"
                 OnEnterPressed="@Save">

            <MudTextField @bind-Value="_transactionDetailsModel.DocumentNumber"
                          Label="@Localizer["DocumentNumber"]"
                          For="@(() => _transactionDetailsModel.DocumentNumber)"
                          Immediate="true" />

            <MudTextField @bind-Value="_transactionDetailsModel.Description"
                          Label="@Localizer["Description"]"
                          For="@(() => _transactionDetailsModel.Description)"
                          Immediate="true" />

            <MudTextField @bind-Value="_transactionDetailsModel.Sum"
                          Label="@Localizer["Sum"]"
                          For="@(() => _transactionDetailsModel.Sum)"
                          Immediate="true" />

            <MudSelect T="int?" Label="@Localizer["Person"]" @bind-Value="_transactionDetailsModel.PersonId"
                       Clearable="true"
                       ToStringFunc="@PersonIdToName">
                @foreach (var p in _persons)
                {
                    <MudSelectItem T="int?" Value="@p.Id">@p.Name</MudSelectItem>
                }
            </MudSelect>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary"
                   OnClick="@(async () => await Save())">
            @(_isEditMode ? Localizer["Save"] : Localizer["AddEntry"])
        </MudButton>
        <MudButton Color="Color.Secondary"
                   OnClick="@Cancel">
            @Localizer["Cancel"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int TransactionId { get; set; }
    [Parameter] public int? TransactionDetailsId { get; set; }
    [Parameter] public int? SuggestedDocumentNumber { get; set; }

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    private MudForm _form = new();
    private TransactionDetailsModel _transactionDetailsModel = new();
    private bool _isEditMode;
    private IEnumerable<PersonModel> _persons = [];

    protected override async Task OnInitializedAsync()
    {
        _isEditMode = TransactionDetailsId.HasValue;
        _persons = await PersonService.GetAllPersonsAsync();
        await MudDialog.SetTitleAsync(_isEditMode ? Localizer["EditTransactionDetails"] : Localizer["AddTransactionDetails"]);
        await LoadTransactionDetailsAsync();
    }

    private async Task LoadTransactionDetailsAsync()
    {
        if (!_isEditMode)
        {
            _transactionDetailsModel = new TransactionDetailsModel
            {
                TransactionId = TransactionId,
                DocumentNumber = SuggestedDocumentNumber,
                Sum = 0m
            };
            return;
        }

        _transactionDetailsModel = await TransactionDetailsService
                                       .GetTransactionDetailsByIdAsync(TransactionDetailsId!.Value)
                                   ?? new TransactionDetailsModel { TransactionId = TransactionId };
    }

    private async Task Save()
    {
        await _form.Validate();
        if (!_form.IsValid)
            return;

        var result = _isEditMode
            ? await TransactionDetailsService.UpdateTransactionDetailsAsync(_transactionDetailsModel)
            : await TransactionDetailsService.AddTransactionDetailsAsync(_transactionDetailsModel);

        if (result.Status is OperationResultStatus.Success)
            MudDialog.Close(DialogResult.Ok(result));
        else
            await NotificationService.ShowOperationResultAsync(result);
    }

    private void Cancel() => MudDialog.Close(DialogResult.Ok(OperationResultFactory.Canceled()));

    private string PersonIdToName(int? id)
        => id is null ? string.Empty : _persons.FirstOrDefault(p => p.Id == id.Value)?.Name ?? string.Empty;
}
