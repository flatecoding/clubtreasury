@using TTCCashRegister.Data.Import.Dialogs
@using TTCCashRegister.Data.Source
@inject IDialogService DialogService
@inject NotificationService NotificationService

<MudNavMenu>
    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
    <MudNavLink Href="/transactions" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Money">Transaction</MudNavLink>
    <MudNavGroup Title="Settings" Expanded="false" Icon="@Icons.Material.Filled.Settings">
        <MudNavGroup Title="Cost unit" Expanded="false" Icon="@Icons.Material.Filled.Settings">
            <MudNavLink Href="/costunits" Match="NavLinkMatch.Prefix">Cost units</MudNavLink>
            <MudNavLink Href="/basicunits" Match="NavLinkMatch.Prefix">Basic position</MudNavLink>
            <MudNavLink Href="/unitdetails" Match="NavLinkMatch.Prefix">Position details</MudNavLink>
        </MudNavGroup>
        <MudNavGroup Title="Cash register" Expanded="false" Icon="@Icons.Material.Filled.AttachMoney">
            <MudNavLink Href="/cashregisters" Match="NavLinkMatch.Prefix">Cash Register</MudNavLink>
            <MudNavLink Href="/specialitems" Match="NavLinkMatch.Prefix">Special positions</MudNavLink>
        </MudNavGroup>
        <MudNavLink Href="/persons" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.People">Persons</MudNavLink>
    </MudNavGroup>
    <MudNavGroup Title="Import / Export data" Expanded="false" Icon="@Icons.Material.Filled.Save">
        <MudNavGroup Title="Import data">
            <MudNavLink
                OnClick="@(() => OpenImportCostUnitDialog())"
                Icon="@Icons.Material.Filled.FileUpload">Cost units
            </MudNavLink>
            <MudNavLink
                OnClick="@(() => OpenImportTransactionDialog())"
                Icon="@Icons.Material.Filled.FileUpload">Booking journals
            </MudNavLink>
        </MudNavGroup>
        <MudNavGroup Title="Export data">
            <MudNavLink Href="/exportcashaudit" Match="NavLinkMatch.Prefix">Cash audit</MudNavLink>
            <MudNavLink Href="/exportbudget" Match="NavLinkMatch.Prefix">Budget plan</MudNavLink>
        </MudNavGroup>
    </MudNavGroup>
    <MudNavLink Href="/about" Match="NavLinkMatch.Prefix">About</MudNavLink>
</MudNavMenu>

@code {
    
    private async Task OpenImportCostUnitDialog()
    {
        var parameters = new DialogParameters();
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ImportCostunits>("Import cost units", parameters, options);
        await NotificationService.ShowDialogResultAsync(await dialog.Result);
    }
    
    private async Task OpenImportTransactionDialog()
    {
        var parameters = new DialogParameters();
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ImportTransactionDialog>("Import booking journal", parameters, options);
        await NotificationService.ShowDialogResultAsync(await dialog.Result);
    }
    
}







