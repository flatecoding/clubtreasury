@using Microsoft.Extensions.Localization
@using TTCCashRegister.Data.DialogService.Dialog
@using TTCCashRegister.Data.Import.Dialogs
@using TTCCashRegister.Data.Notification
@using Translation = TTCCashRegister.Translation
@inject IDialogService DialogService
@inject INotificationService NotificationService
@inject IStringLocalizer<Translation> Localizer

<MudNavMenu>
    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">@Localizer["Dashboard"]</MudNavLink>
    <MudNavLink Href="/transactions" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Money">@Localizer["TransactionPlural"]</MudNavLink>
    <MudNavGroup Title="@Localizer["Settings"]" Expanded="false" Icon="@Icons.Material.Filled.Settings">
    <MudNavLink
        OnClick="@(() => OpenLanguageDialog())"
        Icon="@Icons.Material.Filled.Language">
        @Localizer["Language"]
    </MudNavLink>
    <MudNavGroup Title=@Localizer["CostConfiguration"] Expanded="false" Icon="@Icons.Material.Filled.Settings">
            <MudNavLink Href="/costCenters" Match="NavLinkMatch.Prefix">@Localizer["CostCenter"]</MudNavLink>
            <MudNavLink Href="/categories" Match="NavLinkMatch.Prefix">@Localizer["Category"]</MudNavLink>
            <MudNavLink Href="/itemdetails" Match="NavLinkMatch.Prefix">@Localizer["ItemDetail"]</MudNavLink>
            <MudNavLink Href="/allocations" Match="NavLinkMatch.Prefix">@Localizer["Allocation"]</MudNavLink>
        </MudNavGroup>
        <MudNavGroup Title=@Localizer["FinanceManagement"] Expanded="false" Icon="@Icons.Material.Filled.AttachMoney">
            <MudNavLink Href="/cashregisters" Match="NavLinkMatch.Prefix">@Localizer["CashRegister"]</MudNavLink>
            <MudNavLink Href="/specialitems" Match="NavLinkMatch.Prefix">@Localizer["SpecialPositions"]</MudNavLink>
        </MudNavGroup>
        <MudNavLink Href="/persons" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.People">@Localizer["Person"]</MudNavLink>
    </MudNavGroup>
    <MudNavGroup Title=@Localizer["ImportExport"] Expanded="false" Icon="@Icons.Material.Filled.Save">
        <MudNavGroup Title=@Localizer["ImportData"]>
            <MudNavLink
                OnClick="@(() => OpenImportCostCenterDialog())"
                Icon="@Icons.Material.Filled.FileUpload">@Localizer["CostCenter"]
            </MudNavLink>
            <MudNavLink
                OnClick="@(() => OpenImportTransactionDialog())"
                Icon="@Icons.Material.Filled.FileUpload">@Localizer["BookingJournal"]
            </MudNavLink>
        </MudNavGroup>
        <MudNavGroup Title=@Localizer["ExportData"]>
            <MudNavLink Href="/exportcashaudit" Match="NavLinkMatch.Prefix">@Localizer["CashAudit"]</MudNavLink>
            <MudNavLink Href="/exportbudget" Match="NavLinkMatch.Prefix">@Localizer["BudgetPlan"]</MudNavLink>
        </MudNavGroup>
    </MudNavGroup>
    <MudNavLink Href="/about" Match="NavLinkMatch.Prefix">@Localizer["About"]</MudNavLink>
</MudNavMenu>

@code {
    
    private async Task OpenImportCostCenterDialog()
    {
        var parameters = new DialogParameters();
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ImportCostCenters>(@Localizer["ImportCostCenterDialogTitle"], parameters, options);
        await NotificationService.ShowDialogResultAsync(await dialog.Result);
    }
    
    private async Task OpenImportTransactionDialog()
    {
        var parameters = new DialogParameters();
       
        DialogOptions importDialogOptions = new()
    {
        MaxWidth = MaxWidth.Medium,
        FullWidth = true,
        BackdropClick = false,
        BackgroundClass= "custom-dialog-background"
    };
        var dialog = await DialogService.ShowAsync<ImportTransactionDialog>(@Localizer["ImportTransactionDialogTitle"], parameters, 
            importDialogOptions);
        await NotificationService.ShowDialogResultAsync(await dialog.Result);
    }
    
    private async Task OpenLanguageDialog()
    {
        var parameters = new DialogParameters();

        DialogOptions options = new()
        {
            MaxWidth = MaxWidth.ExtraSmall,
            FullWidth = true,
            CloseButton = true,
            BackdropClick = true
        };

        var dialog = await DialogService.ShowAsync<LanguageSelectionDialog>(
            Localizer["LanguageDialogTitle"],
            parameters,
            options);

        await NotificationService.ShowDialogResultAsync(await dialog.Result);
    }
    
}







