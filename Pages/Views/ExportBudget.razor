@page "/exportbudget"
@using TTCCashRegister.Data.Models
@using TTCCashRegister.Pages.Dialogs
@inject TransactionService TransactionService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<h3>Export Data</h3>
<MudPaper Class="mt-4" Style="width:80%;">
    <MudTable Class="mt-2" Items="@_transactions" Dense="@Dense" Hover="@Hover" Bordered="@Bordered" Striped="@Striped" FixedHeader="true">
        <ToolBarContent>
            <MudButton Class = "ml-2"
                       Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.Download"
                       Color="Color.Secondary"
                       OnClick="ShowExportBudgetDialog">
                Export Transactions
            </MudButton>
        </ToolBarContent>
        <ColGroup>
            <col />    @*Doc. Nr*@
            <col />   @*Desciption*@
            <col style="width: 30px;" />    @*Sum*@
            <col style="width: 30px;" />    @*Acc. mvm.*@
        </ColGroup>
        <HeaderContent>
            <MudTh>Cost unit</MudTh>
            <MudTh>Position</MudTh>
            <MudTh>Position detail</MudTh>
            <MudTh>Acc. mvm.</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Cost unit">@context.Date</MudTd>
            <MudTd DataLabel="Position">@context.Documentnumber</MudTd>
            <MudTd DataLabel="Position detail">@context.Description</MudTd>
            <MudTd DataLabel="Acc. mvm.">@context.AccountMovement</MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
</MudPaper>

@code {
    private IEnumerable<Transaction>? _transactions;
    private const bool Dense = true;
    private const bool Hover = true;
    private const bool Striped = true;
    private const bool Bordered = false;
    
    protected override async Task OnInitializedAsync()
    {
         await base.OnInitializedAsync();
         _transactions = await TransactionService.GetAllTransactions();
    }

    private async Task ShowExportBudgetDialog()
    {
        var parameters = new DialogParameters();
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ExportBudgetDialog>("Export Budgets", parameters, options);
        var result = await dialog.Result;
        if (result?.Data is bool success && success)
        {
            Snackbar.Add("Transactions were exported successfully", Severity.Success);
        }
        else if (result?.Canceled == true)
        {
            Snackbar.Add("Transaction export was cancelled", Severity.Warning);
        }
        else
        {
            Snackbar.Add("Transactions could not be exported", Severity.Error);
        }
    }
}
