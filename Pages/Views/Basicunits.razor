@page "/basicunits"
@using TTCCashRegister.Data.Models
@using TTCCashRegister.Data.Services
@using TTCCashRegister.Pages.Dialogs
@inject BasicUnitService BasicUnitService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<h3>Basic Units</h3>

<MudPaper Class="mt-4" Style="width:55%;">
    <MudTable Class="mt-2" Items="@_allEntries" Dense="@Dense" Hover="@Hover" Bordered="@Bordered" Striped="@Striped" FixedHeader="true"
              @bind-SelectedItem="_selectedItem"
              Filter="new Func<BasicUnit,bool>(FilterFunc)"
              SortLabel="Sort By">
        <ToolBarContent>
            <MudButton Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.Add"
                       Color="Color.Primary"
                       OnClick="ShowAddBasicUnitDialog">
                Add Basic Unit
            </MudButton>
            <MudSpacer />
            <MudTextField @bind-Value="_searchString1"
                          Placeholder="Search"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium"
                          Class="mt-0">
            </MudTextField>
        </ToolBarContent>
        <ColGroup>
            <col style="width: 20px;" />
            <col style="width: 110px;" />
            <col style="width: 110px;" />
            <col style="width: 110px;" />
        </ColGroup>
        <HeaderContent>
            <MudTh>Id<MudTableSortLabel SortBy="new Func<BasicUnit, object>(x => x.Id)"></MudTableSortLabel></MudTh>
            <MudTh>Name<MudTableSortLabel SortBy="new Func<BasicUnit, object>(x => x.Name)"></MudTableSortLabel></MudTh>
            <MudTh>Details</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="ID">@context.Id</MudTd>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="Details">
                @if (context.CostUnitDetails.Any())
                {
                        @foreach (var detail in context.CostUnitDetails)
                        {
                           <li> @detail.CostDetails</li>
                        }
                }
                else
                {
                    <em>No details assigned</em>
                }

            </MudTd>
            <MudTd DataLabel="Actions">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Info" aria-label="edit" OnClick="() => ShowEditBasicUnitDialog(context.Id)"></MudIconButton>
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" aria-label="delete" OnClick="() => ShowDeleteBasicUnitDialog(context.Id)">Delete</MudIconButton>
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
</MudPaper>

@code {

    private IEnumerable<BasicUnit>? _allEntries;

    private const bool Dense = true;
    private const bool Hover = true;
    private const bool Striped = true;
    private const bool Bordered = false;
    private string _searchString1 = string.Empty;
    private BasicUnit _selectedItem = new();

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        _allEntries = await BasicUnitService.GetAllBasicUnitsAsync();
    }

    private bool FilterFunc(BasicUnit? element) => FilterFunc1(element, _searchString1);

    private bool FilterFunc1(BasicUnit? element, string searchstring)
    {
        if (string.IsNullOrWhiteSpace(searchstring))
            return true;
        if (element == null || string.IsNullOrWhiteSpace(searchstring)) return false;
        var lowerstring = searchstring.ToLowerInvariant();
        return element.Name.ToLower().Contains(lowerstring);
    }

    private async Task ShowAddBasicUnitDialog()
    {
        var parameters = new DialogParameters();
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<AddBasicUnitDialog>("Add Basic Unit", parameters, options);

        if ((await dialog.Result)?.Canceled == false)
        {
            _allEntries = await BasicUnitService.GetAllBasicUnitsAsync();
            Snackbar.Add("New basic unit was added successfully", Severity.Success);
        }
    }

    private async Task ShowEditBasicUnitDialog(int basicUnitId)
    {
        var parameters = new DialogParameters { ["BasicUnitId"] = basicUnitId };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<EditBasicUnitDialog>("Edit Basic Unit", parameters, options);
        if ((await dialog.Result)?.Canceled == false)
        {
            _allEntries = await BasicUnitService.GetAllBasicUnitsAsync();
            Snackbar.Add("Basic unit was updated successfully", Severity.Success);
        }
    }

    private async Task ShowDeleteBasicUnitDialog(int basicUnitId)
    {
        var parameters = new DialogParameters { ["BasicUnitId"] = basicUnitId };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<DeleteBasicUnitDialog>("Delete Basic Unit", parameters, options);
        if ((await dialog.Result)?.Canceled == false)
        {
            _allEntries = await BasicUnitService.GetAllBasicUnitsAsync();
            Snackbar.Add("Basic unit was deleted successfully", Severity.Success);
        }
    }
}
