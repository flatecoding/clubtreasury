@page "/specialitems"
@using TTCCashRegister.Data.Models
@using TTCCashRegister.Data.Services
@using TTCCashRegister.Pages.Dialogs
@inject SpecialItemService SpecialItemService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<h3>Special Items</h3>

<MudPaper Class="mt-4" Style="width:50%;">
    <MudTable Class="mt-2" Items="@_allEntries" Dense="@Dense" Hover="@Hover" Bordered="@Bordered" Striped="@Striped" FixedHeader="true"
              @bind-SelectedItem="_selectedItem"
              Filter="new Func<SpecialItem,bool>(FilterFunc)"
              SortLabel="Sort By">
        <ToolBarContent>
            <MudButton Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.Add"
                       Color="Color.Primary"
                       @onclick="ShowAddSpecialItemDialog">
                Add Special Item
            </MudButton>
            <MudSpacer />
            <MudTextField @bind-Value="_searchString1"
                          Placeholder="Search"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium"
                          Class="mt-0">
            </MudTextField>
        </ToolBarContent>
        <ColGroup>
            <col style="width: 20px;" />
            <col style="width: 110px;" />
            <col style="width: 110px;" />
            <col style="width: 110px;" />
        </ColGroup>
        <HeaderContent>
            <MudTh>Id<MudTableSortLabel SortBy="new Func<SpecialItem, object>(x => x.Id)"></MudTableSortLabel></MudTh>
            <MudTh>Name<MudTableSortLabel SortBy="new Func<SpecialItem, object>(x => x.Name)"></MudTableSortLabel></MudTh>
            <MudTh>Amount</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Id">@context.Id</MudTd>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="">@context.Betrag</MudTd>
            <MudTd DataLabel="Actions">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Info" aria-label="edit" @onclick="() => ShowEditSpecialItemDialog(context.Id)"></MudIconButton>
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" aria-label="delete" @onclick="() => ShowDeleteSpecialItemDialog(context.Id)">Delete</MudIconButton>
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
</MudPaper>

@code {
    private IEnumerable<SpecialItem>? _allEntries;
    private const bool Dense = true;
    private const bool Hover = true;
    private const bool Striped = true;
    private const bool Bordered = false;
    private string _searchString1 = string.Empty;
    private SpecialItem _selectedItem = new();

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        _allEntries = await SpecialItemService.GetAllSonderposten();
    }

    private bool FilterFunc(SpecialItem? element) => FilterFunc1(element, _searchString1);

    private bool FilterFunc1(SpecialItem? element, string searchstring)
    {
        if (string.IsNullOrWhiteSpace(searchstring))
            return true;
        if (element is not null && !string.IsNullOrWhiteSpace(searchstring))
        {
            if (element.Name.ToLower().Contains(searchstring.ToLowerInvariant()))
                return true;
        }
        return false;
    }

    private async Task ShowAddSpecialItemDialog()
    {
        var parameters = new DialogParameters();
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<AddSpecialItemDialog>("Add Special Item", parameters, options);

        if ((await dialog.Result)?.Canceled == false)
        {
            _allEntries = await SpecialItemService.GetAllSonderposten();
            Snackbar.Add("New special item was added successfully", Severity.Success);
        }
    }

    private async Task ShowEditSpecialItemDialog(int specialItemId)
    {
        var parameters = new DialogParameters { ["SpecialItemId"] = specialItemId };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<EditSpecialItemDialog>("Edit Special Item", parameters, options);
        if ((await dialog.Result)?.Canceled == false)
        {
            _allEntries = await SpecialItemService.GetAllSonderposten();
            Snackbar.Add("Special item was updated successfully", Severity.Success);
        }
    }

    private async Task ShowDeleteSpecialItemDialog(int specialItemId)
    {
        var parameters = new DialogParameters { ["SpecialItemId"] = specialItemId };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<DeleteSpecialItemDialog>("Delete Special Item", parameters, options);
        if ((await dialog.Result)?.Canceled == false)
        {
            _allEntries = await SpecialItemService.GetAllSonderposten();
            Snackbar.Add("Special item was deleted successfully", Severity.Success);
        }
    }
}
