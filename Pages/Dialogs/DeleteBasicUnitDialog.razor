@page "/deletebasicunit"
@using TTCCashRegister.Data.Models
@using TTCCashRegister.Data.Services
@inject BasicUnitService basicunitservice
@inject IDialogService DialogService

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h6">Are you sure you want to delete this basic unit?</MudText>
        <MudText Typo="Typo.subtitle1">@basicUnitName</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="DeleteBasicUnit">Delete</MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int BasicUnitId { get; set; }
    private string basicUnitName = string.Empty;

    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        var basicUnit = await basicunitservice.GetBasicUnitByIdAsync(BasicUnitId);
        if (basicUnit != null)
        {
            basicUnitName = basicUnit.Name;
        }
    }

    private async Task DeleteBasicUnit()
    {
        var success = await basicunitservice.DeleteBasicUnitAsync(BasicUnitId);
        if (success)
        {
            MudDialog.Close(DialogResult.Ok(true));
        }
        else
        {
            MudDialog.Close(DialogResult.Ok(false));
        }
    }

    private void Cancel()
    {
        MudDialog.Close(DialogResult.Cancel());
    }
}
