@page "/deletecashregister"
@using TTCCashRegister.Data.Models
@using TTCCashRegister.Data.Services
@inject CashRegisterService cashRegisterService
@inject IDialogService DialogService

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h6">Are you sure you want to delete this cash register?</MudText>
        <MudText Typo="Typo.subtitle1">@cashRegisterName</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="DeleteEntry">Delete</MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int CashRegisterId { get; set; }
    private string cashRegisterName = string.Empty;

    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        var cashRegister = await cashRegisterService.GetCashRegisterById(CashRegisterId);
        if (cashRegister != null)
        {
            cashRegisterName = cashRegister.Name;
        }
    }

    private async Task DeleteEntry()
    {
        var success = await cashRegisterService.DeleteCashRegister(CashRegisterId);
        if (success)
        {
            MudDialog.Close(DialogResult.Ok(true));
        }
        else
        {
            MudDialog.Close(DialogResult.Ok(false));
        }
    }

    private void Cancel()
    {
        MudDialog.Close(DialogResult.Cancel());
    }
}
