@page "/editbasicunit"
@using TTCCashRegister.Data.Models
@using TTCCashRegister.Data.Services
@inject BasicUnitService Basicunitservice

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form">
            <MudTextField @bind-Value="_editBasicUnit.Name" Label="Name" Required="true" RequiredError="Name is required." />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="!_form.IsValid" OnClick="SaveBasicUnit">Save</MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int BasicUnitId { get; set; }
    private MudForm _form = new();
    private BasicUnit _editBasicUnit = new();

    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        _editBasicUnit = await Basicunitservice.GetBasicUnitByIdAsync(BasicUnitId) ?? new BasicUnit();
    }

    private async Task SaveBasicUnit()
    {
        if (_form.IsValid)
        {
            await Basicunitservice.UpdateBasicUnitAsync(_editBasicUnit);
            MudDialog.Close(DialogResult.Ok(true));
        }
    }

    private void Cancel()
    {
        MudDialog.Close(DialogResult.Cancel());
    }
}
