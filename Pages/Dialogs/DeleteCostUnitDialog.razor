@page "/deletecostunit"
@using TTCCashRegister.Data.Models
@using TTCCashRegister.Data.Services
@inject CostUnitService costunitservice
@inject IDialogService DialogService

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h6">Are you sure you want to delete this cost unit?</MudText>
        <MudText Typo="Typo.subtitle1">@costUnitName</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="DeleteCostUnit">Delete</MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int CostUnitId { get; set; }
    private string costUnitName = string.Empty;

    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        var costUnit = await costunitservice.GetCostUnitByIdAsync(CostUnitId);
        if (costUnit != null)
        {
            costUnitName = costUnit.CostUnitName;
        }
    }

    private async Task DeleteCostUnit()
    {
        var success = await costunitservice.DeleteCostUnitAsync(CostUnitId);
        if (success)
        {
            MudDialog.Close(DialogResult.Ok(true));
        }
        else
        {
            MudDialog.Close(DialogResult.Ok(false));
        }
    }

    private void Cancel()
    {
        MudDialog.Close(DialogResult.Cancel());
    }
}
