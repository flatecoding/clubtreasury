@page "/editcostunit"
@using TTCCashRegister.Data.Models
@using TTCCashRegister.Data.Services
@inject CostUnitService CostUnitservice
@inject BasicUnitService BasicUnitservice

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form">
            <MudTextField @bind-Value="_editCostUnitCopy.CostUnitName" Label="Unit Name" Required="true" RequiredError="Unit name is required." />
            <MudSelect T="int" Label="Basic Units" @bind-SelectedValues="_selectedBasicUnitIds" MultiSelection="true" Required="true" ToStringFunc="Converter">
                @foreach (var basicUnit in _allBasicUnits)
                {
                    <MudSelectItem T="int" Value="@basicUnit.Id">@basicUnit.Name</MudSelectItem>
                }
            </MudSelect>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="!_form.IsValid" OnClick="SaveCostUnit">Save</MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int CostUnitId { get; set; }
    private MudForm _form = new();
    private CostUnit _editCostUnit = new();
    private CostUnit _editCostUnitCopy = new();
    private IEnumerable<BasicUnit> _allBasicUnits = new List<BasicUnit>();
    private IEnumerable<int> _selectedBasicUnitIds = new List<int>();

    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        _allBasicUnits = await BasicUnitservice.GetAllBasicUnitsAsync();
        // Load the existing CostUnit and its BasicUnits here
        _editCostUnit = await CostUnitservice.GetCostUnitByIdAsync(CostUnitId) ?? new CostUnit();

        _editCostUnitCopy = new CostUnit
        {
                Id = _editCostUnit.Id,
                CostUnitName = _editCostUnit.CostUnitName,
                BasicUnitDetails = new List<BasicUnit>(_editCostUnit.BasicUnitDetails)
        };
        _selectedBasicUnitIds = _editCostUnit.BasicUnitDetails.Select(bu => bu.Id).ToHashSet();
    }

    private async Task SaveCostUnit()
    {
        if (_form.IsValid)
        {
            // Update the BasicUnitDetails based on selectedBasicUnitIds
            _editCostUnit.CostUnitName = _editCostUnitCopy.CostUnitName;
            _editCostUnit.BasicUnitDetails = _allBasicUnits.Where(bu => _selectedBasicUnitIds.Contains(bu.Id)).ToList();
            await CostUnitservice.UpdateCostUnitAsync(_editCostUnit);
            MudDialog.Close(DialogResult.Ok(true));
        }
    }

    private void Cancel()
    {
        MudDialog.Close(DialogResult.Cancel());
    }

    private string Converter(int value)
    {
        if (value == 0)
        {
            return "Please select a Basic Unit";
        }
        var basicUnit = _allBasicUnits.FirstOrDefault(bu => bu.Id == value);
        return basicUnit?.Name ?? "Unknown";
    }
}
