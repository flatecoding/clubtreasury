@page "/addspecialitem"
@using TTCCashRegister.Data.Models
@using TTCCashRegister.Data.Services
@inject SpecialItemService SpecialItemService

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form">
            <MudTextField @bind-Value="_newSpecialItem.Name" Label="Name" Required="true" RequiredError="Name is required." />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="!_form.IsValid" OnClick="AddSpecialItem">Add</MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private MudForm _form = new();
    private readonly SpecialItem _newSpecialItem = new();

    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    private async Task AddSpecialItem()
    {
        if (_form.IsValid)
        {
            await SpecialItemService.AddSonderposten(_newSpecialItem);
            MudDialog.Close(DialogResult.Ok(true));
        }
    }

    private void Cancel()
    {
        MudDialog.Close(DialogResult.Cancel());
    }
}
