@page "/addcashregister"
@using TTCCashRegister.Data.Models
@using TTCCashRegister.Data.Services
@inject CashRegisterService cashRegisterService
@inject IDialogService DialogService

<MudDialog>
    <DialogContent>
        <MudForm @ref="form">
            <MudTextField @bind-Value="newCashRegister.Name" Label="Name" Required="true" RequiredError="Name is required." />
            <MudTextField @bind-Value="newCashRegister.CurrentBalance" Label="Current balance" Required="true" RequiredError="Current balance is required." />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="!form.IsValid" OnClick="AddEntry">Add</MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private MudForm form = new();
    private CashRegister newCashRegister = new();

    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    private async Task AddEntry()
    {
        if (form.IsValid)
        {
            await cashRegisterService.AddCashRegister(newCashRegister);
            MudDialog.Close(DialogResult.Ok(true));
        }
    }

    private void Cancel()
    {
        MudDialog.Close(DialogResult.Cancel());
    }
}
