@page "/editunitdetails"
@using TTCCashRegister.Data.Models
@using TTCCashRegister.Data.Services
@inject UnitDetailService UnitDetailService
@inject BasicUnitService BasicUnitService

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form">
            <MudTextField @bind-Value="_editUnitDetails.CostDetails" Label="Cost Details" Required="true" RequiredError="Cost details are required." />
            <MudSelect T="int" Label="Basic Unit" @bind-Value="_editUnitDetails.BasicUnitId" Required="true" ToStringFunc="Converter">
                @foreach (var basicUnit in _allBasicUnits)
                {
                    <MudSelectItem T="int" Value="@basicUnit.Id">@basicUnit.Name</MudSelectItem>
                }
            </MudSelect>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="!_form.IsValid" OnClick="SaveUnitDetails">Save</MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int UnitDetailsId { get; set; }
    private MudForm _form = new();
    private UnitDetails _editUnitDetails = new();
    private IEnumerable<BasicUnit> _allBasicUnits = new List<BasicUnit>();

    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        _allBasicUnits = await BasicUnitService.GetAllBasicUnitsAsync();
        _editUnitDetails = await UnitDetailService.GetUnitDetailsByIdAsync(UnitDetailsId) ?? new UnitDetails();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await _form.Validate();
        }
    }

    private async Task SaveUnitDetails()
    {
        if (_form.IsValid)
        {
            await UnitDetailService.UpdateUnitDetailsAsync(_editUnitDetails);
            MudDialog.Close(DialogResult.Ok(true));
        }
    }

    private void Cancel()
    {
        MudDialog.Close(DialogResult.Cancel());
    }

    private string Converter(int value)
    {
        if (value == 0)
        {
            return "Please select a Basic Unit";
        }
        var basicUnit = _allBasicUnits.FirstOrDefault(bu => bu.Id == value);
        return basicUnit?.Name ?? "Unknown";
    }
}
