@page "/editspecialitem"
@using TTCCashRegister.Data.Models
@using TTCCashRegister.Data.Services
@inject SpecialItemService SpecialItemService

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form">
            <MudTextField @bind-Value="_editSpecialItem.Name" Label="Name" Required="true" RequiredError="Name is required." />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="!_form.IsValid" OnClick="SaveSpecialItem">Save</MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int SpecialItemId { get; set; }
    private MudForm _form = new();
    private SpecialItem _editSpecialItem = new();

    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        _editSpecialItem = await SpecialItemService.GetSonderpostenById(SpecialItemId) ?? new SpecialItem();
    }

    private async Task SaveSpecialItem()
    {
        if (_form.IsValid)
        {
            await SpecialItemService.UpdateSonderposten(_editSpecialItem);
            MudDialog.Close(DialogResult.Ok(true));
        }
    }

    private void Cancel()
    {
        MudDialog.Close(DialogResult.Cancel());
    }
}
