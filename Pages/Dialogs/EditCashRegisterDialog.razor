@page "/editcashregister"
@using TTCCashRegister.Data.Models
@using TTCCashRegister.Data.Services
@inject CashRegisterService CashRegisterService

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form">
            <MudTextField @bind-Value="_editCashRegister.Name" Label="Name" Required="true" RequiredError="Name is required." />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="!_form.IsValid" OnClick="SaveCashRegister">Save</MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int CashRegisterId { get; set; }
    private MudForm _form = new();
    private CashRegister _editCashRegister = new();

    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        _editCashRegister = await CashRegisterService.GetCashRegisterById(CashRegisterId) ?? new CashRegister();
    }

    private async Task SaveCashRegister()
    {
        if (_form.IsValid)
        {
            await CashRegisterService.UpdateCashRegister(_editCashRegister);
            MudDialog.Close(DialogResult.Ok(true));
        }
    }

    private void Cancel()
    {
        MudDialog.Close(DialogResult.Cancel());
    }
}
