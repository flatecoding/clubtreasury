@page "/edittransaction"
@using TTCCashRegister.Data.Models
@using TTCCashRegister.Data.Services
@inject TransactionService transactionService
@inject CostUnitService costUnitService
@inject BasicUnitService basicUnitService
@inject SpecialItemService specialItemService
@inject CashRegisterService cashRegisterService
@inject IDialogService DialogService

<MudDialog>
    <DialogContent>
        <MudForm @ref="form">
            <MudSelect T="CashRegister"
                       Label="Cash register"
                       Required="true"
                       ToStringFunc="@CashRegisterconverter"
                       Immediate="true"
                       @bind-Value="@selectedCashRegister"
                       @bind-Value:after="OnCashRegisterChangedAsync">
                @if (cashRegisters is not null)
                {
                    @foreach (var cash in cashRegisters)
                    {
                        <MudSelectItem T="CashRegister" Value="@cash">@cash.Name</MudSelectItem>
                    }
                }
            </MudSelect>
            <MudDatePicker @bind-Date="@transactionDateTime" Label="Date" Required="true" RequiredError="Date is required." />
            <MudTextField @bind-Value="editTransactionCopy.Documentnumber" Label="Document Number" Required="true" RequiredError="Document number is required." />
            <MudTextField @bind-Value="editTransactionCopy.Description" Label="Description" Required="true" RequiredError="Description is required." />
            <MudTextField @bind-Value="editTransactionCopy.Sum" Label="Sum" Required="true" RequiredError="Sum is required." />
            <MudTextField @bind-Value="editTransactionCopy.AccountMovement" Label="Account Movement" Required="true" RequiredError="Account movement is required." />

            <MudSelect T="CostUnit"
                       Label="Cost Unit"
                       Required="true"
                       ToStringFunc="@Unitconverter"
                       Immediate="true"
                       @bind-Value="@selectedCostUnit"
                       @bind-Value:after="OnCostUnitChangedAsync">
                @if (costUnits is not null)
                {
                    @foreach (var Unit in costUnits)
                    {
                        <MudSelectItem T="CostUnit" Value="@Unit">@Unit.CostUnitName</MudSelectItem>
                    }
                }
            </MudSelect>
            <MudSelect T="BasicUnit"
                       Label="Basic Unit"
                       Disabled="@(string.IsNullOrEmpty(selectedCostUnit.CostUnitName))"
                       Required="true"
                       ToStringFunc="@BasicUnitconverter"
                       @bind-Value="selectedBasicUnit"
                       @bind-Value:after="OnBasicUnitChangedAsync">
                @if (basicUnits is not null)
                {
                    @foreach (var basicUnit in basicUnits)
                    {
                        <MudSelectItem T="BasicUnit" Value="@basicUnit">@basicUnit.Name</MudSelectItem>
                    }
                }
            </MudSelect>
            <MudSelect T="UnitDetails"
                       Label="Unit Details"
                       Disabled="@(string.IsNullOrEmpty(selectedBasicUnit.Name))"
                       ToStringFunc="@Detailsconverter"
                       @bind-Value="selectedUnitDetails">
                <MudSelectItem T="UnitDetails" Value="null">None</MudSelectItem>
                @if (unitDetails is not null)
                {
                    @foreach (var unitDetail in unitDetails)
                    {
                        <MudSelectItem T="UnitDetails" Value="@unitDetail">@unitDetail.CostDetails</MudSelectItem>
                    }
                }
            </MudSelect>
            <MudSelect T="SpecialItem"
                       Label="SpecialItem"
                       ToStringFunc="@SpecialItemConverter"
                       Placeholder="Select special position if required"
                       @bind-Value="selectedSpecialItem">
                <MudSelectItem T="SpecialItem" Value="null">None</MudSelectItem>
                @foreach (var SpecialItem in SpecialItemList)
                {
                    <MudSelectItem T="SpecialItem" Value="@SpecialItem">@SpecialItem.Name</MudSelectItem>
                }
            </MudSelect>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="!form.IsValid" OnClick="SaveTransaction">Save</MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int TransactionId { get; set; }
    private MudForm form = new();
    private Transaction editTransaction = new();
    private Transaction editTransactionCopy = new();
    private DateTime? transactionDateTime;
    private IEnumerable<CostUnit> costUnits = new List<CostUnit>();
    private IEnumerable<BasicUnit> basicUnits = new List<BasicUnit>();
    private IEnumerable<UnitDetails> unitDetails = new List<UnitDetails>();
    private IEnumerable<CashRegister> cashRegisters = new List<CashRegister>();
    private CostUnit selectedCostUnit = new();
    private BasicUnit selectedBasicUnit = new();
    private UnitDetails selectedUnitDetails = new();
    private IEnumerable<SpecialItem> SpecialItemList = new List<SpecialItem>();
    private SpecialItem? selectedSpecialItem = new();
    private CashRegister selectedCashRegister = new();

    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    Func<CashRegister, string> CashRegisterconverter = p => p?.Name ?? string.Empty;
    Func<DateTime, string> DateOnlyConverter = d => d.ToString() ?? string.Empty;
    Func<CostUnit, string> Unitconverter = p => p?.CostUnitName ?? string.Empty;
    Func<UnitDetails, string> Detailsconverter = d => d?.CostDetails ?? string.Empty;
    Func<SpecialItem, string> SpecialItemConverter = s => s?.Name ?? string.Empty;
    Func<BasicUnit, string> BasicUnitconverter = b => b?.Name ?? string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            editTransaction = await transactionService.GetTransactionByIdAsync(TransactionId) ?? new Transaction();

            editTransactionCopy = new Transaction
                {
                    Id = editTransaction.Id,
                    Description = editTransaction.Description,
                    AccountMovement = editTransaction.AccountMovement,
                    Date = editTransaction.Date,
                    CashRegisterID = editTransaction.CashRegisterID,
                    SpecialItemID = editTransaction.SpecialItemID,
                    Sum = editTransaction.Sum,
                    CostUnitID = editTransaction.CostUnitID,
                    BasicUnitID = editTransaction.BasicUnitID,
                    Documentnumber = editTransaction.Documentnumber

                };

            if (editTransaction.Date.HasValue)
            {
                transactionDateTime = editTransaction.Date.Value.ToDateTime(new TimeOnly(0, 0));
            }

            costUnits = await costUnitService.GetAllUnitsAsync();
            basicUnits = await basicUnitService.GetAllBasicUnitsAsync();
            SpecialItemList = await specialItemService.GetAllSonderposten();
            cashRegisters = await cashRegisterService.GetAllCashRegisters();

            selectedCashRegister = cashRegisters.FirstOrDefault(c => c.ID == editTransaction.CashRegisterID) ?? new CashRegister();
            selectedCostUnit = costUnits.FirstOrDefault(c => c.Id == editTransaction.CostUnitID) ?? new CostUnit();
            selectedBasicUnit = basicUnits.FirstOrDefault(b => b.Id == editTransaction.BasicUnitID) ?? new BasicUnit();
            selectedSpecialItem = SpecialItemList.FirstOrDefault(s => s.Id == editTransaction.SpecialItemID);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error during init: {ex.Message}");
        }
    }

    private async Task OnCostUnitChangedAsync()
    {
        basicUnits = selectedCostUnit?.BasicUnitDetails ?? new List<BasicUnit>();
        selectedBasicUnit = new BasicUnit();
        unitDetails = new List<UnitDetails>();
        selectedUnitDetails = new UnitDetails();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnBasicUnitChangedAsync()
    {
        unitDetails = selectedBasicUnit?.CostUnitDetails ?? new List<UnitDetails>();
        selectedUnitDetails = new();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnCashRegisterChangedAsync()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async Task SaveTransaction()
    {
        if (form.IsValid)
        {
            editTransaction.Description = editTransactionCopy.Description;
            editTransaction.Sum = editTransactionCopy.Sum;
            editTransaction.AccountMovement = editTransactionCopy.AccountMovement;
            if (transactionDateTime.HasValue)
            {
                editTransaction.Date = DateOnly.FromDateTime(transactionDateTime.Value);
            }
            editTransaction.CostUnitID = selectedCostUnit?.Id ?? 0;
            editTransaction.BasicUnitID = selectedBasicUnit?.Id ?? 0;

            if (selectedUnitDetails is not null)
            {
                editTransaction.UnitDetailsId = selectedUnitDetails.Id;
                editTransaction.UnitDetails = selectedUnitDetails;
            }
            if (selectedSpecialItem is not null)
            {
                editTransaction.SpecialItemID = selectedSpecialItem.Id;
                editTransaction.SpecialItem = selectedSpecialItem;
            }

            var success = await transactionService.UpdateTransactionAsync(editTransactionCopy);
            MudDialog.Close(DialogResult.Ok(success));
        }
    }

    private void Cancel()
    {
        MudDialog.Close(DialogResult.Cancel());
    }
}
