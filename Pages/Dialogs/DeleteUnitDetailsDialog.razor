@page "/deleteunitdetails"
@using TTCCashRegister.Data.Models
@using TTCCashRegister.Data.Services
@inject UnitDetailService unitDetailsService
@inject IDialogService DialogService

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h6">Are you sure you want to delete this detail?</MudText>
        <MudText Typo="Typo.subtitle1">@unitDetailsName</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="DeleteUnitDetails">Delete</MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int UnitDetailsId { get; set; }
    private string unitDetailsName = string.Empty;

    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        var unitDetails = await unitDetailsService.GetUnitDetailsByIdAsync(UnitDetailsId);
        if (unitDetails != null)
        {
            unitDetailsName = unitDetails.CostDetails;
        }
    }

    private async Task DeleteUnitDetails()
    {
        var success = await unitDetailsService.DeleteUnitDetailsAsync(UnitDetailsId);
        if (success)
        {
            MudDialog.Close(DialogResult.Ok(true));
        }
        else
        {
            MudDialog.Close(DialogResult.Ok(false));
        }
    }

    private void Cancel()
    {
        MudDialog.Close(DialogResult.Cancel());
    }
}
