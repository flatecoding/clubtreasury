@page "/addcostunit"
@using TTCCashRegister.Data.Models
@using TTCCashRegister.Data.Services
@inject CostUnitService CostUnitService

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form">
            <MudTextField @bind-Value="_newCostUnit.CostUnitName" Label="Unit Name" Required="true" RequiredError="Unit name is required." />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="!_form.IsValid" OnClick="AddCostUnit">Add</MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private MudForm _form = new();
    private readonly CostUnit _newCostUnit = new();
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;
    
    private async Task AddCostUnit()
    {
        if (_form.IsValid)
        {
            await CostUnitService.AddCostUnit(_newCostUnit);
            MudDialog.Close(DialogResult.Ok(true));
        }
    }

    private void Cancel()
    {
        MudDialog.Close(DialogResult.Cancel());
    }
}
