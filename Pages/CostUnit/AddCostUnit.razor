@page "/addcostunit"
@using TTCCashRegister.Data.Models
@using TTCCashRegister.Data.Services
@inject CostUnitService costunitService
@inject NavigationManager navigationManager
@inject ISnackbar Snackbar


<h3>Add new cost unit</h3>
<MudItem Class="d-flex align-center">
    <MudCard>
        <MudCardContent>
            <MudTextField class="mb-2" Label="Name" @bind-Value="@costunit.CostUnitName" Variant="Variant.Outlined"></MudTextField>
            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Label="Add" @onclick="@AddUnit">Add</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Error" Label="Cancel" @onclick="@Cancel">Close</MudButton>
        </MudCardContent>
    </MudCard>
</MudItem> 


@code {
    CostUnit costunit = new()
    {
        CostUnitName = string.Empty,
        CostUnitDetails = null
    };

    private void ClearPageContent()
    {
        costunit.CostUnitName = string.Empty;
        StateHasChanged();
    }

    public async void AddUnit()
    {
        if (costunit is null)
        {
            return;
        }
        else
        {   
            if (await costunitService.AddUnit(costunit))
            {
                Snackbar.Add("New sector was added added successfully", Severity.Success);
                ClearPageContent();
            }
            else
            {
                Snackbar.Add("An error occured", Severity.Error);
            }
        }
    }

    public void Cancel()
    {
        navigationManager.NavigateTo("/costunits");
    }

}
